---
import Base from "../layouts/Base.astro";
import Kiosk from "../components/views/Kiosk.astro";
import { t } from "../lib/i18n";
const lang = "de" as const;
const ui = t(lang);
---
<Base lang={lang} title={ui.kiosk_title} description={ui.kiosk_sub} path="/demos/" altPath="/en/demos/">
  <Kiosk lang={lang} />
</Base>
