---
import Base from "../../layouts/Base.astro";
import ContactForm from "../../components/ContactForm.astro";
import { t } from "../../lib/i18n";
const lang = "zh" as const;
const ui = t(lang);
---
<Base lang={lang} title={ui.contact_title} description={ui.contact_intro} path="/cn/kontakt/" altPath="/kontakt/">
  <div class="wrap contact-grid">
    <ContactForm lang={lang} bare />
    <aside class="contact-aside" data-reveal>
      <h2>接下来会发生什么</h2>
      <ol class="contact-steps">
        <li><span class="step-n">1</span><span>您把最扎心的问题发给我们——原始、未经整理都行。</span></li>
        <li><span class="step-n">2</span><span>我们会带着一份具体的解决方案草图回复您。</span></li>
        <li><span class="step-n">3</span><span>不会有邮件列表，也没有销售套话。</span></li>
      </ol>
      <div class="contact-direct">
        <p class="cd-label">更想用邮件？</p>
        <a href="mailto:hallo@datendrang.com">hallo@datendrang.com</a>
      </div>
    </aside>
  </div>
</Base>
