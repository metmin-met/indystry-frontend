---
import Base from "../layouts/Base.astro";
import ContactForm from "../components/ContactForm.astro";
import { t } from "../lib/i18n";
const lang = "de" as const;
const ui = t(lang);
---
<Base lang={lang} title={ui.contact_title} description={ui.contact_intro} path="/kontakt/" altPath="/en/kontakt/">
  <div class="wrap contact-grid">
    <ContactForm lang={lang} bare />
    <aside class="contact-aside" data-reveal>
      <h2>So geht's weiter</h2>
      <ol class="contact-steps">
        <li><span class="step-n">1</span><span>Du schickst, wo's klemmt — roh, unsortiert.</span></li>
        <li><span class="step-n">2</span><span>Wir melden uns mit einer konkreten Lösungsskizze.</span></li>
        <li><span class="step-n">3</span><span>Kein Verteiler, kein Sales-Blabla.</span></li>
      </ol>
      <div class="contact-direct">
        <p class="cd-label">Lieber direkt schreiben?</p>
        <a href="mailto:hallo@datendrang.com">hallo@datendrang.com</a>
      </div>
    </aside>
  </div>
</Base>
