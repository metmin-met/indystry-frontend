---
// Ambient-Easter-Egg: ein Käfer krabbelt am unteren Rand, knabbert kurz, wandert
// zur Wiese, verpuppt sich und wird zum Schmetterling. Läuft EINMAL pro Seitenaufruf.
// Minimalistisch (Strich/ink, monochrom), pointer-events:none, reduced-motion-safe.
// Haltung statt Reflex: Bugs werden nicht zerquetscht — sie dürfen sich entwickeln.
---
<div class="critter-stage" aria-hidden="true">
  <svg class="meadow" width="56" height="22" viewBox="0 0 56 22" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
    <path d="M6 22 V13 M6 16 l-4 -3 M6 17 l4 -4" />
    <path d="M16 22 V10 M16 14 l-4 -3 M16 15 l4 -4" />
    <path d="M26 22 V14 M26 17 l-4 -3 M26 18 l4 -4" />
  </svg>
  <div class="traveler">
    <svg class="bug" width="22" height="16" viewBox="0 0 22 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
      <ellipse cx="11" cy="8" rx="5" ry="3.4" fill="currentColor" stroke="none"/>
      <line x1="6" y1="8" x2="2" y2="5"/><line x1="6" y1="8" x2="2" y2="8"/><line x1="6" y1="9" x2="2" y2="12"/>
      <line x1="16" y1="8" x2="20" y2="5"/><line x1="16" y1="8" x2="20" y2="8"/><line x1="16" y1="9" x2="20" y2="12"/>
      <line x1="14" y1="6" x2="17" y2="3"/><line x1="14" y1="7" x2="18" y2="6"/>
    </svg>
    <svg class="cocoon" width="14" height="20" viewBox="0 0 14 20" fill="none" stroke="currentColor" stroke-width="1.2">
      <path d="M7 1 C2 4 2 14 7 19 C12 14 12 4 7 1 Z" fill="currentColor" fill-opacity=".15"/>
      <path d="M4 6 h6 M3.5 10 h7 M4 14 h6" stroke-linecap="round"/>
    </svg>
    <svg class="butterfly" width="26" height="22" viewBox="0 0 26 22" fill="none" stroke="currentColor" stroke-width="1.2">
      <line x1="13" y1="5" x2="13" y2="17"/>
      <path class="wing wl" d="M13 9 C4 0 0 7 4 12 C7 16 11 13 13 11 Z" fill="currentColor" fill-opacity=".18"/>
      <path class="wing wr" d="M13 9 C22 0 26 7 22 12 C19 16 15 13 13 11 Z" fill="currentColor" fill-opacity=".18"/>
      <path d="M13 5 l-2 -3 M13 5 l2 -3" stroke-linecap="round"/>
    </svg>
  </div>
</div>

<style>
  .critter-stage { position: fixed; left: 0; bottom: 6px; width: 100%; height: 24px; pointer-events: none; z-index: 30; color: var(--muted); }
  .meadow { position: absolute; left: 9vw; bottom: 0; opacity: 0; animation: meadow-in 22s ease forwards; }
  .traveler { position: absolute; bottom: 2px; left: 0; animation: travel 22s ease-in-out forwards; }
  .traveler > svg { position: absolute; bottom: 0; left: 0; }
  .bug { animation: bug-life 22s ease forwards; }
  .cocoon { opacity: 0; animation: cocoon-life 22s ease forwards; }
  .butterfly { opacity: 0; animation: fly 22s ease forwards; }
  .wl { transform-origin: 13px 10px; animation: flap .3s ease-in-out infinite; }
  .wr { transform-origin: 13px 10px; animation: flap .3s ease-in-out infinite; }
  @keyframes travel {
    0% { transform: translateX(90vw); }
    14% { transform: translateX(60vw); }
    20% { transform: translateX(59vw); }
    40% { transform: translateX(12vw); }
    46% { transform: translateX(10vw); }
    100% { transform: translateX(10vw); }
  }
  @keyframes bug-life { 0%,45% { opacity: 1; } 51%,100% { opacity: 0; } }
  @keyframes cocoon-life { 0%,49% { opacity: 0; } 54%,66% { opacity: 1; } 72%,100% { opacity: 0; } }
  @keyframes fly {
    0%,68% { opacity: 0; transform: translate(0,0); }
    73% { opacity: 1; transform: translate(0,0); }
    92% { opacity: 1; transform: translate(16px,-72px); }
    100% { opacity: 0; transform: translate(28px,-112px); }
  }
  @keyframes flap { 0%,100% { transform: scaleX(1); } 50% { transform: scaleX(.5); } }
  @keyframes meadow-in { 0%,30% { opacity: 0; } 40%,90% { opacity: 1; } 100% { opacity: .6; } }
  @media (prefers-reduced-motion: reduce) { .critter-stage { display: none; } }
</style>
