---
// Zusammenarbeit & Dateiraum (read-only, lang-aware): geteilter Dateiraum (Ordner → Dateien →
// Vorschau) + Aktivitätsfeed. Kohärenter Facetten-Inhalt zur Demo-Firma Nordwerk.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
const L = (d: string, e: string, c?: string) => (de ? d : en ? e : (c ?? e));
const folders = [
  { key: "angebote", name: L("Angebote","Quotes","报价"), files: [
    { n: "Angebot NW-1001 — Helvetia Pumpen.pdf", t: "PDF", s: "182 KB", who: "Jonas K.", when: L("vor 5 h","5 h ago","5 小时前") },
    { n: "Angebot NW-2010 — Alpentech.pdf", t: "PDF", s: "204 KB", who: "Jonas K.", when: L("gestern","yesterday","昨天") },
  ]},
  { key: "auftraege", name: L("Aufträge","Orders","订单"), files: [
    { n: "Auftrag SO-0042 — Donau Maschinenbau.pdf", t: "PDF", s: "96 KB", who: "Lena S.", when: L("vor 3 h","3 h ago","3 小时前") },
    { n: "Lieferschein NW-4002.pdf", t: "PDF", s: "78 KB", who: "Lena S.", when: L("gestern","yesterday","昨天") },
  ]},
  { key: "zeichnungen", name: L("Zeichnungen","Drawings","图纸"), files: [
    { n: "Lagerbock Typ A.dxf", t: "DXF", s: "1,2 MB", who: "Tom B.", when: L("vorgestern","2 days ago","前天") },
    { n: "Flanschplatte 120.step", t: "STEP", s: "3,4 MB", who: "Tom B.", when: L("gestern","yesterday","昨天") },
    { n: "Gehäusedeckel.pdf", t: "PDF", s: "512 KB", who: "Tom B.", when: L("letzte Woche","last week","上周") },
  ]},
  { key: "pruefung", name: L("Prüfprotokolle","Inspection records","检验记录"), files: [
    { n: "Prüfprotokoll NW-2010 — Charge 23.pdf", t: "PDF", s: "144 KB", who: "Mara R.", when: L("vor 2 h","2 h ago","2 小时前") },
    { n: "Maßprotokoll NW-1001.xlsx", t: "XLSX", s: "38 KB", who: "Mara R.", when: L("gestern","yesterday","昨天") },
  ]},
  { key: "wartung", name: L("Wartung","Maintenance","维护"), files: [
    { n: "Wartungsplan Linie Nord.xlsx", t: "XLSX", s: "52 KB", who: "Lena S.", when: L("gestern","yesterday","昨天") },
    { n: "Hydraulik K1 — Bericht.pdf", t: "PDF", s: "210 KB", who: "Tom B.", when: L("letzte Woche","last week","上周") },
  ]},
  { key: "handbuch", name: L("Handbuch","Handbook","手册"), files: [
    { n: "Rüsten CNC.pdf", t: "PDF", s: "320 KB", who: "Jonas K.", when: L("letzte Woche","last week","上周") },
    { n: "Qualitätsrichtlinie.pdf", t: "PDF", s: "188 KB", who: "Mara R.", when: L("vor 2 Wochen","2 weeks ago","2 周前") },
  ]},
];
const activity = [
  { who: "Mara R.", act: L("hat Prüfprotokoll NW-2010 hochgeladen","uploaded inspection record NW-2010","上传了检验记录 NW-2010"), when: L("vor 2 h","2 h ago","2 小时前") },
  { who: "Jonas K.", act: L("hat Angebot NW-1001 kommentiert","commented on quote NW-1001","对报价 NW-1001 添加了评论"), when: L("vor 5 h","5 h ago","5 小时前") },
  { who: "Lena S.", act: L("hat den Wartungsplan Linie Nord aktualisiert","updated the maintenance plan line North","更新了北线维护计划"), when: L("gestern","yesterday","昨天") },
  { who: "Tom B.", act: L("hat die Zeichnung Flanschplatte 120 freigegeben","released the drawing Flange plate 120","发布了图纸 Flanschplatte 120"), when: L("gestern","yesterday","昨天") },
];
---
<section style="background:#F8F9FA;" data-de={String(de)}>
  <div style="max-width:1100px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{L("Zusammenarbeit · Dateiraum · read-only","Collaboration · file room · read-only","协作 · 文件空间 · read-only")}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(34px,6vw,64px); line-height:1.0; letter-spacing:-0.03em; margin:0 0 14px;">{L("Ein Raum für alle Dokumente.","One room for every document.","所有文档，一个空间。")}</h1>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#5C5E63; max-width:62ch; margin:0 0 clamp(32px,4vw,44px);">{L("Angebote, Zeichnungen, Prüfprotokolle, Wartung — geteilt, versioniert, kommentierbar. Selbst gehostet, kein fremder Cloud-Speicher.","Quotes, drawings, inspection records, maintenance — shared, versioned, commentable. Self-hosted, no third-party cloud.","报价、图纸、检验记录、维护——共享、版本化、可评论。自托管，无第三方云存储。")}</p>

    <div id="folderbar" style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:18px;">
      {folders.map((f, i) => (
        <button class="fbtn" data-key={f.key} aria-pressed={i === 0 ? "true" : "false"}
          style="font-family:var(--font-mono); font-size:12px; padding:7px 13px; border:1px solid #C0C8C5; border-radius:999px; background:#fff; cursor:pointer; color:#3C3E42;">
          {f.name} <span style="color:#92938F;">· {f.files.length}</span>
        </button>
      ))}
    </div>

    <div style="display:grid; grid-template-columns:1.3fr 1fr; gap:20px; align-items:start;">
      <div>
        {folders.map((f, i) => (
          <div class="flist" data-key={f.key} style={`border:1px solid #E2E8F0; border-radius:12px; background:#fff; overflow:hidden; ${i === 0 ? "" : "display:none;"}`}>
            {f.files.map((file, j) => (
              <button class="frow" data-n={file.n} data-t={file.t} data-s={file.s} data-who={file.who} data-when={file.when}
                style={`display:grid; grid-template-columns:auto 1fr auto; gap:12px; align-items:center; width:100%; text-align:left; padding:13px 16px; background:none; border:none; cursor:pointer; font-family:inherit; ${j ? "border-top:1px solid #F1F3F2;" : ""}`}>
                <span style="font-family:var(--font-mono); font-size:10px; font-weight:600; color:#16463E; border:1px solid #C0C8C5; border-radius:5px; padding:3px 6px; min-width:34px; text-align:center;">{file.t}</span>
                <span style="font-size:15px; color:#1B1C1E;">{file.n}</span>
                <span style="font-family:var(--font-mono); font-size:11px; color:#92938F;">{file.s}</span>
              </button>
            ))}
          </div>
        ))}
      </div>

      <div style="display:flex; flex-direction:column; gap:16px;">
        <div id="preview" style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:18px; min-height:150px;">
          <p style="font-family:var(--font-mono); font-size:11px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:#92938F; margin:0 0 10px;">{L("Vorschau","Preview","预览")}</p>
          <p id="pv" style="color:#92938F; font-size:14px; margin:0;">{L("Datei links anklicken.","Click a file on the left.","请点击左侧文件。")}</p>
        </div>
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:18px;">
          <p style="font-family:var(--font-mono); font-size:11px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:#92938F; margin:0 0 12px;">{L("Aktivität","Activity","动态")}</p>
          {activity.map((a) => (
            <div style="display:flex; gap:10px; padding:8px 0; border-top:1px solid #F1F3F2; font-size:14px; color:#1B1C1E;">
              <span style="width:26px;height:26px;border-radius:50%;background:#EFEAE0;display:inline-flex;align-items:center;justify-content:center;font:600 11px var(--font-head,sans-serif);color:#16463E;flex:none;">{a.who.slice(0,1)}</span>
              <span style="line-height:1.45;"><strong style="font-weight:600;">{a.who}</strong> {a.act} <span style="color:#92938F; font-family:var(--font-mono); font-size:11px;">· {a.when}</span></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- KOLLABORATION-TIEFE -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:8px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">{L("Mehr als ein Dateiraum","More than a file room","不止是文件空间")}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span>
    </div>
    <h2 style="font-family:var(--font-head); font-weight:700; font-size:clamp(26px,4vw,44px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 24px; max-width:22ch;">{L("Zusammenarbeiten, wo die Arbeit ist.","Collaborate where the work is.","在工作现场协作。")}</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(244px,1fr)); gap:12px;"><div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{L("Projekte & Meilensteine","Projects & milestones","项目与里程碑")}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{L("Gantt-Roadmap mit Abhängigkeiten, kritischem Pfad und Stakeholder-Abnahme.","Gantt roadmap with dependencies, critical path and stakeholder sign-off.","甘特路线图，含依赖关系、关键路径与干系人验收。")}</p></div><div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{L("Whiteboard in Echtzeit","Real-time whiteboard","实时白板")}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{L("Gemeinsam skizzieren — direkt am Datensatz, alle sehen denselben Stand.","Sketch together — right on the record, everyone sees the same state.","协同勾画——直接在记录上进行，所有人看到同一状态。")}</p></div><div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{L("Chat-Brücke","Chat bridge","聊天桥接")}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{L("Jeder Auftrag hat seinen Raum: Notizen aus dem ERP und Chat (Ende-zu-Ende) verbunden.","Every order has its room: ERP notes and chat (end-to-end) connected.","每个订单都有专属空间：ERP 备注与聊天（端到端加密）互联。")}</p></div><div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{L("Diagramme aus Text","Diagrams from text","文字生成图表")}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{L("Abläufe und Pläne als Text schreiben — versioniert, sofort als Diagramm gerendert.","Write flows and plans as text — versioned, instantly rendered as a diagram.","用文字撰写流程与方案——版本化，即时渲染为图表。")}</p></div></div>
  </div>
</section>

<script>
  const DE = document.querySelector("[data-de]")?.getAttribute("data-de") === "true";
  document.querySelectorAll(".fbtn").forEach((b) => {
    b.addEventListener("click", () => {
      const key = b.getAttribute("data-key");
      document.querySelectorAll(".fbtn").forEach((x) => x.setAttribute("aria-pressed", String(x === b)));
      document.querySelectorAll(".fbtn").forEach((x) => x.setAttribute("style", x.getAttribute("style").replace(/background:#EFEAE0;?/,"") + (x === b ? "background:#EFEAE0;" : "")));
      document.querySelectorAll(".flist").forEach((l) => { l.style.display = l.getAttribute("data-key") === key ? "" : "none"; });
    });
  });
  const pv = document.getElementById("pv");
  function bind() {
    document.querySelectorAll(".frow").forEach((r) => {
      r.onclick = () => {
        const n = r.dataset.n, t = r.dataset.t, s = r.dataset.s, who = r.dataset.who, when = r.dataset.when;
        pv.innerHTML = `<span style="display:inline-block;font-family:monospace;font-size:11px;font-weight:600;color:#16463E;border:1px solid #C0C8C5;border-radius:6px;padding:4px 8px;margin-bottom:10px;">${t} · ${s}</span>
          <div style="font:600 17px var(--font-head,sans-serif);color:#1B1C1E;margin-bottom:6px;">${n}</div>
          <div style="font-size:13px;color:#5C5E63;line-height:1.5;">${DE?"Zuletzt geändert von":"Last changed by"} <strong>${who}</strong> · ${when}</div>
          <div style="margin-top:12px;font-size:13px;color:#92938F;">${DE?"Öffnet read-only im Office-Viewer (Collabora) — Bearbeiten ist in der Demo aus.":"Opens read-only in the office viewer (Collabora) — editing is off in the demo."}</div>`;
      };
    });
  }
  bind();
</script>
