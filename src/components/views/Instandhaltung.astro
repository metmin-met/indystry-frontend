---
// /instandhaltung/ — Instandhaltung & Anlagen-Management (QM-konform). Un-branded.
import type { Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const b = de ? "" : "/en";
const L = (d: string, e: string) => (de ? d : e);
const AC = "#2a86a8"; // Domänen-Akzent (Betrieb)

const norms = [
  { t: L("Wiederkehrende Prüfung", "Recurring inspection"), d: L("Prüffristen je Anlage automatisch — nichts läuft ab, ohne dass es jemand sieht.", "Inspection intervals per asset, automatic — nothing expires unnoticed.") },
  { t: L("Druckgeräte (PED)", "Pressure equipment (PED)"), d: L("Kessel, Behälter, Leitungen nach EU-Druckgeräte-Richtlinie dokumentiert.", "Vessels, tanks and lines documented per the EU Pressure Equipment Directive.") },
  { t: L("Elektrische Anlagen", "Electrical installations"), d: L("Prüfungen nach gängiger ÖVE/ÖNORM-Logik, Nachweise am Objekt.", "Checks following common electrical-safety standards, records on the object.") },
  { t: L("Lebenszyklus & Inventar", "Lifecycle & inventory"), d: L("Status, Inventarnummer, Standort — von der Beschaffung bis zur Ausmusterung.", "State, inventory number, location — from procurement to decommissioning.") },
];
const modules = [
  { t: L("Anlagen-Stammdaten", "Asset master data"), d: L("Ein Datensatz je Anlage: Typ, Hersteller, Baujahr, Norm, Verantwortlicher.", "One record per asset: type, maker, year, standard, owner.") },
  { t: L("Hierarchie-Baum", "Hierarchy tree"), d: L("Standort → Anlage → Komponente → Bauteil, auf- und zuklappbar.", "Site → asset → component → part, expand and collapse.") },
  { t: L("Normen-Katalog", "Standards catalogue"), d: L("Welche Norm für welche Anlage gilt — zentral gepflegt, überall verknüpft.", "Which standard applies to which asset — maintained centrally, linked everywhere.") },
  { t: L("Prüffristen & Termine", "Intervals & due dates"), d: L("Fällige Prüfungen als Liste und Kalender, mit Erinnerung.", "Due inspections as list and calendar, with reminders.") },
  { t: L("Verfahrens-Wiki", "Procedure wiki"), d: L("Wartungs- und Prüfanweisungen direkt an der Anlage hinterlegt.", "Maintenance and inspection procedures attached to the asset itself.") },
  { t: L("3D- & DXF-Plan-Viewer", "3D & DXF viewer"), d: L("Modell und Plan im Browser ansehen — ohne CAD-Lizenz.", "View model and drawing in the browser — no CAD licence.") },
  { t: L("Anhang-Registry", "Attachment registry"), d: L("Datenblätter, Zertifikate, Fotos — versioniert, auffindbar.", "Datasheets, certificates, photos — versioned, findable.") },
  { t: L("Excel-Import (Dry-Run)", "Excel import (dry-run)"), d: L("Bestandslisten importieren — zeigt erst den Diff, bucht erst auf Bestätigung.", "Import existing lists — shows the diff first, commits only on confirm.") },
];
---
<!-- HERO -->
<section style="position:relative; background:#123A33; color:#F4F6F5; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-25%; left:58%; width:55%; height:90%; background:radial-gradient(circle,rgba(42,134,168,.18),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(52px,8vw,104px) clamp(24px,5vw,56px) clamp(40px,6vw,64px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px;">{L("Instandhaltung & Anlagen", "Maintenance & assets")}</p>
    <h1 style="font-family:var(--font-head); font-weight:700; font-size:clamp(34px,6.5vw,68px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:15ch;">{L("Jede Anlage. Jede Norm.", "Every asset. Every standard.")} <span style="color:#E6B23A;">{L("Ein Objekt.", "One object.")}</span></h1>
    <p style="font-size:clamp(17px,1.7vw,21px); line-height:1.6; color:#CADAD5; max-width:64ch; margin:0;">{L("Anlage, Komponenten, Wartung, Pläne und Prüfnachweise hängen an einem einzigen Objekt — nicht in fünf Ordnern. Beim Audit fragst du nicht „wo ist das?“, sondern zeigst es.", "Asset, components, maintenance, drawings and inspection records live on a single object — not in five folders. At an audit you don't ask “where is it?”, you show it.")}</p>
  </div>
</section>

<!-- §01 HIERARCHIE -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px) clamp(20px,3vw,32px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§01 · {L("Anlagen-Hierarchie", "Asset hierarchy")}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span><span style="width:7px; height:7px; border:1.5px solid #C0C8C5;"></span>
    </div>
    <h2 style="font-family:var(--font-head); font-weight:700; font-size:clamp(28px,4.4vw,48px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 24px; max-width:20ch;">{L("Vom Standort bis zur Schraube.", "From the site down to the bolt.")}</h2>
    <div style="display:grid; grid-template-columns:1fr; gap:0; max-width:640px; border:1px solid #E2E8F0; border-radius:14px; background:#fff; overflow:hidden;">
      {[
        {l:0, n:L("Standort · Werk Nord","Site · north plant"), m:L("3 Hallen","3 halls")},
        {l:1, n:L("Anlage · Fertigungslinie 2","Asset · production line 2"), m:L("Inv. NW-A-204 · in Betrieb","Inv. NW-A-204 · running")},
        {l:2, n:L("Komponente · Druckbehälter","Component · pressure vessel"), m:L("PED · Prüfung fällig in 42 Tagen","PED · check due in 42 days")},
        {l:3, n:L("Bauteil · Drucksensor P-12","Part · pressure sensor P-12"), m:L("kalibriert 2026-04","calibrated 2026-04")},
      ].map((r) => (
        <div style={`display:flex; align-items:center; justify-content:space-between; gap:12px; padding:13px 16px 13px ${16 + r.l*22}px; border-bottom:1px solid #EFEAE0;`}>
          <span style="display:flex; align-items:center; gap:10px; min-width:0;"><span style={`width:7px; height:7px; border-radius:2px; background:${AC}; flex:none; opacity:${1 - r.l*0.18};`}></span><span style="font-weight:600; font-size:14.5px; color:#1B1C1E;">{r.n}</span></span>
          <span style="font-family:var(--font-mono); font-size:11px; color:#92938F; text-align:right; flex:none;">{r.m}</span>
        </div>
      ))}
    </div>
    <p style="font-size:14px; color:#5C5E63; margin:16px 0 0; max-width:60ch;">{L("Auf- und zuklappbar. Jede Ebene trägt ihre Norm, ihren Status und ihre Prüffrist mit sich.", "Expand and collapse. Each level carries its standard, its state and its inspection interval.")}</p>
  </div>
</section>

<!-- §02 QM/NORMEN -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(24px,3vw,40px) clamp(24px,5vw,56px) clamp(40px,5vw,64px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§02 · {L("QM-konform & prüfsicher", "QM-compliant & audit-ready")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:14px;">
      {norms.map((n) => (
        <div style={`border:1px solid #E2E8F0; border-left:3px solid ${AC}; border-radius:12px; background:#fff; padding:16px 18px;`}>
          <p style="font-weight:600; font-size:15.5px; color:#1B1C1E; margin:0 0 5px;">{n.t}</p>
          <p style="font-size:13.5px; line-height:1.5; color:#5C5E63; margin:0;">{n.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- §03 MODULE-GRID -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§03 · {L("Was drinsteckt", "What's inside")}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span>
    </div>
    <h2 style="font-family:var(--font-head); font-weight:700; font-size:clamp(26px,4vw,44px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 24px;">{L("Alles am Objekt — nichts im Ordner.", "Everything on the object — nothing in a folder.")}</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(244px,1fr)); gap:12px;">
      {modules.map((m) => (
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{m.t}</p>
          <p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{m.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- §04 WORAUF -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,72px) clamp(24px,5vw,56px);">
    <p style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#92938F; margin:0 0 16px;">{L("Worauf das aufbaut", "What it builds on")}</p>
    <p style="font-size:16px; line-height:1.7; color:#3C3E42; margin:0; max-width:70ch;">{L("Offenes ERP-Fundament für die Stammdaten, eine robuste Datenbank dahinter, Standard-3D/DXF-Anzeige im Browser und offene Formate (PDF, DXF) — selbst gehostet, kein Lizenz-Abo, kein Lock-in.", "An open ERP foundation for the master data, a robust database behind it, standard 3D/DXF viewing in the browser and open formats (PDF, DXF) — self-hosted, no licence subscription, no lock-in.")} <a href={b + "/stack/"} style="color:#16463E; font-weight:600; text-decoration:none;">{L("Zum Stack", "To the stack")} →</a></p>
  </div>
</section>

<!-- CTA -->
<section style="position:relative; background:#0E2E29; color:#EAF1EE; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-20%; left:50%; transform:translateX(-50%); width:60%; height:80%; background:radial-gradient(circle,rgba(230,178,58,.13),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px); text-align:center;">
    <h2 style="font-family:var(--font-head); font-weight:800; font-size:clamp(28px,5vw,52px); line-height:1.02; letter-spacing:-0.035em; margin:0 auto; max-width:22ch;">{L("Wann war die letzte Prüfung — und wo ist der Nachweis?", "When was the last inspection — and where's the record?")}</h2>
    <p style="font-size:clamp(16px,1.7vw,20px); color:#C7D8D2; max-width:52ch; margin:20px auto 30px;">{L("Wenn diese Frage Stress auslöst, ist das hier die Antwort.", "If that question causes stress, this is the answer.")}</p>
    <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
      <a href={b + "/kontakt/"} style="background:#E6B23A; color:#123A33; text-decoration:none; font-family:var(--font-head); font-weight:700; font-size:16px; padding:15px 26px; border-radius:10px;">{L("Pain-List schicken", "Send pain list")} →</a>
      <a href={b + "/erp/"} style="font-family:var(--font-mono); font-size:13px; color:#A6CFC5; display:inline-flex; align-items:center;">{L("Teil des ERP-Systems", "Part of the ERP system")} ↗</a>
    </div>
  </div>
</section>
