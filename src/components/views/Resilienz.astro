---
// /resilienz/ — Resilienz & Wiederanlauf (Out-of-Band-Recovery, Backups, HA). Un-branded.
import type { Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
const b = de ? "" : en ? "/en" : "/cn";
const L = (d: string, e: string, c?: string) => (de ? d : en ? e : (c ?? e));
const AC = "#4a6fa5";

const oob = [
  { t: L("KVM über IP", "KVM over IP", "KVM over IP"), d: L("Bild abgreifen, Tastatur/Maus simulieren — als säße jemand davor, auch wenn das Betriebssystem nicht mehr startet.", "Capture the screen, simulate keyboard/mouse — as if someone sat in front, even when the OS won't boot.", "抓取画面、模拟键鼠——如同有人坐在机前，即使操作系统已无法启动。") },
  { t: L("Virtuelle Medien & BIOS", "Virtual media & BIOS", "虚拟介质与 BIOS"), d: L("ISO einhängen, BIOS/UEFI bedienen, neu installieren — alles aus der Ferne.", "Mount an ISO, drive BIOS/UEFI, reinstall — all remotely.", "挂载 ISO、操作 BIOS/UEFI、重新安装——全程远程完成。") },
  { t: L("Strom schalten", "Power control", "电源控制"), d: L("Hartes Aus/Ein per Fernzugriff, wenn nichts mehr reagiert.", "Hard power cycle remotely when nothing responds anymore.", "当一切都无响应时，远程强制断电重启。") },
  { t: L("Eigener Mobilfunk-Uplink", "Own cellular uplink", "独立蜂窝上行链路"), d: L("Mobilfunk-Verbindung unabhängig vom Werksnetz — funktioniert, wenn das lokale Netz tot ist.", "A cellular link independent of the plant network — works when the local net is dead.", "独立于工厂网络的蜂窝连接——本地网络瘫痪时依然可用。") },
  { t: L("Netzstart / Wiederherstellung", "Network boot / recovery", "网络启动／恢复"), d: L("Rechner über das Netz starten und automatisiert wiederherstellen.", "Boot machines over the network and restore them automatically.", "通过网络启动机器并自动完成恢复。") },
  { t: L("Audit-first", "Audit-first", "审计优先"), d: L("Jede Aktion wird protokolliert, fortlaufend und manipulationssicher — read-only, bis es sein muss.", "Every action is logged, append-only and tamper-evident — read-only until it has to act.", "每一次操作都被记录，仅追加、防篡改——在必须动手之前始终 read-only。") },
];
const backup = [
  { t: L("3-2-1, gelebt", "3-2-1, lived", "真正落地的 3-2-1"), d: L("Drei Kopien, zwei Medien, eine außer Haus — nicht als Folie, sondern als laufender Job.", "Three copies, two media, one off-site — not a slide, a running job.", "三份副本、两种介质、一份异地——不是幻灯片，而是真实运行的任务。") },
  { t: L("Verschlüsselte Offsite-Kopie", "Encrypted off-site copy", "加密异地副本"), d: L("Die Auslagerung ist verschlüsselt — der Standort sieht eure Daten nie im Klartext.", "The off-site copy is encrypted — the location never sees your data in clear text.", "异地副本经过加密——存放地点永远看不到您的明文数据。") },
  { t: L("Getestete Restores", "Tested restores", "经过验证的恢复"), d: L("Ein Backup zählt erst, wenn der Restore bewiesen ist — regelmäßig, nicht im Ernstfall zum ersten Mal.", "A backup only counts once the restore is proven — regularly, not for the first time in an emergency.", "只有恢复被验证过，备份才算数——要定期演练，而不是在事故中才第一次尝试。") },
  { t: L("Snapshots & schnelle Rückkehr", "Snapshots & fast rollback", "快照与快速回滚"), d: L("Vor jeder Änderung ein Stand, zu dem man in Minuten zurückkehrt.", "A point before every change you can return to in minutes.", "每次变更前保留一个状态点，几分钟内即可回退。") },
];
const ha = [
  { t: L("Virtualisiert & migrierbar", "Virtualised & migratable", "虚拟化且可迁移"), d: L("Dienste laufen als Container/VM — verschiebbar zwischen Knoten, ohne Ausfall.", "Services run as container/VM — movable between nodes, without downtime.", "服务以容器/VM 形式运行——可在节点间迁移，不中断。") },
  { t: L("Selbstheilend", "Self-healing", "自愈"), d: L("Watchdog erkennt Hänger und startet neu, statt stundenlang tot dazuliegen.", "A watchdog spots hangs and restarts, instead of lying dead for hours.", "看门狗侦测到卡死后自动重启，而非瘫痪数小时。") },
  { t: L("Mesh-Failover", "Mesh failover", "Mesh 故障切换"), d: L("Verschlüsseltes Netz zwischen den Standorten mit alternativen Wegen.", "An encrypted network between sites with alternative paths.", "各站点之间的加密网络，具备备用路径。") },
];
---
<!-- HERO -->
<section style="position:relative; background:#123A33; color:#F4F6F5; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-25%; left:58%; width:55%; height:90%; background:radial-gradient(circle,rgba(74,111,165,.20),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(52px,8vw,104px) clamp(24px,5vw,56px) clamp(40px,6vw,64px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px;">{L("Resilienz & Wiederanlauf", "Resilience & recovery", "韧性与恢复")}</p>
    <h1 style="font-family:var(--font-head); font-weight:700; font-size:clamp(34px,6.5vw,68px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:16ch;">{L("Wenn alles steht —", "When everything's down —", "当一切都停摆——")} <span style="color:#E6B23A;">{L("kommst du trotzdem rein.", "you still get in.", "您依然进得去。")}</span></h1>
    <p style="font-size:clamp(17px,1.7vw,21px); line-height:1.6; color:#CADAD5; max-width:64ch; margin:0;">{L("Server hängt, Netz tot, niemand vor Ort — der klassische Albtraum. Mit einem Out-of-Band-Zugang, geprüften Backups und selbstheilender Infrastruktur wird daraus eine Stunde Arbeit statt ein Tag Stillstand. Sauber protokolliert.", "Server hung, network dead, nobody on site — the classic nightmare. With out-of-band access, tested backups and self-healing infrastructure it becomes an hour of work instead of a day of downtime. Cleanly logged.", "服务器卡死、网络瘫痪、现场无人——经典的噩梦。借助带外访问、经过验证的备份和自愈基础设施，这只需一小时处理，而非一整天停机。全程清晰留痕。")}</p>
  </div>
</section>

<!-- §01 OOB -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px) clamp(24px,3vw,40px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:8px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§01 · {L("Out-of-Band-Zugang", "Out-of-band access", "带外访问")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <h2 style="font-family:var(--font-head); font-weight:700; font-size:clamp(26px,4vw,44px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 10px; max-width:22ch;">{L("Ein Notfall-Koffer, der überall reinkommt.", "An emergency kit that gets in anywhere.", "一个哪里都进得去的应急工具箱。")}</h2>
    <p style="font-size:15px; color:#5C5E63; margin:0 0 24px; max-width:64ch;">{L("Ein eigenständiges Gerät mit eigenem Mobilfunk — hängt sich an die kranke Maschine, nicht ans kaputte Netz.", "A standalone device with its own cellular link — attaches to the sick machine, not the broken network.", "一台自带蜂窝连接的独立设备——直接接到出故障的机器上，而非坏掉的网络上。")}</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(244px,1fr)); gap:12px;">
      {oob.map((o) => (
        <div style={`border:1px solid #E2E8F0; border-left:3px solid ${AC}; border-radius:12px; background:#fff; padding:16px 18px;`}>
          <p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{o.t}</p>
          <p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{o.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- §02 BACKUPS (beige) -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:8px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§02 · {L("Backups, die man getestet hat", "Backups you've tested", "经过测试的备份")}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span>
    </div>
    <p style="font-family:var(--font-head); font-weight:600; font-size:clamp(18px,2vw,24px); line-height:1.4; color:#1B1C1E; margin:0 0 24px; max-width:60ch;">{L("Ein Backup, das nie zurückgespielt wurde, ist eine Hoffnung — kein Backup.", "A backup that's never been restored is a hope — not a backup.", "从未恢复过的备份只是一种期望——而不是备份。")}</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(248px,1fr)); gap:12px;">
      {backup.map((o) => (
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{o.t}</p>
          <p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{o.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- §03 HA -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,72px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§03 · {L("Hochverfügbar & selbstheilend", "Highly available & self-healing", "高可用且自愈")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:12px;">
      {ha.map((o) => (
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{o.t}</p>
          <p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{o.d}</p>
        </div>
      ))}
    </div>
    <p style="font-size:14px; line-height:1.6; color:#5C5E63; border-top:1px solid #E2E8F0; margin-top:24px; padding-top:18px; max-width:70ch;">{L("Status, Backups und Stabilität sieht man live im Status-Board.", "Status, backups and stability are visible live on the status board.", "状态、备份与稳定性可在状态看板上实时查看。")} <a href={b + "/status/"} style="color:#16463E; font-weight:600; text-decoration:none;">{L("Zum Status-Board", "To the status board", "前往状态看板")} →</a></p>
  </div>
</section>

<!-- CTA -->
<section style="position:relative; background:#0E2E29; color:#EAF1EE; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-20%; left:50%; transform:translateX(-50%); width:60%; height:80%; background:radial-gradient(circle,rgba(230,178,58,.13),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px); text-align:center;">
    <h2 style="font-family:var(--font-head); font-weight:800; font-size:clamp(28px,5vw,52px); line-height:1.02; letter-spacing:-0.035em; margin:0 auto; max-width:22ch;">{L("Was kostet euch ein Tag Stillstand?", "What does a day of downtime cost you?", "一天停机要让贵厂付出多少代价？")}</h2>
    <p style="font-size:clamp(16px,1.7vw,20px); color:#C7D8D2; max-width:52ch; margin:20px auto 30px;">{L("Genau das ist das Budget, das Resilienz spart. Einmal eingerichtet, läuft sie im Hintergrund.", "That's exactly the budget resilience saves. Set up once, it runs in the background.", "这正是韧性为您省下的预算。一次配置好，它便在后台默默运行。")}</p>
    <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
      <a href={b + "/kontakt/"} style="background:#E6B23A; color:#123A33; text-decoration:none; font-family:var(--font-head); font-weight:700; font-size:16px; padding:15px 26px; border-radius:10px;">{L("Pain-List schicken", "Send pain list", "发送痛点清单")} →</a>
      <a href={b + "/compliance/"} style="font-family:var(--font-mono); font-size:13px; color:#A6CFC5; display:inline-flex; align-items:center;">{L("Teil der Sicherheits-Story", "Part of the security story", "安全叙事的一部分")} ↗</a>
    </div>
  </div>
</section>
