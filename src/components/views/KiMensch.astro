---
// /ki-mensch/ — Redesign: grafisch geführte Argumentation (Handoff ZIP 9). Mensch-in-der-Schleife.
// Inhalte (ki[]/mensch[]) 1:1 behalten. Keine Emojis — handgesetzte SVG-Line-Icons.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const L = (d: string, e: string) => (de ? d : e);
const b = de ? "" : "/en";
const KI = "#16794a"; const MENSCH = "#E6B23A";
// 24er Line-Icons (stroke=currentColor)
const I: Record<string,string> = {
  search:'<circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/>',
  doc:'<rect x="5" y="3" width="14" height="18" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>',
  wave:'<path d="M3 14c2 0 2-5 4-5s2 7 4 7 2-9 4-9 2 6 4 6"/>',
  broom:'<path d="M19 4 9 14"/><path d="M5 21c0-4 2-6 5-7l3 3c-1 3-3 5-7 5z"/>',
  bulb:'<path d="M9 18h6"/><path d="M10 21h4"/><path d="M12 3a6 6 0 0 1 4 10c-.7.7-1 1.4-1 2H9c0-.6-.3-1.3-1-2A6 6 0 0 1 12 3z"/>',
  pen:'<path d="M14 4l6 6L8 22H2v-6z"/><line x1="12" y1="6" x2="18" y2="12"/>',
  scale:'<line x1="12" y1="3" x2="12" y2="21"/><path d="M5 7h14"/><path d="M5 7l-3 6a3 3 0 0 0 6 0z"/><path d="M19 7l3 6a3 3 0 0 1-6 0z"/>',
  wrench:'<path d="M21 4a5 5 0 0 1-6.5 6.5L5 20l-1-1 9.5-9.5A5 5 0 0 1 20 3z"/>',
  hands:'<path d="M3 12l4-4 5 3 4-4 5 3"/><path d="M3 16l4-4 5 3 4-4 5 3"/>',
  shield:'<path d="M12 3l8 3v6c0 5-4 8-8 9-4-1-8-4-8-9V6z"/><path d="M9 12l2 2 4-4"/>',
  eye:'<path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/>',
  link:'<path d="M9 15l6-6"/><path d="M11 6l1-1a4 4 0 0 1 6 6l-1 1"/><path d="M13 18l-1 1a4 4 0 0 1-6-6l1-1"/>',
  box:'<path d="M3 7l9-4 9 4-9 4z"/><path d="M3 7v10l9 4 9-4V7"/><line x1="12" y1="11" x2="12" y2="21"/>',
  server:'<rect x="3" y="4" width="18" height="7" rx="1"/><rect x="3" y="13" width="18" height="7" rx="1"/><line x1="7" y1="7.5" x2="7" y2="7.5"/><line x1="7" y1="16.5" x2="7" y2="16.5"/>',
  lock:'<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
};
const kiIc = ["search","doc","wave","broom","bulb"];
const meIc = ["pen","scale","wrench","hands","shield"];
const ki = [
  L("Findet in Sekunden über alle Systeme — Produkte, Maschinen, Aufträge, Handbuch.", "Finds in seconds across all systems — products, machines, orders, handbook."),
  L("Fasst zusammen und antwortet in ganzen Sätzen — nur auf Basis der eigenen Firmendaten, mit Quellen.", "Summarises and answers in full sentences — only from the company's own data, with sources."),
  L("Erkennt Muster und Drift früher als das Auge — etwa eine schleichende Maßabweichung.", "Spots patterns and drift earlier than the eye — e.g. a slow dimensional deviation."),
  L("Nimmt die Routine ab: Tabellen pflegen, suchen, abtippen, Vorschläge vorbereiten.", "Takes the routine off your plate: maintaining spreadsheets, searching, retyping, drafting suggestions."),
  L("Schlägt vor — Bestellmengen, ähnliche Altfälle, den nächsten sinnvollen Schritt.", "Suggests — order quantities, similar past cases, the next sensible step."),
];
const mensch = [
  L("Entscheidet und verantwortet — die KI schlägt vor, unterschreiben tut ein Mensch.", "Decides and owns it — the AI suggests, a human signs off."),
  L("Urteilt im Grenzfall, mit Kontext, den keine Datenbank kennt.", "Judges the edge case, with context no database holds."),
  L("Legt Hand an: rüstet die Maschine, behebt die Störung, prüft das Teil in der Hand.", "Gets hands-on: sets up the machine, fixes the fault, checks the part by hand."),
  L("Hält die Kundenbeziehung — Vertrauen entsteht zwischen Menschen, nicht aus einem Modell.", "Holds the customer relationship — trust grows between people, not from a model."),
  L("Trägt Verantwortung, Haftung und das Warum — setzt Prioritäten und Grenzen.", "Carries responsibility, liability and the why — sets priorities and limits."),
];
const steps = [
  { n:"01", who:"ki", t:L("KI erkennt","AI detects"), d:L("Eine schleichende Maßabweichung über mehrere Chargen — früher als das Auge.","A slow dimensional drift across batches — earlier than the eye.") },
  { n:"02", who:"ki", t:L("KI schlägt vor","AI suggests"), d:L("Nachjustieren, mit Beleg aus den Messdaten — read-only, kein Eingriff.","Re-adjust, with evidence from the measurements — read-only, no action.") },
  { n:"03", who:"me", t:L("Mensch urteilt","Human judges"), d:L("Im Kontext: Werkstoffcharge, Werkzeugstand, Kundentoleranz — was die DB nicht weiß.","In context: material batch, tool state, customer tolerance — what the DB doesn't know.") },
  { n:"04", who:"me", t:L("Mensch entscheidet & zeichnet","Human decides & signs"), d:L("Setzt die Korrektur um und verantwortet sie. Kein Schritt ohne Freigabe.","Applies the correction and owns it. No step without sign-off.") },
];
const guards = [
  { k:"eye", t:L("Read-only","Read-only"), d:L("Die KI liest, sie verändert nichts von selbst.","The AI reads, it changes nothing on its own.") },
  { k:"link", t:L("Mit Quellen","With sources"), d:L("Jede Antwort mit Beleg — nachprüfbar.","Every answer with evidence — verifiable.") },
  { k:"box", t:L("Keine Blackbox","No black box"), d:L("Nachvollziehbar, warum etwas vorgeschlagen wird.","Traceable why something is suggested.") },
  { k:"server", t:L("Selbst gehostet","Self-hosted"), d:L("Modell und Daten im eigenen Haus.","Model and data in your own house.") },
  { k:"lock", t:L("Kein Konzern liest mit","No corporation reading along"), d:L("Keine Prompts in fremde Clouds.","No prompts into foreign clouds.") },
];
const loop = [
  { n:"1", who:"ki", t:L("KI bereitet vor","AI prepares") },
  { n:"2", who:"ki", t:L("KI schlägt vor","AI suggests") },
  { n:"3", who:"me", t:L("Mensch prüft & urteilt","Human reviews & judges") },
  { n:"4", who:"me", t:L("Mensch entscheidet","Human decides") },
];
---
<!-- HERO -->
<section style="position:relative; background:#0E2522; color:#F4F6F5; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(52px,8vw,100px) clamp(24px,5vw,56px) clamp(40px,6vw,64px); display:grid; grid-template-columns:1.1fr .9fr; gap:clamp(24px,4vw,48px); align-items:center;">
    <div>
      <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 16px;">{L("KI & Mensch", "AI & humans")}</p>
      <h1 style="font-family:var(--font-head); font-weight:700; font-size:clamp(32px,6vw,64px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:15ch;">{L("Die KI hilft. Entscheiden tun", "AI helps. Decisions are made by")} <span style="color:#E6B23A;">{L("Menschen.", "people.")}</span></h1>
      <p style="font-size:clamp(16px,1.6vw,20px); line-height:1.6; color:#CADAD5; max-width:56ch; margin:0 0 20px;">{L("Die KI arbeitet auf den eigenen Firmendaten — read-only, mit Quellen, keine Blackbox. Sie beschleunigt und entlastet. Aber sie ersetzt kein Urteil, keine Hand an der Maschine und keine Verantwortung.", "The AI works on the company's own data — read-only, with sources, no black box. It speeds things up and takes load off. But it replaces no judgement, no hand at the machine and no responsibility.")}</p>
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        {[L("read-only","read-only"),L("mit Quellen","with sources"),L("keine Blackbox","no black box"),L("selbst gehostet","self-hosted")].map((c)=>(
          <span style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.05em; color:#A6CFC5; border:1px solid #2E5A52; border-radius:999px; padding:5px 11px;">{c}</span>))}
      </div>
    </div>
    <div style="justify-self:center; width:100%; max-width:360px;">
      <svg viewBox="0 0 190 100" style="width:100%; height:auto;" aria-hidden="true">
        <path d="M40,50 C40,28 72,28 95,50 C118,72 150,72 150,50 C150,28 118,28 95,50 C72,72 40,72 40,50 Z" fill="none" stroke="#214740" stroke-width="6"/>
        <path class="km-flow" d="M40,50 C40,28 72,28 95,50 C118,72 150,72 150,50 C150,28 118,28 95,50 C72,72 40,72 40,50 Z" fill="none" stroke="#E6B23A" stroke-width="2.4" stroke-dasharray="6 12" stroke-linecap="round"/>
        <circle cx="40" cy="50" r="9" fill="#16794a"/><circle cx="150" cy="50" r="9" fill="#E6B23A"/><circle cx="95" cy="50" r="5" fill="#A6CFC5"/>
        <text x="40" y="84" text-anchor="middle" font-family="var(--font-mono),monospace" font-size="8" fill="#8FB3AA">{L("KI · schlägt vor","AI · suggests")}</text>
        <text x="150" y="84" text-anchor="middle" font-family="var(--font-mono),monospace" font-size="8" fill="#d9b15a">{L("Du · entscheidest","You · decide")}</text>
      </svg>
    </div>
  </div>
</section>

<!-- DUALITÄT -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:24px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§ {L("Zwei Kräfte, eine Schleife","Two forces, one loop")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div class="km-dual">
      <div class="km-panel" style="border-top:3px solid #16794a;">
        <p class="km-pt" style="color:#16794a;">{L("Tempo & Fleißarbeit","Speed & legwork")}</p>
        <p class="km-ph">{L("Was die KI übernimmt","What the AI takes on")}</p>
        {ki.map((x,i)=>(<div class="km-row"><span class="km-ic" style="color:#16794a; border-color:#16794a44;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={I[kiIc[i]]}></svg></span><span>{x}</span></div>))}
      </div>
      <div class="km-bridge" aria-hidden="true"><span class="km-bnode">⇄</span><span class="km-blbl">{L("Mensch in der Schleife","Human in the loop")}</span></div>
      <div class="km-panel" style="border-top:3px solid #E6B23A;">
        <p class="km-pt" style="color:#b5851a;">{L("Urteil & Verantwortung","Judgement & responsibility")}</p>
        <p class="km-ph">{L("Wofür es Menschen braucht","What still needs humans")}</p>
        {mensch.map((x,i)=>(<div class="km-row"><span class="km-ic" style="color:#b5851a; border-color:#E6B23A55;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={I[meIc[i]]}></svg></span><span>{x}</span></div>))}
      </div>
    </div>
  </div>
</section>

<!-- KREISLAUF -->
<section style="position:relative; background:#0E2E29; color:#EAF1EE; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <h2 style="font-family:var(--font-head); font-weight:700; font-size:clamp(24px,3.6vw,40px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 28px; max-width:24ch;">{L("Die KI bereitet vor. Der Mensch entscheidet.", "The AI prepares. The human decides.")}</h2>
    <div class="km-loop">
      {loop.map((s,i)=>(<>
        {i>0 && <span class="km-arr" style="color:#E6B23A;">→</span>}
        <div class="km-lnode" style={`border-color:${s.who==="ki"?"#16794a":"#E6B23A"};`}><span class="km-ln-n" style={`color:${s.who==="ki"?"#3FB57E":"#E6B23A"};`}>{s.n}</span><span>{s.t}</span></div>
      </>))}
      <span class="km-arr" style="color:#E6B23A;">↺</span>
    </div>
    <p style="font-family:var(--font-mono); font-size:12px; color:#8FB0A8; margin:20px 0 0;">{L("Kein Schritt ohne menschliche Freigabe.","No step without human sign-off.")}</p>
  </div>
</section>

<!-- BEISPIEL -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:24px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§ {L("Ein Beispiel · schleichende Maßabweichung","An example · slow dimensional drift")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:14px;">
      {steps.map((s)=>{const c=s.who==="ki"?"#16794a":"#b5851a"; return (
        <div style={`border:1px solid #E2E8F0; border-top:3px solid ${c}; border-radius:14px; background:#fff; padding:18px 20px;`}>
          <p style={`font-family:var(--font-mono); font-size:13px; font-weight:700; color:${c}; margin:0 0 8px;`}>{s.n} · {s.t}</p>
          <p style="font-size:13.5px; line-height:1.55; color:#5C5E63; margin:0;">{s.d}</p>
        </div>)})}
    </div>
  </div>
</section>

<!-- LEITPLANKEN -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:24px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§ {L("Die Leitplanken","The guardrails")}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:12px; margin-bottom:28px;">
      {guards.map((g)=>(
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <span style="display:inline-flex; width:34px; height:34px; align-items:center; justify-content:center; border-radius:9px; border:1px solid #16463e33; color:#16463E; margin-bottom:10px;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={I[g.k]}></svg></span>
          <p style="font-weight:600; font-size:14.5px; color:#1B1C1E; margin:0 0 4px;">{g.t}</p>
          <p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{g.d}</p>
        </div>))}
    </div>
    <div style="background:#0E2E29; color:#EAF1EE; border-radius:16px; padding:clamp(22px,3vw,32px); display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:18px;">
      <p style="font-size:clamp(16px,1.7vw,20px); line-height:1.5; margin:0; max-width:48ch; font-family:var(--font-head); font-weight:600;">{L("Daten und Modellwahl bleiben im eigenen Haus. Kein Konzern liest mit.","Data and model choice stay in your own house. No corporation reading along.")}</p>
      <div style="display:flex; flex-wrap:wrap; gap:12px;">
        <a href={b + "/suche/"} style="background:#E6B23A; color:#123A33; text-decoration:none; font-family:var(--font-head); font-weight:700; font-size:15px; padding:13px 22px; border-radius:10px;">{L("KI live ausprobieren","Try the AI live")} →</a>
        <a href={b + "/stack/"} style="font-family:var(--font-mono); font-size:13px; color:#A6CFC5; display:inline-flex; align-items:center;">{L("Womit (der Stack)","With what (the stack)")} ↗</a>
      </div>
    </div>
  </div>
</section>

<style>
  .km-dual{display:grid;grid-template-columns:1fr auto 1fr;gap:18px;align-items:stretch;}
  @media(max-width:900px){.km-dual{grid-template-columns:1fr;}}
  .km-panel{background:#fff;border:1px solid #E2E8F0;border-radius:16px;padding:clamp(18px,2.5vw,26px);}
  .km-pt{font-family:var(--font-mono);font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;margin:0 0 4px;}
  .km-ph{font-family:var(--font-head);font-weight:700;font-size:18px;color:#1B1C1E;margin:0 0 14px;}
  .km-row{display:flex;gap:11px;align-items:flex-start;font-size:14.5px;line-height:1.5;color:#1B1C1E;margin:10px 0;}
  .km-ic{flex:none;width:30px;height:30px;border:1px solid;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;}
  .km-ic svg{width:17px;height:17px;}
  .km-bridge{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;}
  @media(max-width:900px){.km-bridge{flex-direction:row;}}
  .km-bnode{width:40px;height:40px;border-radius:50%;background:linear-gradient(160deg,#16794a,#E6B23A);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;}
  .km-blbl{font-family:var(--font-mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:#92938F;writing-mode:vertical-rl;}
  @media(max-width:900px){.km-blbl{writing-mode:horizontal-tb;}}
  .km-loop{display:flex;flex-wrap:wrap;align-items:center;gap:10px;}
  .km-lnode{display:flex;flex-direction:column;gap:4px;border:1.5px solid;border-radius:12px;background:#10322C;padding:12px 16px;font-size:13.5px;color:#EAF1EE;min-width:120px;}
  .km-ln-n{font-family:var(--font-mono);font-weight:700;font-size:15px;}
  .km-arr{font-size:18px;font-weight:700;}
  .km-flow{animation:km-dash 3s linear infinite;}
  @keyframes km-dash{to{stroke-dashoffset:-180;}}
  @media(prefers-reduced-motion:reduce){.km-flow{animation:none;}}
</style>
