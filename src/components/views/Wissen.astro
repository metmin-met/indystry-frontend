---
// Wissen & Kiosk (read-only, lang-aware): Handbuch + Compliance/ISMS-Register + App-Launcher.
// Statischer, kohärenter Facetten-Inhalt zur Demo-Firma Nordwerk.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const L = (d: string, e: string) => (de ? d : e);
const P = (path: string) => (de ? "" : "/en") + path;
const handbuch = [
  { t: L("Maschine rüsten","Set up a machine"), b: L("Werkzeug wechseln, Nullpunkt setzen, Programm laden, Erststück prüfen.","Change tooling, set zero point, load program, check first part.") },
  { t: L("Qualitätsprüfung","Quality inspection"), b: L("Maßhaltigkeit, Oberflächenrauheit, Gewicht — Grenzwerte, Prüfprotokoll, Sperre bei Abweichung.","Dimensions, surface roughness, weight — limits, inspection record, block on deviation.") },
  { t: L("Reklamation bearbeiten","Handle a complaint"), b: L("Schaden aufnehmen, Reparaturauftrag anlegen, Ursache (8D) dokumentieren, Kunde informieren.","Record damage, open a repair order, document root cause (8D), inform customer.") },
  { t: L("Wartungsplan","Maintenance plan"), b: L("Präventive Intervalle je Maschine, Checklisten, korrektive Einsätze bei Störung.","Preventive intervals per machine, checklists, corrective work on faults.") },
  { t: L("Onboarding","Onboarding"), b: L("Erste Woche, Sicherheitsunterweisung, Zugänge, Ansprechpartner, Rundgang.","First week, safety briefing, access, contacts, plant tour.") },
  { t: L("Notfall & Sicherheit","Emergency & safety"), b: L("Not-Aus, Brandschutz, Erste Hilfe, Meldewege.","E-stop, fire safety, first aid, reporting paths.") },
];
const risiken = [
  { r: L("Maschinenausfall Linie Nord","Machine outage line North"), w: L("mittel","medium"), i: L("hoch","high"), c: "#E6B23A" },
  { r: L("Lieferengpass Rohstahl","Raw steel supply gap"), w: L("niedrig","low"), i: L("hoch","high"), c: "#16794a" },
  { r: L("Qualitätsabweichung Charge","Batch quality deviation"), w: L("mittel","medium"), i: L("mittel","medium"), c: "#E6B23A" },
  { r: L("Datenverlust / IT","Data loss / IT"), w: L("niedrig","low"), i: L("hoch","high"), c: "#16794a" },
  { r: L("Arbeitsunfall","Workplace accident"), w: L("niedrig","low"), i: L("kritisch","critical"), c: "#E6B23A" },
];
const apps = [
  { t: "ERP", d: L("Aufträge, Lager, Fertigung","Orders, stock, production"), href: "https://erp-demo.indystry.works/odoo", ext: true },
  { t: "BI", d: L("Dashboards & Reports","Dashboards & reports"), href: "https://bi-demo.indystry.works", ext: true },
  { t: L("Leitstand","Control room"), d: L("Maschinen live","Machines live"), href: P("/leitstand/"), ext: false },
  { t: "Historian", d: L("Zeitreihen","Time series"), href: P("/historian/"), ext: false },
  { t: L("Anlage","Plant"), d: L("3D bis zum Plan","3D to the plan"), href: P("/anlage/"), ext: false },
  { t: L("Suche","Search"), d: L("Frag die Firma","Ask the company"), href: P("/suche/"), ext: false },
  { t: "Status", d: L("Betrieb & Backups","Ops & backups"), href: P("/status/"), ext: false },
];
---
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{L("Wissen & Kiosk · read-only","Knowledge & kiosk · read-only")}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(34px,6vw,64px); line-height:1.0; letter-spacing:-0.03em; margin:0 0 14px;">{L("Das Wissen der Firma.","The company's knowledge.")}</h1>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#5C5E63; max-width:62ch; margin:0 0 clamp(36px,5vw,52px);">{L("Handbuch, Compliance und der Kiosk, von dem aus jeder seine Werkzeuge erreicht — an einem Ort, für alle, immer aktuell.","Handbook, compliance and the kiosk from which everyone reaches their tools — one place, for everyone, always current.")}</p>

    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 14px;">{L("Handbuch","Handbook")}</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; margin-bottom:clamp(40px,5vw,60px);">
      {handbuch.map((h) => (
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <p style="font-family:var(--font-head); font-weight:600; font-size:16px; color:#1B1C1E; margin:0 0 6px;">{h.t}</p>
          <p style="font-size:14px; line-height:1.5; color:#5C5E63; margin:0;">{h.b}</p>
        </div>
      ))}
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:24px; margin-bottom:clamp(40px,5vw,60px);">
      <div>
        <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 14px;">{L("Compliance · Risikoregister","Compliance · risk register")}</p>
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; overflow:hidden;">
          <div style="display:grid; grid-template-columns:1fr auto auto; gap:10px; padding:10px 16px; border-bottom:1px solid #EFEAE0; font-family:var(--font-mono); font-size:10px; letter-spacing:0.06em; text-transform:uppercase; color:#92938F;">
            <span>{L("Risiko","Risk")}</span><span>{L("Eintritt","Likelihood")}</span><span>{L("Wirkung","Impact")}</span>
          </div>
          {risiken.map((x, i) => (
            <div style={`display:grid; grid-template-columns:1fr auto auto; gap:10px; align-items:center; padding:11px 16px; ${i ? "border-top:1px solid #F1F3F2;" : ""}`}>
              <span style="display:flex; align-items:center; gap:9px; font-size:14px; color:#1B1C1E;"><span style={`width:8px;height:8px;border-radius:50%;background:${x.c};`}></span>{x.r}</span>
              <span style="font-family:var(--font-mono); font-size:12px; color:#5C5E63; text-align:right;">{x.w}</span>
              <span style="font-family:var(--font-mono); font-size:12px; color:#5C5E63; text-align:right;">{x.i}</span>
            </div>
          ))}
        </div>
        <p style="font-size:12px; color:#92938F; margin:10px 0 0;">{L("ISO 9001 / IEC 62443-Logik — gepflegt, nachvollziehbar, read-only.","ISO 9001 / IEC 62443 logic — maintained, traceable, read-only.")}</p>
      </div>
      <div>
        <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 14px;">{L("Kiosk · App-Launcher","Kiosk · app launcher")}</p>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
          {apps.map((a) => (
            <a href={a.href} target={a.ext ? "_blank" : undefined} rel={a.ext ? "noopener" : undefined}
              style="text-decoration:none; border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:14px 16px; display:block;">
              <span style="display:flex; align-items:center; justify-content:space-between;">
                <span style="font-weight:600; font-size:15px; color:#1B1C1E;">{a.t}</span>
                <span style="color:#92938F; font-size:13px;">{a.ext ? "↗" : "→"}</span>
              </span>
              <span style="font-size:13px; color:#5C5E63;">{a.d}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
