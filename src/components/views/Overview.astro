<!-- 03 KI-FINDER (dark) -->
<section id="finder" class="blueprint" style="color:#F8F9FA; border-top:1px solid #E2E8F0;">
  <div style="max-width:1280px; margin:0 auto; padding:clamp(96px,12vw,168px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:20px; margin-bottom:clamp(40px,5vw,64px); flex-wrap:wrap;">
      <span style="font-size:13px; font-weight:600; color:#E6B23A;">03</span>
      <span style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#7C9A92;">{tx.finderLabel}</span>
      <span style="flex:1; min-width:40px; height:1px; background:#2E5A52;"></span>
      <span style="font-size:11px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#7C9A92; display:inline-flex; align-items:center; gap:8px;"><span style="width:6px; height:6px; border-radius:50%; background:#E6B23A;"></span>{tx.finderBadge}</span>
    </div>
    <h2 style="font-weight:600; font-size:clamp(32px,5vw,64px); line-height:1.02; letter-spacing:-0.025em; margin:0 0 18px; max-width:20ch;">{tx.finderH}</h2>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#9FB8B0; margin:0 0 clamp(40px,5vw,56px); max-width:54ch;">{tx.finderLead}</p>
    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:22px; max-width:820px;">
      <input id="kf-input" type="search" autocomplete="off" placeholder={tx.finderPh}
        data-host={search.host} data-index={search.index} data-key={search.key} data-lang={lang} data-semantic={search.semantic ? "1" : ""}
        style="flex:1; min-width:240px; background:#0E2E29; border:1px solid #2E5A52; color:#F8F9FA; font-family:inherit; font-size:17px; padding:18px 20px; outline:none;" />
      <button id="kf-go" type="button" style="background:#E6B23A; color:#123A33; border:none; font-family:inherit; font-weight:600; font-size:16px; padding:18px 30px; cursor:pointer; white-space:nowrap;">{tx.finderBtn}</button>
    </div>
    <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-bottom:clamp(44px,5vw,64px);">
      <span style="font-size:13px; color:#7C9A92;">{tx.finderExamples}</span>
      {examples.map((e) => (
        <button type="button" class="kf-ex" data-q={e} style="cursor:pointer; font-family:inherit; font-size:13px; font-weight:500; padding:8px 15px; border-radius:999px; background:transparent; color:#9FB8B0; border:1px solid #2E5A52;">{e}</button>
      ))}
    </div>
    <div style="min-height:180px;">
      <p id="kf-searching" hidden style="font-size:15px; font-weight:500; color:#E6B23A; margin:0; animation:pulse 1.2s ease-in-out infinite;">{tx.finderSearching}</p>
      <p id="kf-idle" style="font-size:16px; color:#7C9A92; margin:0; line-height:1.6; max-width:44ch;">{tx.finderIdle}</p>
      <div id="kf-results" hidden>
        <p id="kf-meta" style="font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#7C9A92; margin:0 0 4px;"></p>
        <div id="kf-list" style="border-top:1px solid #2E5A52;"></div>
      </div>
      <p id="kf-none" hidden style="font-size:16px; color:#9FB8B0; margin:0; line-height:1.6; max-width:44ch;">{tx.finderNo} <a href="#kontakt" style="color:#E6B23A;">Pain-List</a>.</p>
    </div>
  </div>
  <script is:inline define:vars={{ srcLabel: tx.finderBadge }}>
    (function () {
      var inp = document.getElementById("kf-input"), go = document.getElementById("kf-go");
      var elS = document.getElementById("kf-searching"), elI = document.getElementById("kf-idle"),
          elR = document.getElementById("kf-results"), elN = document.getElementById("kf-none"),
          meta = document.getElementById("kf-meta"), list = document.getElementById("kf-list");
      if (!inp) return;
      function show(state) { elS.hidden = state !== "searching"; elI.hidden = state !== "idle"; elR.hidden = state !== "results"; elN.hidden = state !== "none"; }
      var esc = function (s) { return String(s || "").replace(/[&<>"]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]; }); };
      async function run(q) {
        q = (q || "").trim(); if (!q) { show("idle"); return; }
        show("searching");
        try {
          var body = { q: q, filter: "lang = " + inp.dataset.lang, limit: 3, showRankingScore: true };
          if (inp.dataset.semantic === "1") body.hybrid = { embedder: "mistral", semanticRatio: 0.7 };
          var res = await fetch(inp.dataset.host + "/indexes/" + inp.dataset.index + "/search", {
            method: "POST", headers: { "Authorization": "Bearer " + inp.dataset.key, "Content-Type": "application/json" }, body: JSON.stringify(body) });
          var data = await res.json(); var hits = data.hits || [];
          if (!hits.length) { show("none"); return; }
          meta.textContent = hits.length + " Treffer · " + srcLabel;
          list.innerHTML = hits.map(function (h) {
            var pct = h._rankingScore != null ? Math.round(h._rankingScore * 100) + "% Match" : "";
            return '<a href="' + esc(h.url) + '" style="text-decoration:none; color:#F8F9FA; display:grid; grid-template-columns:104px 1fr auto; gap:clamp(14px,2.5vw,32px); align-items:baseline; padding:22px 0; border-bottom:1px solid #2E5A52;">' +
              '<span style="font-size:14px; font-weight:600; color:#E6B23A;">' + pct + '</span>' +
              '<span style="display:flex; flex-direction:column; gap:7px;"><span style="font-weight:600; font-size:clamp(18px,1.9vw,22px); letter-spacing:-0.015em;">' + esc(h.title) + '</span><span style="font-size:14px; line-height:1.5; color:#9FB8B0;">' + esc(h.subline || "") + '</span></span>' +
              '<span style="color:#7C9A92; justify-self:end;">↗</span></a>';
          }).join("");
          show("results");
        } catch (e) { show("none"); }
      }
      go.addEventListener("click", function () { run(inp.value); });
      inp.addEventListener("keydown", function (e) { if (e.key === "Enter") run(inp.value); });
      document.querySelectorAll(".kf-ex").forEach(function (b) { b.addEventListener("click", function () { inp.value = b.getAttribute("data-q"); run(inp.value); }); });
      show("idle");
    })();
  </script>
</section>

