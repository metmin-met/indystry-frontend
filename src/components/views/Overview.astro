<!-- DIGITALE SOUVERÄNITÄT (dark statement) -->
<section id="souv" class="blueprint" style="color:#F8F9FA; border-top:1px solid #E2E8F0;">
  <div style="max-width:1280px; margin:0 auto; padding:clamp(110px,14vw,200px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:20px; margin-bottom:clamp(40px,5vw,64px); flex-wrap:wrap;">
      <span style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#7C9A92;">{tx.souvLabel}</span>
      <span style="flex:1; min-width:40px; height:1px; background:#2E5A52;"></span>
    </div>
    <h2 style="font-weight:600; font-size:clamp(36px,6vw,88px); line-height:0.98; letter-spacing:-0.03em; margin:0 0 clamp(24px,3vw,32px); max-width:18ch;">{tx.souvH1} <span style="color:#E6B23A;">{tx.souvH2}</span></h2>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#9FB8B0; margin:0 0 clamp(56px,7vw,88px); max-width:60ch;">{tx.souvLead}</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:clamp(32px,4vw,56px);">
      {souv.map((s, i) => (
        <div style="border-top:1px solid #2E5A52; padding-top:24px;">
          <span style="font-size:13px; font-weight:600; color:#E6B23A;">{String(i + 1).padStart(2, "0")}</span>
          <h3 style="font-weight:600; font-size:clamp(19px,1.9vw,22px); letter-spacing:-0.015em; margin:14px 0 12px;">{s.t}</h3>
          <p style="font-size:15px; line-height:1.6; color:#9FB8B0; margin:0;">{s.d}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:clamp(48px,6vw,72px);">
      <a href={slug("basis-betrieb")} class="more-link-gold">{tx.souvMore} <span class="arr">→</span></a>
    </div>
  </div>
</section>

