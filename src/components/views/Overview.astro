          <span style="font-weight:600; font-size:clamp(30px,3.2vw,46px); letter-spacing:-0.02em; color:inherit;">{label}</span>
        </button>
      ))}
    </div>
    <div style="margin-top:clamp(40px,5vw,60px); min-height:80px; max-width:40ch;">
      <div id="st-result" hidden>
        <p style="font-size:13px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{tx.s01diag}</p>
        <p id="st-text" style="font-size:clamp(20px,2.4vw,30px); line-height:1.25; letter-spacing:-0.015em; font-weight:500; margin:0 0 24px;"></p>
        <a href="#saeulen" style="text-decoration:none; font-size:15px; font-weight:500; color:#1B1C1E; border-bottom:1.5px solid #16463E; padding-bottom:3px;">{tx.s01link}</a>
      </div>
      <p id="st-hint" style="font-size:17px; color:#92938F; margin:0;">{tx.s01hint}</p>
    </div>
    <p style="margin-top:clamp(28px,3vw,36px);">
      <a href={P("/check/")} class="more-link">{de ? "Vollständigen Werks-Check starten" : "Start the full factory check"} <span class="arr">→</span></a>
    </p>
  </div>
  <script is:inline define:vars={{ reactions }}>
    (function () {
      var res = document.getElementById("st-result"), hint = document.getElementById("st-hint"), txt = document.getElementById("st-text");
      document.querySelectorAll("#st-opts [data-st]").forEach(function (b) {
        b.addEventListener("click", function () {
          document.querySelectorAll("#st-opts [data-st]").forEach(function (x) { x.style.borderTop = "1px solid #1B1C1E"; x.style.color = "#1B1C1E"; });
          b.style.borderTop = "3px solid #16463E"; b.style.color = "#16463E";
          txt.textContent = reactions[b.getAttribute("data-st")] || "";
          res.hidden = false; hint.hidden = true;
        });
      });
    })();
  </script>
</section>

<!-- STATEMENT (dark) -->
