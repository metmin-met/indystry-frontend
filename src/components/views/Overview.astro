  : ["没人看得到机器在做什么","我们总是丢失测量数据","每月分析都要耗费好几天","审计将至，却什么都找不到"];
// Daten für Finder-Island
const finderData = baust.map((x) => ({ nr:x.nr, name:x.n, desc:x.d, color:x.color, href:`${S}/saeule/${x.slug}/`, kw:x.kw }));
const kick = (n:string) => n; // helper noop
const branchen = [
  { tag:"zerspanung", n:L("Zerspanung & Metallbearbeitung","Machining & metalworking","切削加工与金属加工"), d:L("CNC-Fräsen, Drehen, viele Varianten, enge Toleranzen.","CNC milling, turning, many variants, tight tolerances.","CNC 铣削、车削，多品种，公差严格。"), c:"#c4673f" },
  { tag:"maschinenbau", n:L("Anlagen- & Maschinenbau","Plant & machine building","成套设备与机械制造"), d:L("Einzel- und Sondermaschinen, Projektfertigung, lange Stücklisten.","One-off and special machines, project builds, long BOMs.","单件与非标机器、项目制生产、超长物料清单。"), c:"#2a86a8" },
  { tag:"serienfertigung", n:L("Serien- & Variantenfertigung","Series & variant production","批量与多品种生产"), d:L("Wiederkehrende Aufträge, Chargen, lückenlose Rückverfolgung.","Recurring orders, batches, seamless traceability.","重复订单、批次、全程可追溯。"), c:"#3d4fc0" },
  { tag:"prozesstechnik", n:L("Verfahrens- & Prozesstechnik","Process technology","工艺与过程技术"), d:L("Misch-, Reaktions- und Chargenprozesse mit vielen Messwerten.","Mixing, reaction and batch processes with lots of readings.","混合、反应与批次工艺，测量值众多。"), c:"#7b5cc4" },
  { tag:"blech-schweiss", n:L("Blech, Schweiß & Metallbau","Sheet, welding & metal fab","钣金、焊接与金属结构"), d:L("Zuschnitt, Umformung, Baugruppen, Endkontrolle.","Cutting, forming, assemblies, final inspection.","下料、成形、组件装配、终检。"), c:"#4a6fa5" },
  { tag:"kunststoff", n:L("Kunststoff & Spritzguss","Plastics & injection moulding","塑料与注塑成型"), d:L("Werkzeuge, Zyklen, Qualität pro Schuss.","Tools, cycles, quality per shot.","模具、周期、逐模次质量。"), c:"#c08a2e" },
  { tag:"elektronik", n:L("Elektronik & Baugruppen","Electronics & assembly","电子与组件装配"), d:L("Bestückung, Prüfung, Seriennummern.","Placement, testing, serial numbers.","贴片、测试、序列号管理。"), c:"#b03f93" },
  { tag:"lohnfertigung", n:L("Lohnfertigung & Job-Shop","Contract & job-shop","代工与单件车间"), d:L("Viele Kunden, viele Teile, knappe Termine.","Many customers, many parts, tight dates.","客户多、零件多、交期紧。"), c:"#5a8a98" },
  { tag:"lebensmittel", n:L("Lebensmittel & Getränke","Food & beverage","食品与饮料"), d:L("Chargen, Rückverfolgbarkeit, Hygiene- und Qualitätsnachweise.","Batches, traceability, hygiene and quality records.","批次、可追溯性、卫生与质量凭证。"), c:"#3f9a52" },
  { tag:"holz-papier", n:L("Holz & Papier","Wood & paper","木材与纸业"), d:L("Zuschnitt, Serien, Materialfluss — durchgängige Daten statt Zettel.","Cutting, series, material flow — continuous data instead of paper.","下料、批量、物料流转——用连贯数据取代纸单。"), c:"#b5852a" },
  { tag:"automotive", n:L("Automotive-Zulieferer","Automotive suppliers","汽车零部件供应商"), d:L("Serien, enge Toleranzen, lückenlose Rückverfolgung (IATF).","Series, tight tolerances, seamless traceability (IATF).","批量、严公差、全程可追溯（IATF）。"), c:"#6b54b0" },
