<!-- Fortschrittsbalken + Readout -->
<div class="ov-prog-wrap"><div class="prog ov-prog"></div></div>
<div class="ov-readout"><span class="led ov-led"></span>ON-PREM · 100% · WERK-OS v3</div>

<!-- HERO -->
<section class="ov-hero">
  <div class="glow ov-glow"></div>
  <div class="ov-wrap ov-hero-kick">
    <span class="ov-tk-sq"></span><span class="ov-mono ov-hk">{L("Der dritte Weg","The third way")}<span class="ov-dot">·</span>{L("Industriesoftware fürs Werk","Industrial software for the works")}</span>
  </div>
  <div class="ov-wrap ov-hsplit">
    <div>
      <h1 class="ov-h1" set:html={L("Raus aus dem<br>Tabellen-Chaos.<br><span class='gold'>Selbstbestimmt.</span>","Out of the<br>spreadsheet chaos.<br><span class='gold'>Self-determined.</span>")}></h1>
      <p class="ov-hlead">{L("Fertige Software fürs Werk — ab Tag eins angelernt, an euch angepasst. Ein System statt zehn Tabellen.","Ready software for the works — trained from day one, adapted to you. One system instead of ten spreadsheets.")}</p>
      <p class="ov-mono ov-hsub">{L("Eure Daten. Euer Server. Euer System. Start bei 80 %, nicht bei null.","Your data. Your server. Your system. Start at 80%, not zero.")}</p>
      <div class="ov-cta-row">
        <a class="ctagold ov-cta-gold" href="#saeulen">{L("Den Stack ansehen","See the stack")} →</a>
        <a class="ctaghost ov-cta-ghost" href="#demos">{L("Live ausprobieren","Try it live")} ↗</a>
        <a class="ctaghost ov-cta-ghost" href={`${b}/einstieg/`}>{L("Einstieg & Förderung","Getting started & funding")} ↗</a>
      </div>
    </div>
    <div class="ov-dash-wrap">
      <div class="tk ov-dash">
        <div class="scanline ov-scan"></div>
        <div class="ov-dash-top"><span>DASH_BOARD_01</span><span class="ioled ov-rec">● LIVE</span></div>
        <div class="ov-dash-lab">{L("Status Gesamtproduktion","Total production status")}</div>
        <div class="ov-dash-big"><span id="m-prod">84,2 %</span><span class="ov-delta">▲ <span id="m-delta">2,4</span></span></div>
        <div class="ov-bars"><i style="height:42%"></i><i style="height:58%"></i><i style="height:50%"></i><i class="g" style="height:74%"></i><i style="height:66%"></i><i class="y" style="height:88%"></i><i class="g" style="height:79%"></i></div>
        <div class="ov-dash-grid">
          <div class="ov-dash-cell"><div class="ov-dash-k">{L("Effizienz","Efficiency")}</div><div class="ov-dash-v green">+<span id="m-eff">24,8</span> %</div></div>
          <div class="ov-dash-cell"><div class="ov-dash-k">{L("Sicherheit","Security")}</div><div class="ov-dash-v">Self-Host</div></div>
        </div>
        <div class="ov-dash-foot"><span class="led ov-led-sm"></span><span id="hero-ticker">SERVER · 100% ON-PREMISE</span></div>
      </div>
    </div>
