        <button type="button" data-st={label} style="cursor:pointer; text-align:left; display:flex; flex-direction:column; gap:14px; padding:22px 0 0; background:transparent; font-family:inherit; border:none; border-top:1px solid #1B1C1E; color:#1B1C1E;">
