<script type="application/json" id="ov-data" is:inline set:html={JSON.stringify({ baust: finderData, diag: diag.map((d)=>d.v) })}></script>
<script>
  const DE = document.documentElement.lang !== "en";
  const D = JSON.parse(document.getElementById("ov-data").textContent);

  // Diagnose
  const verdict = document.getElementById("ov-verdict"), vtx = document.getElementById("ov-verdict-tx");
  document.querySelectorAll(".ov-diagopt").forEach((btn) => btn.addEventListener("click", () => {
    document.querySelectorAll(".ov-diagopt").forEach((x) => x.classList.toggle("sel", x === btn));
    vtx.textContent = D.diag[+btn.dataset.i]; verdict.hidden = false;
  }));

  // KI-Finder
  const fxIn = document.getElementById("fx-input"), fxRes = document.getElementById("fx-results"), fxHint = document.getElementById("fx-hint");
  function fxRun(q) {
    q = (q || "").toLowerCase();
    if (q.trim().length < 2) { fxRes.innerHTML = ""; fxHint.hidden = false; fxHint.textContent = DE ? "Tipp deinen Bedarf ein oder wähl ein Beispiel — die passenden Bausteine erscheinen hier, nach Relevanz gerankt." : "Type your need or pick an example — the matching blocks appear here, ranked by relevance."; return; }
    let r = D.baust.map((bb) => { let s = 0; bb.kw.forEach((k) => { if (q.includes(k)) s += 2; }); if (bb.name.toLowerCase().split(/[ &]+/).some((w) => w.length > 3 && q.includes(w))) s += 1; return { bb, s }; }).filter((x) => x.s > 0).sort((a, c) => c.s - a.s).slice(0, 4);
    if (!r.length) { fxRes.innerHTML = ""; fxHint.hidden = false; fxHint.textContent = DE ? "Keine passenden Bausteine gefunden — formulier's anders." : "No matching blocks found — try rephrasing."; return; }
    fxHint.hidden = true;
    const max = r[0].s;
    fxRes.innerHTML = r.map((x, i) => {
      const pct = Math.round(40 + (x.s / max) * 58);
      return `<a href="${x.bb.href}" target="_blank" rel="noopener" style="display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1rem;border:1px solid rgba(166,207,197,.2);border-radius:11px;padding:.9rem 1.1rem;text-decoration:none;margin-bottom:.55rem;transition:border-color .25s,background .25s;" onmouseover="this.style.borderColor='#E6B23A';this.style.background='rgba(230,178,58,.06)'" onmouseout="this.style.borderColor='rgba(166,207,197,.2)';this.style.background='transparent'"><span style="width:.7rem;height:.7rem;border-radius:50%;background:${x.bb.color};flex:none;"></span><span style="min-width:0;"><b style="font-family:var(--font-head);font-weight:660;font-size:1rem;color:#F4F8F6;display:block;">${x.bb.name}</b><span style="font-size:.88rem;color:#A6CFC5;display:block;margin:.15rem 0 .5rem;">${x.bb.desc}</span><span style="display:block;height:6px;background:rgba(166,207,197,.18);border-radius:999px;overflow:hidden;"><i style="display:block;height:100%;width:${pct}%;background:${x.bb.color};border-radius:999px;"></i></span></span><span style="font-family:var(--font-mono);font-size:.8rem;color:#7C9A92;">${String(i+1).padStart(2,"0")}</span></a>`;
    }).join("");
  }
  if (fxIn) {
    fxIn.addEventListener("input", (e) => fxRun(e.target.value));
    document.querySelectorAll(".ov-fx-chip").forEach((c) => c.addEventListener("click", () => { fxIn.value = c.textContent; fxRun(c.textContent); fxIn.focus(); }));
  }

  // Stack-Filter
  const stack = document.getElementById("ov-stack");
  document.querySelectorAll(".ov-filt").forEach((btn) => btn.addEventListener("click", () => {
    const f = btn.dataset.f;
    document.querySelectorAll(".ov-filt").forEach((x) => x.classList.toggle("on", x === btn));
    stack.querySelectorAll(".ov-baust").forEach((c) => { c.style.display = (f === "all" || c.dataset.bk === f) ? "" : "none"; });
  }));

  // Stat-Zähler
  const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { anim(e.target); io.unobserve(e.target); } }), { threshold: 0.4 });
  document.querySelectorAll(".count").forEach((el) => io.observe(el));
  function anim(el) {
    const to = parseFloat(el.dataset.to || "0"), group = el.dataset.group === "1", suf = el.dataset.suffix || "", t0 = performance.now(), dur = 1500;
    const fmt = (n) => (group ? Math.round(n).toLocaleString("de-DE") : String(Math.round(n))) + suf;
    const step = (t) => { const p = Math.min((t - t0) / dur, 1); el.textContent = fmt(to * (1 - Math.pow(1 - p, 3))); if (p < 1) requestAnimationFrame(step); };
    requestAnimationFrame(step);
  }

  // Live-Dashboard
  const rnd = (base, j) => (base + (Math.random() * 2 - 1) * j);
  const ticks = ["CNC-FRÄSE A1 · 1.480 U/min · OK","DREHZENTRUM B1 · 62 °C · OK","HISTORIAN · 50.214 Punkte/s · SYNC","BACKUP · EU-RZ · verschlüsselt","MONTAGEZELLE M2 · Takt 11,4 s · OK","SERVER · 100% ON-PREMISE"];
  let tk = 0;
  const elProd = document.getElementById("m-prod"), elDelta = document.getElementById("m-delta"), elEff = document.getElementById("m-eff"), elTick = document.getElementById("hero-ticker");
  if (elProd) setInterval(() => {
    elProd.textContent = rnd(84.2, 0.5).toFixed(1).replace(".", ",") + " %";
    if (elDelta) elDelta.textContent = rnd(2.4, 0.4).toFixed(1).replace(".", ",");
    if (elEff) elEff.textContent = rnd(24.8, 0.6).toFixed(1).replace(".", ",");
    if (elTick) { tk = (tk + 1) % ticks.length; elTick.textContent = ticks[tk]; }
  }, 2100);
</script>

