          <a href="#demos" style="text-decoration:none; color:#F8F9FA; font-weight:500; font-size:15px; padding:16px 4px; border-bottom:1.5px solid #2E5A52; display:inline-flex; align-items:center; gap:10px;">{tx.heroCta2}</a>
