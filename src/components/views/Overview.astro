<!-- 06 BAUSTEINE (tag filter) -->
<section id="saeulen" style="background:#EFEAE0; border-top:1px solid #E2E8F0;">
  <div style="max-width:1280px; margin:0 auto; padding:clamp(96px,12vw,168px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:20px; margin-bottom:clamp(40px,5vw,64px);">
      <span style="font-size:13px; font-weight:600; color:#16463E;">06</span>
      <span style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#92938F;">{tx.s06label}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <h2 style="font-weight:600; font-size:clamp(32px,5vw,64px); line-height:1.02; letter-spacing:-0.025em; margin:0 0 16px;">{tx.s06h}</h2>
    <p style="font-size:18px; line-height:1.6; max-width:52ch; color:#5C5E63; margin:0 0 clamp(32px,4vw,44px);">{tx.s06lead}</p>
    <div id="tagbar" style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:clamp(36px,4vw,52px);">
      {TAGS.map((t, i) => (
        <button type="button" data-tag={i === 0 ? "Alle" : t} class={i === 0 ? "tagpill tag-active" : "tagpill"} style="cursor:pointer; font-family:inherit; font-size:13px; font-weight:500; padding:8px 16px; border-radius:999px;">{t} <span style="opacity:0.5;">{tagCount(t, i)}</span></button>
      ))}
    </div>
    <div style="border-top:1px solid #1B1C1E;">
      {BAUSTEINE.map((b) => (
        <a href={slug(b.s)} data-cat={b.cat} class="stack-row" style="text-decoration:none; color:#1B1C1E; display:grid; grid-template-columns:54px 1fr; gap:clamp(16px,3vw,40px); align-items:baseline; padding:clamp(22px,2.4vw,30px) 0; border-bottom:1px solid #E2E8F0;">
          <span style="font-size:13px; font-weight:600; color:#92938F;">{b.n}</span>
          <span data-stack-row="1" style="display:grid; grid-template-columns:minmax(180px,0.9fr) 1.6fr auto; gap:clamp(12px,2.5vw,36px); align-items:baseline;">
            <span style="display:flex; flex-direction:column; gap:9px; align-items:flex-start;">
              <span style="font-weight:600; font-size:clamp(18px,1.9vw,23px); letter-spacing:-0.015em;">{b.t}</span>
              <span style="font-size:11px; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:#16463E; border:1px solid #C0C8C5; padding:3px 10px; border-radius:999px;">{b.cat}</span>
            </span>
            <span style="font-size:15px; line-height:1.5; color:#5C5E63;">{b.d}</span>
            <span data-hide-sm="1" style="font-size:15px; color:#92938F; justify-self:end;">↗</span>
          </span>
        </a>
      ))}
    </div>
  </div>
  <script is:inline>
    (function () {
      var bar = document.getElementById("tagbar"); if (!bar) return;
      bar.querySelectorAll("[data-tag]").forEach(function (b) {
        b.addEventListener("click", function () {
          var tag = b.getAttribute("data-tag");
          bar.querySelectorAll("[data-tag]").forEach(function (x) { x.classList.toggle("tag-active", x === b); });
          document.querySelectorAll(".stack-row").forEach(function (row) {
            row.style.display = (tag === "Alle" || row.getAttribute("data-cat") === tag) ? "" : "none";
          });
        });
      });
    })();
  </script>
</section>

