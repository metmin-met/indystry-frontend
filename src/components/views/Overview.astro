  teamBody: de ? "Vorne steht David Fuchs — Unternehmer, technischer Generalist, Systemdenker, 25 Jahre an der Naht zwischen Infrastruktur, Automatisierung und Geschäftsprozessen. Dahinter ein eingespieltes Team und eine ganze Crowd. Für euch heißt das: ein Ansprechpartner, der das Ganze überblickt — kein Abteilungs-Pingpong." : "Out front is David Fuchs — entrepreneur, technical generalist, systems thinker, 25 years at the seam between infrastructure, automation and business processes. Behind him a tight-knit team and a whole crowd. For you: one contact who sees the whole — no departmental ping-pong.",
  haltLabel: de ? "Haltung" : "Attitude",
  haltH: de ? "Wir arbeiten gerne — aber nicht mit jedem." : "We like working — but not with everyone.",
  haltD: de ? "Die Chemie muss stimmen. Wir packen viel an, aber nicht alles nur fürs Geld. Wer's auf die harte Tour will, sucht sich besser jemand anderen." : "The chemistry has to fit. We take on a lot, but not everything just for money. If you want it the hard way, you're better off with someone else.",
  haltChips: de ? ["Kurze Wege", "Kommunikation ohne Umweg", "Alles nachvollziehbar"] : ["Short paths", "Direct communication", "All traceable"],
  s10label: de ? "Lösung — So läuft's ab" : "Solution — how it works",
  s10h: de ? "Von der Pain-List zum laufenden System — in klaren Schritten." : "From pain list to running system — in clear steps.",
  s11label: de ? "Lösung — Aufwand & Transparenz" : "Solution — effort & transparency",
  s11h: de ? "Worauf ihr euch einlasst — vorab, ehrlich." : "What you're getting into — upfront, honest.",
  s11note: de ? "Was kostet das? Konkrete Zahlen gibt's mit der Lösungsskizze — ein fixes Angebot, keine Überraschungen." : "What does it cost? Concrete figures come with the solution sketch — a fixed quote, no surprises.",
  ctaLabel: de ? "Pain-List → Lösung" : "Pain list → solution",
  ctaH: de ? "Schick uns deine Pain-List." : "Send us your pain list.",
  ctaLead: de ? "Die drei nervigsten Tabellen. Das System, das ihr hasst. Der Ablauf, der jeden Montag schmerzt. Schreib's roh runter — wir melden uns mit einer konkreten Lösungsskizze. Kein Sales-Blabla." : "The three most annoying spreadsheets. The system you hate. The routine that hurts every Monday. Jot it down raw — we'll get back with a concrete solution sketch. No sales fluff.",
  ctaBtn: de ? "Pain-List schicken →" : "Send pain list →",
  ctaMail: de ? "oder direkt: hallo@datendrang.com" : "or email: hallo@datendrang.com",
};
const placeholder = (label: string, h = "clamp(320px,46vw,600px)") =>
  `background:#EFEAE0; border:1px solid #E2E8F0; border-radius:8px; height:${h}; display:flex; align-items:center; justify-content:center; color:#92938F; font-size:13px; text-align:center; padding:16px;`;
---
<!-- HERO (dunkel · Blueprint-Grid · UI-Mockup) -->
