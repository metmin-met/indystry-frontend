---
// Kunden-Self-Service-Portal (lang-aware, read-only): Auftragsstatus, Rechnungen, Service/Wartung,
// Reklamation — aus Kundensicht, kohärent zu Nordwerk + dem Zustandsmodell. Demo-Daten.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
const L = (d: string, e: string, c?: string) => (de ? d : en ? e : (c ?? e));
const P = (path: string) => (de ? "" : en ? "/en" : "/cn") + path;
const kunde = "Helvetia Pumpen AG";
const auftraege = [
  { id: "SO-0042", produkt: "NW-1001 · " + L("Lagerbock Typ A", "Bearing block A", "轴承座 A 型"), menge: 200, status: "geliefert", c: "#16794a" },
  { id: "SO-0051", produkt: "NW-2010 · " + L("Flanschplatte 120", "Flange plate 120", "法兰板 120"), menge: 150, status: "fertigung", c: "#E6B23A" },
  { id: "SO-0058", produkt: "NW-3006 · " + L("Wellenadapter M", "Shaft adapter M", "轴适配器 M"), menge: 100, status: "bestätigt", c: "#1d4ed8" },
  { id: "SO-0063", produkt: "NW-4002 · " + L("Gehäusedeckel", "Housing cover", "壳体盖板"), menge: 80, status: "angebot", c: "#92938F" },
];
const ST: Record<string, string> = {
  angebot: L("Angebot", "Quote", "报价"), bestätigt: L("Auftrag bestätigt", "Order confirmed", "订单已确认"),
  fertigung: L("in Fertigung", "in production", "生产中"), geliefert: L("geliefert", "delivered", "已交付"),
};
const rechnungen = [
  { id: "RE-2026-0188", auftrag: "SO-0042", betrag: "7.600,00 €", status: "offen", c: "#E6B23A" },
  { id: "RE-2026-0151", auftrag: "SO-0039", betrag: "4.250,00 €", status: "bezahlt", c: "#16794a" },
];
const RST: Record<string, string> = { offen: L("offen", "open", "未付"), bezahlt: L("bezahlt", "paid", "已付") };
---
<section style="background:#F8F9FA; min-height:80vh;">
  <div style="max-width:1000px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{L("Kundenportal · read-only", "Customer portal · read-only", "客户门户 · 只读")}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(30px,5vw,52px); line-height:1.0; letter-spacing:-0.03em; margin:0 0 8px;">{L("Willkommen, ", "Welcome, ", "欢迎，")}{kunde}.</h1>
    <p style="font-size:clamp(16px,1.5vw,19px); line-height:1.6; color:#5C5E63; max-width:60ch; margin:0 0 clamp(32px,4vw,48px);">{L("Ihre Aufträge, Rechnungen, Wartung und Reklamationen bei Nordwerk — an einem Ort, jederzeit.", "Your orders, invoices, maintenance and complaints at Nordwerk — one place, anytime.", "您在 Nordwerk 的订单、发票、维护和投诉 — 集于一处，随时可查。")}</p>

    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 12px;">{L("Aufträge", "Orders", "订单")}</p>
    <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; overflow:hidden; margin-bottom:clamp(32px,4vw,44px);">
      {auftraege.map((a, i) => (
        <div style={`display:grid; grid-template-columns:auto 1fr auto auto; gap:14px; align-items:center; padding:13px 18px; ${i ? "border-top:1px solid #F1F3F2;" : ""}`}>
          <span style="font-family:var(--font-mono); font-size:12px; color:#92938F;">{a.id}</span>
          <span style="font-size:15px; color:#1B1C1E;">{a.produkt}</span>
          <span style="font-family:var(--font-mono); font-size:12px; color:#5C5E63;">{a.menge} {L("Stk", "pcs", "件")}</span>
          <span style={`font-family:var(--font-mono); font-size:11px; color:${a.c}; border:1px solid ${a.c}44; border-radius:999px; padding:3px 10px; white-space:nowrap;`}>● {ST[a.status]}</span>
        </div>
      ))}
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; margin-bottom:clamp(32px,4vw,44px);">
      <div>
        <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 12px;">{L("Rechnungen", "Invoices", "发票")}</p>
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; overflow:hidden;">
          {rechnungen.map((r, i) => (
            <div style={`display:flex; align-items:center; justify-content:space-between; gap:10px; padding:12px 16px; ${i ? "border-top:1px solid #F1F3F2;" : ""}`}>
              <span style="font-family:var(--font-mono); font-size:12px; color:#92938F;">{r.id}</span>
              <span style="font-size:14px; color:#1B1C1E;">{r.betrag}</span>
              <span style={`font-family:var(--font-mono); font-size:11px; color:${r.c}; border:1px solid ${r.c}44; border-radius:999px; padding:2px 9px;`}>{RST[r.status]}</span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 12px;">{L("Service & Wartung", "Service & maintenance", "服务与维护")}</p>
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <p style="font-size:14px; color:#1B1C1E; margin:0 0 6px;"><strong>{L("Servicevertrag aktiv", "Service contract active", "服务合同有效")}</strong> · SLA 48 h</p>
          <p style="font-size:13px; color:#5C5E63; line-height:1.5; margin:0;">{L("Nächste präventive Wartung: in 3 Wochen. Letzter Einsatz: dokumentiert, ohne Befund.", "Next preventive maintenance: in 3 weeks. Last visit: documented, no findings.", "下一次预防性维护：3 周后。上次上门：已记录，未发现问题。")}</p>
        </div>
      </div>
    </div>

    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 12px;">{L("Reklamation melden", "Report a complaint", "提交投诉")}</p>
    <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:clamp(16px,2.5vw,24px);">
      <div style="display:grid; gap:10px; max-width:560px;">
        <input disabled placeholder={L("Auftrag (z. B. SO-0042)", "Order (e.g. SO-0042)", "订单（例如 SO-0042）")} style="padding:11px 14px; border:1px solid #C0C8C5; border-radius:9px; background:#F8F9FA; font-family:inherit; font-size:14px; color:#92938F;" />
        <textarea disabled rows="3" placeholder={L("Was ist aufgetreten?", "What happened?", "发生了什么问题？")} style="padding:11px 14px; border:1px solid #C0C8C5; border-radius:9px; background:#F8F9FA; font-family:inherit; font-size:14px; color:#92938F; resize:none;"></textarea>
        <span style="font-family:var(--font-mono); font-size:11px; color:#92938F;">{L("Demo · read-only — im Echtbetrieb landet die Meldung direkt als Fall im System (Status verfolgbar).", "Demo · read-only — in production this lands straight as a case in the system (trackable status).", "演示 · 只读 — 在实际运行中，该报告会直接作为一个案例进入系统（状态可追踪）。")}</span>
      </div>
    </div>

    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:clamp(28px,4vw,40px) 0 12px;">{L("E-Rechnung (PEPPOL)", "E-invoice (PEPPOL)", "电子发票（PEPPOL）")}</p>
    <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:clamp(16px,2.5vw,24px);">
      <div style="display:flex; flex-wrap:wrap; align-items:center; gap:12px; justify-content:space-between;">
        <div><p style="margin:0; font-weight:600; color:#1B1C1E;">RE-2026-0188 · 7.600,00 €</p><p style="margin:2px 0 0; font-size:13px; color:#5C5E63;">200× NW-1001 · {L("Lagerbock Typ A","Bearing block A","轴承座 A 型")} · Helvetia Pumpen AG</p></div>
        <div style="display:flex; gap:8px;">
          <button id="er-view" type="button" style="font-family:var(--font-mono); font-size:12px; font-weight:600; padding:9px 14px; border:1px solid #C0C8C5; border-radius:9px; background:#fff; color:#16463E; cursor:pointer;">{L("Rechnung ansehen","View invoice","查看发票")}</button>
          <button id="er-dl" type="button" style="font-family:var(--font-mono); font-size:12px; font-weight:600; padding:9px 14px; border:none; border-radius:9px; background:#123A33; color:#fff; cursor:pointer;">PEPPOL-XML ↓</button>
        </div>
      </div>
      <div id="er-detail" hidden style="margin-top:16px; border-top:1px solid #EFEAE0; padding-top:16px;">
        <div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-bottom:14px;">
          <div><p style="margin:0; font-weight:600; color:#123A33;">Nordwerk Manufacturing</p><p style="margin:2px 0 0; font-size:12px; color:#92938F;">Werkstr. 1 · AT</p></div>
          <div style="text-align:right;"><p style="margin:0; font-size:12px; color:#92938F;">{L("Rechnung","Invoice","发票")} RE-2026-0188</p><p style="margin:2px 0 0; font-size:12px; color:#92938F;">{L("Kunde","Customer","客户")}: Helvetia Pumpen AG</p></div>
        </div>
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
          <tr style="border-bottom:1px solid #E2E8F0;"><th style="text-align:left; padding:6px 4px; font-family:var(--font-mono); font-size:10px; text-transform:uppercase; color:#92938F;">{L("Position","Item","项目")}</th><th style="text-align:right; padding:6px 4px; font-family:var(--font-mono); font-size:10px; text-transform:uppercase; color:#92938F;">{L("Menge","Qty","数量")}</th><th style="text-align:right; padding:6px 4px; font-family:var(--font-mono); font-size:10px; text-transform:uppercase; color:#92938F;">{L("Einzel","Unit","单价")}</th><th style="text-align:right; padding:6px 4px; font-family:var(--font-mono); font-size:10px; text-transform:uppercase; color:#92938F;">{L("Netto","Net","净额")}</th></tr>
          <tr><td style="padding:8px 4px;">NW-1001 · {L("Lagerbock Typ A","Bearing block A","轴承座 A 型")}</td><td style="text-align:right; padding:8px 4px;">200</td><td style="text-align:right; padding:8px 4px;">31,67 €</td><td style="text-align:right; padding:8px 4px;">6.333,33 €</td></tr>
          <tr><td colspan="3" style="text-align:right; padding:6px 4px; color:#5C5E63;">{L("Netto","Net","净额")}</td><td style="text-align:right; padding:6px 4px;">6.333,33 €</td></tr>
          <tr><td colspan="3" style="text-align:right; padding:4px; color:#5C5E63;">USt 20 %</td><td style="text-align:right; padding:4px;">1.266,67 €</td></tr>
          <tr><td colspan="3" style="text-align:right; padding:8px 4px; font-weight:700; color:#123A33; border-top:1px solid #123A33;">{L("Brutto","Gross","总额")}</td><td style="text-align:right; padding:8px 4px; font-weight:700; color:#123A33; border-top:1px solid #123A33;">7.600,00 €</td></tr>
        </table>
        <p style="font-family:var(--font-mono); font-size:11px; color:#92938F; margin:12px 0 0;">{L("UBL / PEPPOL BIS Billing 3.0 — normkonform elektronisch versendbar.","UBL / PEPPOL BIS Billing 3.0 — standard-compliant e-dispatch.","UBL / PEPPOL BIS Billing 3.0 — 符合规范，可电子发送。")}</p>
      </div>
    </div>

    <p style="font-family:var(--font-mono); font-size:11px; color:#92938F; margin:clamp(32px,4vw,48px) 0 0;">{L("Demo-Daten der fiktiven Firma Nordwerk. Status spiegeln das Auftrags-Zustandsmodell (Angebot → Auftrag → Fertigung → Lieferung → Rechnung).", "Demo data of the fictional company Nordwerk. Statuses mirror the order state model (quote → order → production → delivery → invoice).", "虚构公司 Nordwerk 的演示数据。状态映射订单状态模型（报价 → 订单 → 生产 → 交付 → 发票）。")}</p>
  </div>
  <script>
    (function(){
      var v=document.getElementById("er-view"), d=document.getElementById("er-detail"), dl=document.getElementById("er-dl");
      if(v&&d) v.addEventListener("click", function(){ d.hidden=!d.hidden; });
      if(dl) dl.addEventListener("click", function(){
        var xml = [
          '<?xml version="1.0" encoding="UTF-8"?>',
          '<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2" xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2" xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2">',
          '  <cbc:CustomizationID>urn:cen.eu:en16931:2017#compliant#urn:fdc:peppol.eu:2017:poacc:billing:3.0</cbc:CustomizationID>',
          '  <cbc:ProfileID>urn:fdc:peppol.eu:2017:poacc:billing:01:1.0</cbc:ProfileID>',
          '  <cbc:ID>RE-2026-0188</cbc:ID>',
          '  <cbc:IssueDate>2026-06-15</cbc:IssueDate>',
          '  <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>',
          '  <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>',
          '  <cac:AccountingSupplierParty><cac:Party><cac:PartyName><cbc:Name>Nordwerk Manufacturing</cbc:Name></cac:PartyName></cac:Party></cac:AccountingSupplierParty>',
          '  <cac:AccountingCustomerParty><cac:Party><cac:PartyName><cbc:Name>Helvetia Pumpen AG</cbc:Name></cac:PartyName></cac:Party></cac:AccountingCustomerParty>',
          '  <cac:TaxTotal><cbc:TaxAmount currencyID="EUR">1266.67</cbc:TaxAmount></cac:TaxTotal>',
          '  <cac:LegalMonetaryTotal><cbc:TaxExclusiveAmount currencyID="EUR">6333.33</cbc:TaxExclusiveAmount><cbc:TaxInclusiveAmount currencyID="EUR">7600.00</cbc:TaxInclusiveAmount><cbc:PayableAmount currencyID="EUR">7600.00</cbc:PayableAmount></cac:LegalMonetaryTotal>',
          '  <cac:InvoiceLine><cbc:ID>1</cbc:ID><cbc:InvoicedQuantity unitCode="C62">200</cbc:InvoicedQuantity><cbc:LineExtensionAmount currencyID="EUR">6333.33</cbc:LineExtensionAmount><cac:Item><cbc:Name>NW-1001 Lagerbock Typ A</cbc:Name></cac:Item><cac:Price><cbc:PriceAmount currencyID="EUR">31.67</cbc:PriceAmount></cac:Price></cac:InvoiceLine>',
          '</Invoice>'
        ].join("\n");
        var blob=new Blob([xml],{type:"application/xml"}); var a=document.createElement("a");
        a.href=URL.createObjectURL(blob); a.download="RE-2026-0188.xml"; a.click(); URL.revokeObjectURL(a.href);
      });
    })();
  </script>
</section>
