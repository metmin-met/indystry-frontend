---
// /ueber-uns/ — Wer hinter indystry steht: Betreiber (DATENDRANG), Betriebsmodell, Referenz. Trust-Seite.
import type { Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
const b = de ? "" : en ? "/en" : "/cn";
const L = (d: string, e: string, c?: string) => (de ? d : en ? e : (c ?? e));
const AC = "#E6B23A";
const pillars = [
  { t: L("Betrieb inklusive", "Operation included", "运营托管一并包含"), d: L("Ihr bekommt nicht den Quellcode hingeworfen, sondern ein laufendes System — wir betreiben, überwachen und aktualisieren es.", "You are not handed source code — you get a running system. We operate, monitor and update it.", "我们交付的不是一堆源代码，而是一套正在运行的系统 —— 由我们运营、监控并持续更新。") },
  { t: L("Ein Ansprechpartner", "One point of contact", "唯一对接人"), d: L("Kein Abteilungs-Pingpong. Eine Stelle, die das Ganze überblickt — von der Infrastruktur bis zum Geschäftsprozess.", "No departmental ping-pong. One contact who sees the whole — from infrastructure to business process.", "不用在各部门之间来回踢皮球。一个人统揽全局 —— 从基础设施到业务流程。") },
  { t: L("Eure Hoheit bleibt", "Your sovereignty stays", "自主权始终在您手中"), d: L("Offene Bausteine, eure Hardware, eure Daten. Keine Lizenz-Eskalation, kein Anbieter-Lock-in.", "Open building blocks, your hardware, your data. No licence escalation, no vendor lock-in.", "开源模块、您的硬件、您的数据。没有许可费层层加码，没有厂商锁定。") },
];
---
<!-- HERO -->
<section style="position:relative; background:#123A33; color:#F4F6F5; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-25%; left:58%; width:55%; height:90%; background:radial-gradient(circle,rgba(230,178,58,.18),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(52px,8vw,104px) clamp(24px,5vw,56px) clamp(40px,6vw,64px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px;">{L("Über uns", "About us", "关于我们")}</p>
    <h1 style="font-family:var(--font-head); font-weight:700; font-size:clamp(34px,6.5vw,68px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:18ch;">{L("Wer hinter", "Who stands behind", "谁在支撑")} <span style="color:#E6B23A;">indystry</span> {L("steht.", "", "。")}</h1>
    <p style="font-size:clamp(17px,1.7vw,21px); line-height:1.6; color:#CADAD5; max-width:64ch; margin:0;">{L("Eine souveräne Fabrik braucht jemanden, der sie betreibt — nicht nur Software, die man Ihnen überlässt. Genau das ist unsere Rolle: Betrieb, Support und Verantwortung aus einer Hand.", "A sovereign factory needs someone to run it — not just software you are left with. That is exactly our role: operation, support and responsibility from one source.", "一座自主可控的工厂需要有人来运营它 —— 而不仅仅是把软件丢给您自行处理。这正是我们的角色：运营、支持与责任，全部一站式承担。")}</p>
  </div>
</section>

<!-- BETRIEBSMODELL -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,72px) clamp(24px,5vw,56px) clamp(20px,3vw,28px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§01 · {L("Das Modell", "The model", "运营模式")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(248px,1fr)); gap:14px;">
      {pillars.map((m) => (
        <div style={`border:1px solid #E2E8F0; border-left:3px solid ${AC}; border-radius:12px; background:#fff; padding:18px 20px;`}>
          <p style="font-weight:700; font-size:16px; color:#1B1C1E; margin:0 0 6px; font-family:var(--font-head);">{m.t}</p>
          <p style="font-size:14px; line-height:1.55; color:#5C5E63; margin:0;">{m.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- DER ANBIETER -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(20px,3vw,28px) clamp(24px,5vw,56px) clamp(44px,6vw,72px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§02 · {L("Der Anbieter", "The provider", "服务提供方")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:minmax(0,1.3fr) minmax(0,1fr); gap:28px; align-items:start;">
      <div>
        <p style="font-size:16px; line-height:1.7; color:#3C3E42; margin:0 0 14px;">{L("indystry wird gebaut und betrieben von der", "indystry is built and operated by", "indystry 由")} <strong style="color:#1B1C1E;">DATENDRANG Software GmbH &amp; Co KG</strong> {L("in Graz — einem IT- und Automatisierungshaus mit langjähriger Erfahrung an der Naht zwischen Infrastruktur, Automatisierung und Geschäftsprozessen.", "in Graz — an IT and automation house with many years of experience at the seam between infrastructure, automation and business processes.", "构建并运营，公司位于格拉茨 —— 一家在基础设施、自动化与业务流程交汇处拥有多年经验的 IT 与自动化企业。")}</p>
        <p style="font-size:16px; line-height:1.7; color:#3C3E42; margin:0;">{L("Geführt von David Fuchs, dahinter ein eingespieltes Team. Für Sie heißt das: jemand, der das Ganze überblickt und es auch im Betrieb hält — nicht nur verkauft.", "Led by David Fuchs, with a tight-knit team behind him. For you that means: someone who sees the whole and keeps it running — not just sells it.", "由 David Fuchs 带领，背后是一支配合默契的团队。对您而言，这意味着：有人统揽全局并让系统持续运转 —— 而不仅仅是把它卖给您。")}</p>
        <p style="font-size:14px; line-height:1.7; color:#5C5E63; margin:16px 0 0;"><a href={b + "/impressum/"} style="color:#16463E; font-weight:600; text-decoration:none;">{L("Vollständiges Impressum", "Full legal notice", "完整法律声明")} →</a></p>
      </div>
      <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:20px;">
        <p style="font-family:var(--font-mono); font-size:11px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#92938F; margin:0 0 12px;">{L("Sitz & Kontakt", "Office & contact", "地址与联系方式")}</p>
        <p style="font-size:14px; line-height:1.7; color:#3C3E42; margin:0;">DATENDRANG Software GmbH &amp; Co KG<br>Neubaugasse 24, 8020 Graz<br>Österreich</p>
        <p style="font-size:14px; line-height:1.7; color:#3C3E42; margin:12px 0 0;"><a href="mailto:hallo@datendrang.com" style="color:#16463E; font-weight:600; text-decoration:none;">hallo@datendrang.com</a></p>
      </div>
    </div>
  </div>
</section>

<!-- REFERENZ -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; gap:16px; align-items:flex-start; max-width:84ch;">
      <span style="font-family:var(--font-mono); font-size:17px; color:#16463E; flex:none; margin-top:4px;">★</span>
      <div>
        <p style="margin:0; font-size:clamp(18px,2vw,26px); line-height:1.45; color:#1B1C1E; font-family:var(--font-head); font-weight:600;">{L("Ein produzierender Industriebetrieb aus der Steiermark führt seine gesamte Fertigung auf diesem Stack — Tag für Tag, im Echtbetrieb.", "A manufacturing company in Styria runs its entire production on this stack — day after day, in real operation.", "施蒂利亚州的一家生产型工业企业在这套技术栈上运行其全部生产 —— 日复一日，实实在在地运转。")}</p>
        <p style="margin:14px 0 0; font-size:14px; line-height:1.6; color:#5C5E63;">{L("Bewiesen, nicht versprochen. ", "Proven, not promised. ", "已被验证，而非空口承诺。")}<a href={b + "/einstieg/"} style="color:#16463E; font-weight:600; text-decoration:none;">{L("So läuft der Einstieg", "How getting started works", "入门流程是这样的")} →</a></p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="position:relative; background:#0E2E29; color:#EAF1EE; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-20%; left:50%; transform:translateX(-50%); width:60%; height:80%; background:radial-gradient(circle,rgba(230,178,58,.13),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px); text-align:center;">
    <h2 style="font-family:var(--font-head); font-weight:800; font-size:clamp(28px,5vw,52px); line-height:1.02; letter-spacing:-0.035em; margin:0 auto; max-width:22ch;">{L("Reden wir — unter Praktikern.", "Let us talk — among practitioners.", "让我们聊聊 —— 都是实干的行家。")}</h2>
    <p style="font-size:clamp(16px,1.7vw,20px); color:#C7D8D2; max-width:54ch; margin:20px auto 30px;">{L("Kein Verteiler, kein Sales-Blabla. Ein Ansprechpartner, der das Ganze überblickt.", "No mailing list, no sales talk. One contact who sees the whole picture.", "没有群发名单，没有销售套话。一个统揽全局的对接人。")}</p>
    <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
      <a href={b + "/kontakt/"} style="background:#E6B23A; color:#123A33; text-decoration:none; font-family:var(--font-head); font-weight:700; font-size:16px; padding:15px 26px; border-radius:10px;">{L("Kontakt aufnehmen", "Get in touch", "取得联系")} →</a>
      <a href={b + "/demos/"} style="font-family:var(--font-mono); font-size:13px; color:#A6CFC5; display:inline-flex; align-items:center;">{L("Erst die Demo ansehen", "See the demo first", "先看看演示")} ↗</a>
    </div>
  </div>
</section>
