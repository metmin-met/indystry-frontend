---
// Demo-Firma-Hub: alle read-only Demos als EINE Firma „Nordwerk Manufacturing", nach Prozess-Stufe
// gruppiert, + Beispiel-Spuren über die Systeme. DE/EN via lang.
import { demos, type Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
const live = demos.filter((d) => d.status === "live");
const soon = demos.filter((d) => d.status !== "live");

// URL-Helfer (robust, ohne slug-Abhängigkeit)
const find = (frag: string) => (live.find((d) => d.url.includes(frag)) || ({} as any)).url || "#";
const U = { erp: find("erp-demo"), bi: find("bi-demo"), cockpit: find("grafana-demo"), twin: find("twin-demo"), lab: find("lab-demo"), app: find("app-demo") };
const P = (path) => (de ? "" : en ? "/en" : "/cn") + path;
const ANLAGE = P("/anlage/");

// Prozess-Stufen
const STAGES = de
  ? [
      ["betrieb", "Auftrag & Betrieb", "ERP — vom Angebot bis zur Rechnung"],
      ["fertigung", "Fertigung & Leitstand", "Was die Maschinen gerade tun"],
      ["anlage", "Anlage & Schaltschrank", "Runter bis auf den Stromlaufplan"],
      ["bi", "Qualität & Auswertung", "Zahlen statt Tabellen"],
      ["data", "Data-Science", "Eigene Analysen auf den Werksdaten"],
      ["status", "Betrieb & Status", "Läuft alles, ist alles gesichert"],
      ["wissen", "Wissen & Suche", "Handbuch, Suche, Compliance"],
      ["collab", "Zusammenarbeit", "Dokumente, geteilt und versioniert"],
      ["aussen", "Außenauftritt & Kunde", "Firmen-Website + Kundenportal"],
      ["story", "Verstehen & Story", "Ein Tag, Glossar, KI & Mensch"],
    ]
  : en
  ? [
      ["betrieb", "Orders & operations", "ERP — from quote to invoice"],
      ["fertigung", "Production & control room", "What the machines are doing"],
      ["anlage", "Plant & control cabinet", "Down to the wiring plan"],
      ["bi", "Quality & analytics", "Numbers, not spreadsheets"],
      ["data", "Data science", "Your own analyses on the factory data"],
      ["status", "Operations & status", "Is everything up and backed up"],
      ["wissen", "Knowledge & search", "Handbook, search, compliance"],
      ["collab", "Collaboration", "Documents, shared and versioned"],
      ["aussen", "Web & customer", "Company website + customer portal"],
      ["story", "Understand & story", "A day, glossary, AI & humans"],
    ]
  : [
      ["betrieb", "订单与运营", "ERP — 从报价到开票"],
      ["fertigung", "生产与中控室", "机器当前的运行状态"],
      ["anlage", "设备与控制柜", "深入到电气原理图"],
      ["bi", "质量与分析", "用数字说话，而非表格"],
      ["data", "数据科学", "在工厂数据上做您自己的分析"],
      ["status", "运营与状态", "一切是否运行正常、是否已备份"],
      ["wissen", "知识与搜索", "手册、搜索、合规"],
      ["collab", "协作", "文档，共享且带版本管理"],
      ["aussen", "对外形象与客户", "企业官网 + 客户门户"],
      ["story", "理解与故事", "一天、术语表、AI 与人"],
    ];

const stageOf = (url: string) =>
  url.includes("erp-demo") ? "betrieb"
  : url.includes("grafana-demo") || url.includes("app-demo") ? "fertigung"
  : url.includes("twin-demo") ? "anlage"
  : url.includes("bi-demo") ? "bi"
  : url.includes("lab-demo") ? "data" : "data";

const cards = live.map((d) => ({ title: d.title[lang], desc: d.desc[lang], href: d.url, login: d.login, stage: stageOf(d.url) }));
// Interne Anlage-Demo (nicht in demos.yaml) einhängen
cards.push({
  title: de ? "Anlage & Schaltschrank · 3D" : en ? "Plant & control cabinet · 3D" : "设备与控制柜 · 3D",
  desc: de ? "Von der Maschine in den Schaltschrank bis zum Stromlaufplan — klickbarer 3D-Drilldown." : en ? "From the machine into the control cabinet down to the wiring plan — clickable 3D drilldown." : "从机器到控制柜，再到电气原理图 — 可点击的 3D 逐层钻取。",
  href: ANLAGE, login: "", stage: "anlage",
});
cards.push({
  title: de ? "Digitaler Zwilling · Live + Optimizer" : en ? "Digital twin · live + optimizer" : "数字孪生 · 实时 + 优化器",
  desc: de ? "Echtbetrieb, Röntgenblick, übersteuern — und den KI-Optimizer fragen." : en ? "Real operation, X-ray view, override — and ask the AI optimizer." : "真实运行、透视视图、手动干预 — 并向 AI 优化器提问。",
  href: P("/twin/"), login: "", stage: "anlage",
});
cards.push({
  title: de ? "Wissensgraph · 3D" : en ? "Knowledge graph · 3D" : "知识图谱 · 3D",
  desc: de ? "Die ganze Firma als 3D-Netz — Linie, Maschine, Produkt, Auftrag, Kunde, Charge." : en ? "The whole company as a 3D network — line, machine, product, order, customer, batch." : "整个企业化为 3D 网络 — 产线、机器、产品、订单、客户、批次。",
  href: P("/graph/"), login: "", stage: "anlage",
});
cards.push({
  title: de ? "Werkstoff-Analyse" : en ? "Material analysis" : "材料分析",
  desc: de ? "Oberfläche, Schliff, Mikroskopie + Messwerte je Charge." : en ? "Surface, cross-section, microscopy + measurements per batch." : "表面、金相、显微 + 每批次的测量值。",
  href: P("/analyse/"), login: "", stage: "anlage",
});
cards.push({
  title: de ? "Leitstand · SCADA" : en ? "Control room · SCADA" : "中控室 · SCADA",
  desc: de ? "Alle Maschinen auf einen Blick — Status und Live-Messwerte in der Operator-Sicht." : en ? "Every machine at a glance — status and live readings in the operator view." : "所有机器一览无余 — 操作员视图中的状态与实时测量值。",
  href: P("/leitstand/"), login: "", stage: "fertigung",
});
cards.push({
  title: de ? "Historian-Explorer" : en ? "Historian explorer" : "历史数据库浏览器",
  desc: de ? "Zeitreihen-Browser über alle Maschinen und Messreihen — dieselben Sensordaten wie in der BI." : en ? "Time-series browser across all machines and metrics — the same sensor data as in BI." : "跨所有机器与测量序列的时序浏览器 — 与 BI 中相同的传感器数据。",
  href: P("/historian/"), login: "", stage: "data",
});
cards.push({
  title: de ? "Status-Board" : en ? "Status board" : "状态看板",
  desc: de ? "Welche Dienste laufen, wann das letzte Backup lief, wie stabil alles ist." : en ? "Which services are up, when the last backup ran, how stable everything is." : "哪些服务在运行、上次备份何时进行、整体有多稳定。",
  href: P("/status/"), login: "", stage: "status",
});
cards.push({
  title: de ? "KI-Suche · Frag die Firma" : en ? "AI search · Ask the company" : "AI 搜索 · 向企业提问",
  desc: de ? "Volltextsuche über Produkte, Maschinen, Aufträge, Handbuch und Kennzahlen." : en ? "Full-text search across products, machines, orders, handbook and metrics." : "跨产品、机器、订单、手册与关键指标的全文搜索。",
  href: P("/suche/"), login: "", stage: "wissen",
});
cards.push({
  title: de ? "Wissen & Kiosk" : en ? "Knowledge & kiosk" : "知识与自助终端",
  desc: de ? "Handbuch, Compliance-Register und der App-Launcher der Firma." : en ? "Handbook, compliance register and the company app launcher." : "手册、合规登记册以及企业的应用启动器。",
  href: P("/wissen/"), login: "", stage: "wissen",
});
cards.push({
  title: de ? "Zusammenarbeit · Dateiraum" : en ? "Collaboration · file room" : "协作 · 文件空间",
  desc: de ? "Angebote, Zeichnungen, Prüfprotokolle — geteilt, versioniert, kommentierbar." : en ? "Quotes, drawings, inspection records — shared, versioned, commentable." : "报价、图纸、检验记录 — 共享、带版本、可评论。",
  href: P("/zusammenarbeit/"), login: "", stage: "collab",
});
cards.push({
  title: de ? "Nordwerk-Homepage" : en ? "Nordwerk homepage" : "Nordwerk 官网",
  desc: de ? "Die eigene Firmen-Website der Demo-Firma — selbst gehostet." : en ? "The demo company's own website — self-hosted." : "这家演示企业自己的官网 — 自托管。",
  href: P("/werk/"), login: "", stage: "aussen",
});
cards.push({
  title: de ? "Kundenportal · Self-Service" : en ? "Customer portal · self-service" : "客户门户 · 自助服务",
  desc: de ? "Aufträge, Rechnungen, Service, Reklamation aus Kundensicht." : en ? "Orders, invoices, service, complaints from the customer's view." : "从客户视角查看订单、发票、服务与投诉。",
  href: P("/portal/"), login: "", stage: "aussen",
});
cards.push({
  title: de ? "Ein Tag bei Nordwerk" : en ? "A day at Nordwerk" : "Nordwerk 的一天",
  desc: de ? "Eine Schicht als Geschichte — jede Szene führt ins echte System." : en ? "One shift as a story — each scene leads into the real system." : "把一个班次讲成故事 — 每个场景都引向真实系统。",
  href: P("/tag/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Geführte Tour · Der rote Faden" : en ? "Guided tour · The thread" : "导览 · 主线",
  desc: de ? "Eine Bestellung Schritt für Schritt durch alle Systeme." : en ? "One order step by step through all systems." : "一份订单，一步步贯穿所有系统。",
  href: P("/tour/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Ich bin … (Rollen-Einstieg)" : en ? "I am … (role entry)" : "我是 …（按角色进入）",
  desc: de ? "Wähl deine Rolle — was indystry für dich tut, mit den passenden Demos." : en ? "Pick your role — what indystry does for you, with the matching demos." : "选择您的角色 — indystry 能为您做什么，并附上匹配的演示。",
  href: P("/ich-bin/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Aus Erfahrung gebaut" : en ? "Built from experience" : "源于实战经验",
  desc: de ? "Was schon läuft: Daten/Twin, Finanzen, Instandhaltung, Wissen, IT & Geräte." : en ? "What's already running: data/twin, finance, maintenance, knowledge, IT & devices." : "已经在运行的：数据/孪生、财务、维护、知识、IT 与设备。",
  href: P("/koennen/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Daily Industrie 4.0" : en ? "Daily Industry 4.0" : "每日工业 4.0",
  desc: de ? "Selbst gehosteter KI-News-Digest zur vernetzten Fabrik." : en ? "Self-hosted AI news digest on the connected factory." : "关于互联工厂的自托管 AI 新闻摘要。",
  href: P("/daily/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Datenschutz & KI-Souveränität" : en ? "Privacy & AI sovereignty" : "数据保护与 AI 自主可控（数据主权）",
  desc: de ? "Von Cloud-KI bis zum eigenen, on-prem trainierten Modell." : en ? "From cloud AI to your own on-prem trained model." : "从云端 AI 到您自己本地训练的模型。",
  href: P("/datenhoheit/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Schnittstellen" : en ? "Interfaces" : "接口",
  desc: de ? "Womit reden wir? SPS, OPC-UA, API, MCP, PEPPOL, DATEV …" : en ? "What do we talk to? PLC, OPC-UA, API, MCP, PEPPOL, DATEV …" : "我们与什么对接？SPS、OPC-UA、API、MCP、PEPPOL、DATEV …",
  href: P("/schnittstellen/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Werks-Landkarte" : en ? "Factory map" : "工厂地图",
  desc: de ? "Jede Phase, jedes Tool, jede Live-Demo — klickbar & gefiltert." : en ? "Every phase, every tool, every live demo — clickable & filtered." : "每个阶段、每个工具、每个实时演示 — 可点击且可筛选。",
  href: P("/landkarte/"), login: "", stage: "story",
});
cards.push({
  title: de ? "So skaliert das System" : en ? "How the system scales" : "系统如何扩展",
  desc: de ? "Core bleibt gleich, Hardware wächst — und wann sich Kafka lohnt." : en ? "Core stays the same, hardware grows — and when Kafka pays off." : "核心保持不变，硬件随需增长 — 以及何时值得引入 Kafka。",
  href: P("/rechner/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Glossar" : en ? "Glossary" : "术语表",
  desc: de ? "Alle Begriffe, jeder mit Link zum Thema." : en ? "Every term, each linked to its topic." : "所有术语，每个都链接到相应主题。",
  href: P("/glossar/"), login: "", stage: "story",
});
cards.push({
  title: de ? "Onboarding & Lernen" : en ? "Onboarding & learning" : "入职引导与学习",
  desc: de ? "Lernpfad mit Lektion + Quiz, Fortschritt gespeichert." : en ? "Learning path with lesson + quiz, progress saved." : "含课程 + 测验的学习路径，进度自动保存。",
  href: P("/lernen/"), login: "", stage: "story",
});
cards.push({
  title: de ? "KI & Mensch" : en ? "AI & humans" : "AI 与人",
  desc: de ? "Was die KI übernimmt — und wofür es Menschen braucht." : en ? "What the AI takes on — and what still needs humans." : "AI 接手了什么 — 又有什么仍然离不开人。",
  href: P("/ki-mensch/"), login: "", stage: "story",
});

const ph = "background:#EFEAE0; border:1px solid #E2E8F0; border-radius:8px; height:clamp(150px,16vw,200px); display:flex; align-items:center; justify-content:center; color:#92938F; font-size:13px; text-align:center; padding:16px; margin-bottom:18px;";
const open = de ? "öffnen ↗" : en ? "open ↗" : "打开 ↗";
const ro = de ? "read-only" : en ? "read-only" : "read-only";
---
<section style="background:#F8F9FA;">
  <div style="max-width:1280px; margin:0 auto; padding:clamp(64px,8vw,112px) clamp(24px,5vw,56px) clamp(96px,12vw,168px);">
    <p style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 clamp(24px,3vw,36px);">{de ? "Demo-Firma · Nordwerk Manufacturing" : en ? "Demo company · Nordwerk Manufacturing" : "演示企业 · Nordwerk Manufacturing"}</p>
    <h1 style="font-weight:600; font-size:clamp(40px,7vw,84px); line-height:0.98; letter-spacing:-0.03em; margin:0 0 18px; max-width:18ch;">{de ? "Eine ganze Firma zum Durchklicken." : en ? "A whole company to click through." : "一整家企业，任您逐一点击体验。"}</h1>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#5C5E63; max-width:62ch; margin:0;">{de ? "„Nordwerk Manufacturing“ ist eine fiktive Metallteile-Fertigung — komplett auf indystry. Auftrag, Maschinen, Schaltschrank, Qualität, Auswertung: alles dieselbe Firma, dieselben Daten. Alles zum Ansehen, nichts kann kaputtgehen." : en ? "“Nordwerk Manufacturing” is a fictional metal-parts shop — fully on indystry. Orders, machines, control cabinet, quality, analytics: one company, one set of data. All read-only, nothing can break." : "「Nordwerk Manufacturing」是一家虚构的金属零件工厂 — 完全构建于 indystry 之上。订单、机器、控制柜、质量、分析：同一家企业，同一套数据。一切皆可查看，任何操作都不会造成损坏。"}</p>
    <p style="font-family:var(--font-mono); font-size:13px; color:#92938F; margin:14px 0 0;">{de ? "synthetische Daten · alle Demos read-only" : en ? "synthetic data · all demos read-only" : "合成数据 · 所有演示均为 read-only"}</p>

    <!-- Beispiel-Spuren -->
    <div style="margin-top:clamp(40px,5vw,60px); border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:clamp(22px,3vw,32px);">
      <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{de ? "Folg dem roten Faden" : en ? "Follow the thread" : "顺着主线走"}</p>
      <p style="font-size:16px; line-height:1.7; color:#1B1C1E; margin:0 0 10px;">
        <strong>{de ? "Produkt NW-1001 „Lagerbock Typ A“" : en ? "Product NW-1001 “Bearing block A”" : "产品 NW-1001「A 型轴承座」"}:</strong>
        <a href={U.erp} style="color:#16463E;text-decoration:none;border-bottom:1.5px solid #C0C8C5;">{de ? "Auftrag im ERP" : en ? "order in ERP" : "ERP 中的订单"}</a> →
        <a href={U.bi} style="color:#16463E;text-decoration:none;border-bottom:1.5px solid #C0C8C5;">{de ? "Auswertung in der BI" : en ? "analytics in BI" : "BI 中的分析"}</a> →
        <a href={U.cockpit} style="color:#16463E;text-decoration:none;border-bottom:1.5px solid #C0C8C5;">{de ? "Fertigung im Live-Cockpit" : en ? "production in the live cockpit" : "实时驾驶舱中的生产"}</a>
      </p>
      <p style="font-size:16px; line-height:1.7; color:#1B1C1E; margin:0;">
        <strong>{de ? "Maschine CNC-Fräse A1" : en ? "Machine CNC mill A1" : "机器 CNC 铣床 A1"}:</strong>
        <a href={U.cockpit} style="color:#16463E;text-decoration:none;border-bottom:1.5px solid #C0C8C5;">{de ? "live im Cockpit" : en ? "live in the cockpit" : "驾驶舱中实时查看"}</a> →
        <a href={ANLAGE} style="color:#16463E;text-decoration:none;border-bottom:1.5px solid #C0C8C5;">{de ? "Anlage & Schaltschrank" : en ? "plant & cabinet" : "设备与控制柜"}</a> →
        <a href={U.twin} style="color:#16463E;text-decoration:none;border-bottom:1.5px solid #C0C8C5;">{de ? "Simulation im Digital Twin" : en ? "simulation in the digital twin" : "数字孪生中的仿真"}</a>
      </p>
    </div>

    <!-- Gruppen nach Prozess-Stufe -->
    {STAGES.map(([key, name, sub]) => {
      const cs = cards.filter((c) => c.stage === key);
      return cs.length === 0 ? null : (
        <div style="margin-top:clamp(48px,6vw,72px);">
          <div style="display:flex; align-items:baseline; gap:16px; margin-bottom:clamp(24px,3vw,32px);">
            <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E;">{name}</span>
            <span style="font-size:14px; color:#92938F;">{sub}</span>
            <span style="flex:1; height:1px; background:#E2E8F0;"></span>
          </div>
          <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:clamp(24px,3vw,40px);">
            {cs.map((d) => (
              <a href={d.href} class="demo-card" style="text-decoration:none; color:#1B1C1E; display:flex; flex-direction:column;">
                <span style={ph}>{d.title}</span>
                <span style="display:flex; gap:10px; align-items:center;">
                  <span style="font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#16463E;">● live</span>
                  <span style="font-family:var(--font-mono); font-size:10px; letter-spacing:0.06em; text-transform:uppercase; color:#92938F; border:1px solid #C0C8C5; border-radius:999px; padding:2px 8px;">{ro}</span>
                </span>
                <span style="font-weight:600; font-size:clamp(19px,2vw,23px); letter-spacing:-0.02em; line-height:1.14; margin:12px 0 12px;">{d.title}</span>
                <span style="font-size:15px; line-height:1.5; color:#5C5E63; flex:1;">{d.desc}</span>
                {d.login && <span style="font-size:13px; color:#92938F; margin-top:14px;">Login: {d.login}</span>}
                <span style="font-size:14px; font-weight:600; color:#16463E; margin-top:18px;">{open}</span>
              </a>
            ))}
          </div>
        </div>
      );
    })}

    {soon.length > 0 && (
      <div style="margin-top:clamp(56px,7vw,88px);">
        <p style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#92938F; margin:0 0 clamp(20px,3vw,28px);">{de ? "In Vorbereitung" : en ? "Coming soon" : "筹备中"}</p>
        <div style="border-top:1px solid #1B1C1E;">
          {soon.map((d) => (
            <a href={de ? "/kontakt/" : en ? "/en/kontakt/" : "/cn/kontakt/"} class="soon-row" style="text-decoration:none; color:#1B1C1E; display:grid; grid-template-columns:1fr auto; gap:16px; align-items:baseline; padding:22px 0; border-bottom:1px solid #E2E8F0;">
              <span style="display:flex; flex-direction:column; gap:6px;">
                <span style="font-weight:600; font-size:18px; letter-spacing:-0.015em;">{d.title[lang]}</span>
                <span style="font-size:14px; color:#5C5E63;">{d.desc[lang]}</span>
              </span>
              <span style="font-size:11px; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:#92938F; border:1px solid #C0C8C5; padding:4px 12px; border-radius:999px; justify-self:end;">{de ? "in Vorbereitung" : en ? "coming soon" : "筹备中"} →</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
<style>.demo-card:hover { transform: translateY(-5px); } .soon-row:hover { color: #16463E; }</style>
