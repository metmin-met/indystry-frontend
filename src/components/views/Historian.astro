---
// Historian-Explorer (read-only, lang-aware): Zeitreihen-Browser auf Nordwerk-Warehouse-Daten
// (gebackener Snapshot /data/nordwerk-telemetry.json). Dependency-frei (Inline-SVG).
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
---
<section style="background:#F8F9FA;" data-de={String(de)}>
  <div style="max-width:1100px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{de ? "Historian · Zeitreihen · read-only" : en ? "Historian · time series · read-only" : "历史数据库 · 时间序列 · read-only"}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(34px,6vw,64px); line-height:1.0; letter-spacing:-0.03em; margin:0 0 14px;">{de ? "Jede Maschine, jede Messreihe." : en ? "Every machine, every metric." : "每台机器，每条测量序列。"}</h1>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#5C5E63; max-width:62ch; margin:0 0 6px;">{de ? "Temperatur und Vibration der Nordwerk-Maschinen — dieselben Sensordaten, die auch im BI-Dashboard und in Grafana stecken. Wähl eine Maschine, blätter durch die Messreihen." : en ? "Temperature and vibration of the Nordwerk machines — the same sensor data that feeds the BI dashboard and Grafana. Pick a machine, browse the metrics." : "Nordwerk 机器的温度与振动 — 与 BI 仪表盘和 Grafana 使用的是同一批传感器数据。选择一台机器，浏览各条测量序列。"}</p>
    <p id="meta" style="font-family:var(--font-mono); font-size:12px; color:#92938F; margin:0 0 clamp(28px,4vw,40px);">{de ? "Snapshot wird geladen …" : en ? "Loading snapshot …" : "正在加载快照 …"}</p>

    <div id="controls" style="display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:18px;"></div>

    <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:clamp(16px,2.5vw,26px);">
      <div style="display:flex; align-items:baseline; justify-content:space-between; gap:12px; margin-bottom:10px;">
        <span id="chart-title" style="font-family:var(--font-head); font-weight:600; font-size:18px; color:#1B1C1E;">—</span>
        <span id="chart-stat" style="font-family:var(--font-mono); font-size:12px; color:#92938F;"></span>
      </div>
      <div id="chart" style="width:100%;"></div>
    </div>

    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E; margin:clamp(32px,4vw,48px) 0 14px;">{de ? "Alle Messreihen" : en ? "All metrics" : "全部测量序列"}</p>
    <div id="grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px;"></div>
  </div>
</section>

<style>
  .seg { font-family:var(--font-mono); font-size:12px; padding:7px 13px; border:1px solid #C0C8C5; border-radius:999px; background:#fff; cursor:pointer; color:#3C3E42; }
  .seg[aria-pressed="true"] { background:#123A33; color:#fff; border-color:#123A33; }
  .spark { border:1px solid #E2E8F0; border-radius:10px; background:#fff; padding:12px; cursor:pointer; }
  .spark:hover { border-color:#123A33; }
  .spark.sel { border-color:#123A33; box-shadow:0 0 0 1px #123A33; }
</style>

<!-- DATEN-BACKBONE -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:8px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">{de ? "Das Rückgrat darunter" : en ? "The backbone beneath" : "底层支撑"}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span>
    </div>
    <h2 style="font-family:var(--font-head); font-weight:700; font-size:clamp(26px,4vw,44px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 24px; max-width:22ch;">{de ? "Millionen Messpunkte — und trotzdem schnell." : en ? "Millions of data points — and still fast." : "数百万测量点 — 依然飞快。"}</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(244px,1fr)); gap:12px;">
      <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Zeitreihen-Datenbank" : en ? "Time-series database" : "时间序列数据库"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Jahre an Sensor- und Maschinenwerten, Abfragen in Millisekunden." : en ? "Years of sensor and machine values, queried in milliseconds." : "多年的传感器与机器数值，查询仅需毫秒。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Data-Lake (Object-Store)" : en ? "Data lake (object store)" : "数据湖（对象存储）"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Rohdateien, Bilder, Reports — günstig und praktisch endlos abgelegt." : en ? "Raw files, images, reports — stored cheaply and practically endlessly." : "原始文件、图像、报告 — 存储成本低廉，容量几乎无限。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Automatischer Ingest" : en ? "Automatic ingest" : "自动数据接入"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Neue Messdateien werden selbst eingelesen — kein manuelles Importieren." : en ? "New measurement files are ingested automatically — no manual importing." : "新的测量文件自动读入 — 无需手动导入。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "ETL & fertige Sichten" : en ? "ETL & ready-made views" : "ETL 与开箱即用的视图"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Verteilte Quellen sauber zusammengeführt, aufgelöste Auswertungs-Views." : en ? "Scattered sources merged cleanly, resolved analytics views." : "分散的数据源干净整合，形成解析完成的分析视图。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Direkt aus der Steuerung" : en ? "Straight from the controls" : "直接来自控制系统"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Werte aus SPS und Leittechnik fließen live in die Historie (OPC-UA)." : en ? "Values from PLC and control system flow live into the history (OPC-UA)." : "来自 SPS 与主控系统的数值实时流入历史记录（OPC-UA）。"}</p></div>
    </div>
    <p style="font-size:14px; line-height:1.6; color:#5C5E63; margin-top:24px; max-width:70ch;">{de ? "Aus denselben Daten speisen sich Leitstand, Auswertung und Zwilling." : en ? "The same data feeds the control room, analysis and the twin." : "同一批数据同时供给中控室、分析与数字孪生。"} <a href={(de?"":en?"/en":"/cn")+"/analyse/"} style="color:#16463E; font-weight:600; text-decoration:none;">{de ? "Zur Werkstoff-Analyse" : en ? "To material analysis" : "前往材料分析"} →</a></p>
  </div>
</section>

<script>
  const DE = document.querySelector("[data-de]")?.getAttribute("data-de") === "true";
  const L = DE ? "de-DE" : "en-GB";
  const M_LABEL = DE
    ? { temperatur_c: "Temperatur (°C)", vibration_mm_s: "Vibration (mm/s)" }
    : { temperatur_c: "Temperature (°C)", vibration_mm_s: "Vibration (mm/s)" };
  const M_COLOR = { temperatur_c: "#E6B23A", vibration_mm_s: "#16794a" };
  const $ = (s) => document.querySelector(s);

  function line(pts, w, h, color, pad = 26) {
    if (!pts.length) return "";
    const xs = pts.map(p => p.t), vs = pts.map(p => p.v);
    const x0 = Math.min(...xs), x1 = Math.max(...xs);
    let v0 = Math.min(...vs), v1 = Math.max(...vs);
    if (v0 === v1) { v0 -= 1; v1 += 1; }
    const sx = (t) => pad + (w - pad * 1.3) * (x1 === x0 ? 0.5 : (t - x0) / (x1 - x0));
    const sy = (v) => (h - pad) - (h - pad * 1.6) * (v - v0) / (v1 - v0);
    const d = pts.map((p, i) => (i ? "L" : "M") + sx(p.t).toFixed(1) + " " + sy(p.v).toFixed(1)).join(" ");
    const area = d + ` L${sx(x1).toFixed(1)} ${h - pad} L${sx(x0).toFixed(1)} ${h - pad} Z`;
    const gid = "g" + Math.random().toString(36).slice(2, 7);
    return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none" style="display:block;">
      <defs><linearGradient id="${gid}" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="${color}" stop-opacity="0.18"/><stop offset="1" stop-color="${color}" stop-opacity="0"/></linearGradient></defs>
      <text x="2" y="${sy(v1).toFixed(1)}" font-family="monospace" font-size="10" fill="#92938F">${v1.toFixed(1)}</text>
      <text x="2" y="${(h - pad + 4).toFixed(1)}" font-family="monospace" font-size="10" fill="#92938F">${v0.toFixed(1)}</text>
      <path d="${area}" fill="url(#${gid})"/>
      <path d="${d}" fill="none" stroke="${color}" stroke-width="2" stroke-linejoin="round"/></svg>`;
  }
  function spark(pts, color) {
    if (!pts.length) return `<div style="height:42px;display:flex;align-items:center;color:#C0C8C5;font:12px monospace;">${DE ? "kein Signal" : "no signal"}</div>`;
    const vs = pts.map(p => p.v); let v0 = Math.min(...vs), v1 = Math.max(...vs); if (v0 === v1){v0--;v1++;}
    const w = 200, h = 42;
    const d = pts.map((p, i) => (i ? "L" : "M") + (i / (pts.length - 1) * w).toFixed(1) + " " + ((h - 4) - (h - 8) * (p.v - v0) / (v1 - v0)).toFixed(1)).join(" ");
    return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none"><path d="${d}" fill="none" stroke="${color}" stroke-width="1.6"/></svg>`;
  }

  let DATA, sel = { machine: null, metric: "temperatur_c" };

  function render() {
    const s = DATA.series.find(x => x.machine_id === sel.machine && x.metric === sel.metric)
          || DATA.series.find(x => x.machine_id === sel.machine);
    if (s) sel.metric = s.metric;
    $("#chart-title").textContent = s ? `${s.name} — ${M_LABEL[sel.metric] || sel.metric}` : (DE ? "Keine Messreihe" : "No metric");
    if (s) {
      const vs = s.pts.map(p => p.v);
      const stat = DE ? `min ${Math.min(...vs).toFixed(1)} · ø ${(vs.reduce((a,b)=>a+b,0)/vs.length).toFixed(1)} · max ${Math.max(...vs).toFixed(1)} · ${s.pts.length} Pkt`
                      : `min ${Math.min(...vs).toFixed(1)} · avg ${(vs.reduce((a,b)=>a+b,0)/vs.length).toFixed(1)} · max ${Math.max(...vs).toFixed(1)} · ${s.pts.length} pts`;
      $("#chart-stat").textContent = stat;
      $("#chart").innerHTML = line(s.pts, 900, 280, M_COLOR[sel.metric] || "#123A33");
    } else { $("#chart-stat").textContent = ""; $("#chart").innerHTML = `<p style="color:#92938F;font:14px monospace;padding:40px 0;">${DE ? "Diese Maschine liefert keine Live-Messreihe (z. B. Montage/Prüfung)." : "This machine has no live metric (e.g. assembly/inspection)."}</p>`; }
    document.querySelectorAll(".seg[data-metric]").forEach(b => b.setAttribute("aria-pressed", String(b.dataset.metric === sel.metric)));
    document.querySelectorAll(".seg[data-machine]").forEach(b => b.setAttribute("aria-pressed", String(+b.dataset.machine === sel.machine)));
    document.querySelectorAll(".spark").forEach(c => c.classList.toggle("sel", +c.dataset.m === sel.machine && c.dataset.metric === sel.metric));
  }

  function loadTel(){ return fetch("/_live/telemetry",{cache:"no-store"}).then(r=>{if(!r.ok)throw 0;return r.json();}).then(d=>{if(!d||!d.series)throw 0;return d;}).catch(()=>fetch("/data/nordwerk-telemetry.json").then(r=>r.json())); }
  loadTel().then(d => {
    DATA = d;
    const dt = new Date(d.generated * 1000);
    $("#meta").textContent = `${d.live?"● Live":"Snapshot"} ${dt.toLocaleDateString(L)} ${dt.toLocaleTimeString(L,{hour:"2-digit",minute:"2-digit"})} · ${d.series.length} ${DE ? "Messreihen · echte Warehouse-Daten (read-only)" : "metrics · real warehouse data (read-only)"}`;
    const withData = new Set(d.series.map(s => s.machine_id));
    sel.machine = d.series.length ? d.series[0].machine_id : (d.machines[0] && d.machines[0].id);

    const ctl = $("#controls");
    d.machines.forEach(m => {
      const b = document.createElement("button");
      b.className = "seg"; b.dataset.machine = m.id; b.textContent = m.name + (withData.has(m.id) ? "" : " ·");
      b.title = m.line + " · " + m.kind + (withData.has(m.id) ? "" : (DE ? " (kein Sensor)" : " (no sensor)"));
      b.onclick = () => { sel.machine = m.id; render(); };
      ctl.appendChild(b);
    });
    const sep = document.createElement("span"); sep.style.cssText = "width:1px;height:22px;background:#E2E8F0;margin:0 4px;"; ctl.appendChild(sep);
    ["temperatur_c", "vibration_mm_s"].forEach(mt => {
      const b = document.createElement("button");
      b.className = "seg"; b.dataset.metric = mt; b.textContent = M_LABEL[mt];
      b.onclick = () => { sel.metric = mt; render(); };
      ctl.appendChild(b);
    });

    const grid = $("#grid");
    d.series.forEach(s => {
      const c = document.createElement("div");
      c.className = "spark"; c.dataset.m = s.machine_id; c.dataset.metric = s.metric;
      const last = s.pts.length ? s.pts[s.pts.length - 1].v : null;
      c.innerHTML = `<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
          <span style="font:600 13px var(--font-head,sans-serif);color:#1B1C1E;">${s.name}</span>
          <span style="font:11px monospace;color:${M_COLOR[s.metric]};">${last!=null?last.toFixed(1):"–"}</span></div>
        <div style="font:10px monospace;color:#92938F;margin-bottom:4px;">${M_LABEL[s.metric]||s.metric}</div>
        ${spark(s.pts, M_COLOR[s.metric] || "#123A33")}`;
      c.onclick = () => { sel.machine = s.machine_id; sel.metric = s.metric; render(); window.scrollTo({top:0,behavior:"smooth"}); };
      grid.appendChild(c);
    });
    render();
  }).catch(e => { $("#meta").textContent = DE ? "Snapshot konnte nicht geladen werden." : "Could not load snapshot."; });
</script>
