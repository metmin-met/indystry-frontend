---
// Animiertes Architektur-/Datenfluss-Diagramm: Quellen → Ingest/Puffer → Backbone → Auswertung → Außen,
// Backups darunter. Knoten klickbar zu den jeweiligen Demos. Flow-Animation wie im Stromlaufplan (/anlage/).
import type { Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const b = de ? "" : "/en";
const L = (d: string, e: string) => (de ? d : e);
// Knoten: x,y (viewBox 0 0 1160 560), Label, Pillar-Farbe, optional href
const N = (id: string, x: number, y: number, t: string, c: string, href?: string, ext?: boolean) => ({ id, x, y, t, c, href, ext });
const C = { src: "#7b5cc4", file: "#b03f93", web: "#c2506f", edge: "#2a86a8", kafka: "#4a6fa5", ts: "#3d4fc0", lake: "#5a8a98", erp: "#c4673f", bi: "#c08a2e", twin: "#7b5cc4", ai: "#b03f93", out: "#c2506f", bak: "#16794a" };
const nodes = [
  N("src", 30, 60,  L("Maschinen · SPS/OPC-UA", "Machines · PLC/OPC-UA"), C.src, "/anlage/"),
  N("file", 30, 150, L("Dateien · Excel/ETL", "Files · Excel/ETL"), C.file, "/suche/"),
  N("webin", 30, 240, L("Web · Anfrage/Portal", "Web · inquiry/portal"), C.web, "/portal/"),
  N("edge", 270, 105, L("Gateway / Edge", "Gateway / edge"), C.edge),
  N("kafka", 270, 210, L("Streaming-Puffer · Kafka", "Streaming buffer · Kafka"), C.kafka, "/rechner/"),
  N("ts", 520, 60,  L("Zeitreihen-DB · Timescale", "Time-series DB · Timescale"), C.ts, "/historian/"),
  N("lake", 520, 150, L("Object-Store · Data-Lake", "Object store · data lake"), C.lake, "/analyse/"),
  N("erp", 520, 240, L("ERP · PostgreSQL", "ERP · PostgreSQL"), C.erp, "https://erp-demo.indystry.works", true),
  N("bi", 780, 45,  L("BI & Analytics", "BI & analytics"), C.bi, "https://bi-demo.indystry.works", true),
  N("twin", 780, 130, L("Digital Twin", "Digital twin"), C.twin, "https://twin-demo.indystry.works", true),
  N("ai", 780, 215, L("KI & Suche", "AI & search"), C.ai, "/suche/"),
  N("out", 1010, 130, L("Web · Portal · App", "Web · portal · app"), C.out, "/portal/"),
  N("bak", 520, 360, L("Backups & Offsite (PBS)", "Backups & offsite (PBS)"), C.bak, "/status/"),
];
const NM = Object.fromEntries(nodes.map((n) => [n.id, n]));
const edges = [["src","edge"],["file","edge"],["webin","edge"],["edge","kafka"],["edge","ts"],["kafka","ts"],["kafka","lake"],["edge","erp"],["ts","bi"],["ts","twin"],["lake","ai"],["erp","bi"],["erp","ai"],["bi","out"],["twin","out"],["ai","out"]];
const W = 150, H = 46;
const cx = (n: any) => n.x + W / 2, cy = (n: any) => n.y + H / 2;
---
<div class="sf-wrap">
  <svg viewBox="0 0 1160 430" class="sf-svg" role="img" aria-label={L("Architektur: Datenfluss durch den Stack", "Architecture: data flow through the stack")}>
    <g class="sf-edges">
      {edges.map(([a, c]) => {
        const A = NM[a], B = NM[c];
        return <path class="sf-edge" d={`M ${A.x + W} ${cy(A)} C ${A.x + W + 40} ${cy(A)}, ${B.x - 40} ${cy(B)}, ${B.x} ${cy(B)}`} />;
      })}
      {/* Backup-Pfeile (nach oben in die Backbone) */}
      {["ts","lake","erp"].map((k) => { const A = NM[k], Bk = NM["bak"]; return <path class="sf-edge sf-bak" d={`M ${cx(Bk)} ${Bk.y} C ${cx(Bk)} ${Bk.y - 30}, ${cx(A)} ${A.y + H + 30}, ${cx(A)} ${A.y + H}`} />; })}
    </g>
    <g class="sf-nodes">
      {nodes.map((n) => (
        <a href={n.href ? (n.ext ? n.href : b + n.href) : undefined} target={n.ext ? "_blank" : undefined} rel={n.ext ? "noopener" : undefined} class={`sf-node ${n.href ? "lk" : ""}`}>
          <rect x={n.x} y={n.y} width={W} height={H} rx="10" style={`--cc:${n.c}`} />
          <text x={n.x + 13} y={n.y + 27}>{n.t}{n.href ? (n.ext ? "  ↗" : "  →") : ""}</text>
        </a>
      ))}
    </g>
    <g class="sf-cols" font-family="var(--font-mono,monospace)">
      <text x="105" y="335">{L("Quellen", "Sources")}</text>
      <text x="345" y="335">{L("Ingest & Puffer", "Ingest & buffer")}</text>
      <text x="595" y="335">{L("Backbone", "Backbone")}</text>
      <text x="855" y="20">{L("Auswertung", "Analysis")}</text>
      <text x="1085" y="335">{L("Außen", "Edge-out")}</text>
    </g>
  </svg>
  <p class="sf-cap">{L("Daten fließen von links (Maschinen, Dateien, Web) über Gateway & Streaming-Puffer in das Rückgrat — Zeitreihen-DB, Data-Lake, ERP — und von dort in BI, Twin & KI bis zum Außenauftritt. Alles unten abgesichert durch Backups & Offsite.", "Data flows from the left (machines, files, web) via gateway & streaming buffer into the backbone — time-series DB, data lake, ERP — and on into BI, twin & AI up to the public face. All secured underneath by backups & offsite.")}</p>
</div>

<style>
  .sf-wrap { border: 1px solid #E2E8F0; border-radius: 16px; background: #fff; padding: clamp(16px,2.5vw,28px); }
  .sf-svg { width: 100%; height: auto; display: block; }
  .sf-edge { fill: none; stroke: #C0C8C5; stroke-width: 1.8; stroke-dasharray: 7 6; animation: sf-flow 1.1s linear infinite; }
  .sf-bak { stroke: #9ccdb9; stroke-width: 1.4; opacity: .7; animation-duration: 1.6s; }
  @keyframes sf-flow { to { stroke-dashoffset: -26; } }
  .sf-node rect { fill: color-mix(in srgb, var(--cc) 10%, #fff); stroke: var(--cc); stroke-width: 1.6; transition: fill .15s; }
  .sf-node text { font-family: var(--font-mono,monospace); font-size: 12.5px; font-weight: 600; fill: #15433b; }
  .sf-node.lk { cursor: pointer; }
  .sf-node.lk:hover rect { fill: color-mix(in srgb, var(--cc) 22%, #fff); }
  .sf-cols text { fill: #92938F; font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }
  .sf-cap { font-size: 13.5px; line-height: 1.6; color: #5C5E63; margin: 16px 0 0; max-width: 80ch; }
  @media (prefers-reduced-motion: reduce) { .sf-edge { animation: none; } }
</style>
