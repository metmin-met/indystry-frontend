---
// /landkarte/ — die große klickbare Werks-Landkarte: alle Phasen, alle Tools, alle Live-Demos,
// gefiltert nach Akt/Bereich/Live. Reuse PhaseMatrix (variant=full) + Tool-Legende.
import type { Lang } from "../../lib/content";
import { TOOLS, CATS } from "../../data/phases";
import PhaseMatrix from "./PhaseMatrix.astro";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const b = de ? "" : "/en";
const L = (d: string, e: string) => (de ? d : e);
const hrefOf = (t: any) => (t.ext ? t.href : b + t.href);
const toolList = Object.values(TOOLS);
---
<section style="background:#123A33; color:#F4F6F5;">
  <div style="max-width:1180px; margin:0 auto; padding:clamp(52px,8vw,104px) clamp(24px,5vw,56px) clamp(40px,6vw,64px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px;">{L("Werks-Landkarte", "Factory map")}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(34px,6.5vw,68px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:17ch;">{L("Die ganze Firma — als klickbare Landkarte.", "The whole company — as a clickable map.")}</h1>
    <p style="font-size:clamp(17px,1.7vw,21px); line-height:1.6; color:#CADAD5; max-width:64ch; margin:0;">{L("Jede Phase vom Erstkontakt bis zur Wartung, jedes Tool, jede Live-Demo — alles anklickbar. Filtere nach Akt, Bereich oder nur Live-Demos und spring direkt rein.", "Every phase from first contact to maintenance, every tool, every live demo — all clickable. Filter by act, area or live demos only and jump straight in.")}</p>
  </div>
</section>

<section style="background:#F8F9FA;">
  <div style="max-width:1180px; margin:0 auto; padding:clamp(32px,4vw,56px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <PhaseMatrix lang={lang} variant="full" />

    <div class="lk-legend">
      <p class="lk-legend-h">{L("Alle Tools im Überblick", "All tools at a glance")}</p>
      <div class="lk-tools">
        {toolList.map((t) => (
          <a class="lk-tool" style={`--cc:${t.color}`} href={hrefOf(t)} target={t.ext ? "_blank" : undefined} rel={t.ext ? "noopener" : undefined}>
            <span class="lk-tdot"></span><span class="lk-tname">{t.name[lang]}</span>
            <span class="lk-tcat">{CATS[t.cat][lang]}</span>
            <span class="lk-tarr">{t.ext ? "↗" : "→"}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .lk-legend { margin-top: clamp(40px,5vw,64px); border-top: 1px solid #E2E8F0; padding-top: 28px; }
  .lk-legend-h { font-family: var(--font-mono); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #16463E; margin: 0 0 16px; }
  .lk-tools { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; }
  .lk-tool { display: flex; align-items: center; gap: 10px; text-decoration: none; border: 1px solid #E2E8F0; border-left: 3px solid var(--cc); border-radius: 10px; background: #fff; padding: 11px 14px; transition: box-shadow .14s, transform .14s, border-color .14s; }
  .lk-tool:hover { box-shadow: 0 8px 20px rgba(11,28,25,.08); transform: translateY(-2px); }
  .lk-tdot { width: 9px; height: 9px; border-radius: 50%; background: var(--cc); flex: none; }
  .lk-tname { font-weight: 600; font-size: 14px; color: #1B1C1E; }
  .lk-tcat { font-family: var(--font-mono); font-size: 10.5px; color: #92938F; margin-left: auto; }
  .lk-tarr { color: var(--cc); font-weight: 600; }
</style>
