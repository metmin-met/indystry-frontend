---
// /tour/ — geführte Tour „Roter Faden" (lang-aware): eine Bestellung (NW-1001) Schritt für Schritt,
// je Schritt ein interaktives Visual (flow/bars/table/dots) + Live-Link. Tastatur ← →, Fortschritt.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const L = (d: string, e: string) => (de ? d : e);
const b = de ? "" : "/en";
const ERP="https://erp-demo.indystry.works/odoo", BI="https://bi-demo.indystry.works";
const steps = [
  { ph:L("Anbahnung","Lead-in"), t:L("Die Anfrage","The inquiry"),
    x:L("Helvetia Pumpen fragt 200 Lagerböcke NW-1001 an. Die Anfrage landet als Lead im CRM — nichts geht verloren.","Helvetia Pumpen asks for 200 bearing blocks NW-1001. It lands as a lead in the CRM — nothing gets lost."),
    l:"ERP / CRM", h:ERP, ext:true, vt:"flow", vd:{stages:[L("Neu","New"),L("Qualifiziert","Qualified"),L("Angebot","Quote"),L("Gewonnen","Won")], active:0} },
  { ph:L("Anbahnung","Lead-in"), t:L("Das Angebot","The quote"),
    x:L("Am Digital Twin werden Durchsatz, Ausbeute und Ausschuss durchgespielt — so steht ein belastbares Angebot mit echtem Termin.","On the digital twin throughput, yield and scrap are simulated — for a solid quote with a real date."),
    l:L("Digital Twin","Digital twin"), h:`${b}/twin/`, vt:"bars", vd:{items:[{l:L("Durchsatz","Throughput"),v:103,max:140,u:"/h",c:"#16794a"},{l:L("Ausbeute","Yield"),v:96,max:100,u:"%",c:"#16794a"},{l:L("Ausschuss","Scrap"),v:4,max:20,u:"%",c:"#E6B23A"}]} },
  { ph:L("Bestelleingang","Order intake"), t:L("Der Auftrag","The order"),
    x:L("Der Kunde bestätigt. Mit einem Klick entstehen Fertigung und Lieferung — keine Doppelerfassung.","The customer confirms. One click creates production and delivery — no double entry."),
    l:"ERP", h:ERP, ext:true, vt:"flow", vd:{stages:[L("Angebot","Quote"),L("Auftrag","Order"),L("Fertigung","Production"),L("Geliefert","Delivered"),L("Rechnung","Invoice")], active:1} },
  { ph:L("Auftrag → Lieferung","Order → delivery"), t:L("Beschaffung","Procurement"),
    x:L("Das MRP rechnet den Materialbedarf aus der Stückliste — Bestellung mit zwei Klicks.","MRP computes material demand from the BOM — order in two clicks."),
    l:"ERP", h:ERP, ext:true, vt:"table", vd:{head:[L("Material","Material"),L("Menge/Stk","Qty/pc")], rows:[["Stahl-Block S235","2×"],["Normschraube M8","1×"]]} },
  { ph:L("Auftrag → Lieferung","Order → delivery"), t:L("Fertigung","Production"),
    x:L("Die CNC-Fräse A1 läuft. Im Leitstand siehst du live jede Maschine — auch dass B1 Wartung braucht.","CNC mill A1 runs. The control room shows every machine live — including B1 needing maintenance."),
    l:L("Leitstand","Control room"), h:`${b}/leitstand/`, vt:"dots", vd:{items:[["A1","ok"],["A2","ok"],["B1","warn"],["M1","ok"],["M2","idle"],["P1","ok"],["L1","ok"],["K1","ok"]]} },
  { ph:L("Auftrag → Lieferung","Order → delivery"), t:L("In die Anlage","Into the plant"),
    x:L("Von der Maschine in den Schaltschrank — bis auf den animierten Stromlaufplan. Schalter und Leitungen in Aktion.","From the machine into the cabinet — down to the animated wiring plan."),
    l:L("Anlage","Plant"), h:`${b}/anlage/`, vt:"flow", vd:{stages:[L("Maschine","Machine"),L("Schaltschrank","Cabinet"),L("Stromlaufplan","Wiring plan")], active:2} },
  { ph:L("Auftrag → Lieferung","Order → delivery"), t:L("Der Zwilling","The twin"),
    x:L("Echtbetrieb beobachten, übersteuern, Optimizer fragen — und die Ausfall-Prognose lesen.","Watch live operation, override, ask the optimizer — and read the failure prediction."),
    l:L("Digital Twin","Digital twin"), h:`${b}/twin/`, vt:"bars", vd:{items:[{l:L("Temperatur","Temperature"),v:41,max:80,u:"°C",c:"#E6B23A"},{l:"Vibration",v:3.1,max:9,u:"mm/s",c:"#16794a"},{l:L("Restlebensd.","Rem. life"),v:48,max:120,u:L("Tage","days"),c:"#16794a"}]} },
  { ph:L("Auftrag → Lieferung","Order → delivery"), t:L("Qualität","Quality"),
    x:L("Die Charge wird geprüft und das Gefüge analysiert — automatisch gegen Grenzwerte bewertet.","The batch is inspected and the grain analysed — auto-graded against limits."),
    l:L("Analyse","Analysis"), h:`${b}/analyse/`, vt:"table", vd:{head:[L("Merkmal","Feature"),L("Wert","Value"),"Status"], rows:[[L("Maßhaltigkeit","Dimension"),"50.04 mm","✓"],["Rauheit Ra","1.6 µm","✓"],[L("Gewicht","Weight"),"421 g","✓"]]} },
  { ph:L("Auftrag → Lieferung","Order → delivery"), t:L("Versand","Shipping"),
    x:L("Fertig und geprüft: mit Echtzeit-Bestand kommissioniert, Lieferschein gedruckt.","Done and inspected: picked with real-time stock, delivery note printed."),
    l:"ERP", h:ERP, ext:true, vt:"table", vd:{head:[L("Position","Item"),L("Menge","Qty")], rows:[["NW-1001 · "+L("Lagerbock Typ A","Bearing block A"),"200 Stk"]], foot:[L("Lieferschein","Delivery note"),"LS-0042"]} },
  { ph:L("Nach der Lieferung","After delivery"), t:L("Die Rechnung","The invoice"),
    x:L("Aus der Lieferung wird per Klick die E-Rechnung — direkt an den Kunden, ohne Medienbruch.","The delivery becomes an e-invoice in one click — straight to the customer."),
    l:"ERP", h:ERP, ext:true, vt:"table", vd:{head:[L("Position","Item"),L("Betrag","Amount")], rows:[["200× NW-1001","7.600,00 €"]], foot:[L("Summe (E-Rechnung)","Total (e-invoice)"),"7.600,00 €"]} },
  { ph:L("Nach der Lieferung","After delivery"), t:L("Der Kunde","The customer"),
    x:L("Im Self-Service-Portal sieht der Kunde Status, Rechnung und Servicevertrag — ohne Rückfrage.","In the self-service portal the customer sees status, invoice and service contract — without asking."),
    l:L("Kundenportal","Customer portal"), h:`${b}/portal/`, vt:"table", vd:{head:[L("Im Portal","In portal"),"Status"], rows:[[L("Auftrag","Order"),L("geliefert","delivered")],[L("Rechnung","Invoice"),L("offen","open")],[L("Servicevertrag","Service contract"),L("aktiv","active")]]} },
  { ph:L("Steuern","Steering"), t:L("Die Auswertung","The analytics"),
    x:L("Im Cockpit: Auftrag → Liefertreue → Marge. Eine Wahrheit, die alle teilen.","In the cockpit: order → on-time → margin. One truth everyone shares."),
    l:"BI", h:BI, ext:true, vt:"bars", vd:{items:[{l:"OEE",v:78,max:100,u:"%",c:"#16794a"},{l:L("Liefertreue","On-time"),v:96,max:100,u:"%",c:"#16794a"},{l:L("Ausschuss","Scrap"),v:4,max:20,u:"%",c:"#E6B23A"}]} },
];
const STC: Record<string,string> = { ok:"#16794a", warn:"#E6B23A", idle:"#92938F" };
function viz(s: any): string {
  const v = s.vd;
  if (s.vt === "flow") return `<div class="vz-flow">${v.stages.map((st:string,k:number)=>`<span class="vz-pill ${k===v.active?'on':(k<v.active?'past':'')}">${st}</span>${k<v.stages.length-1?'<span class="vz-arr">→</span>':''}`).join("")}</div>`;
  if (s.vt === "bars") return `<div class="vz-bars">${v.items.map((it:any)=>`<div class="vz-bar"><div class="vz-bl"><span>${it.l}</span><b>${it.v}${it.u}</b></div><div class="vz-track"><div class="vz-fillb" data-w="${Math.round(it.v/it.max*100)}" style="background:${it.c};width:0%"></div></div></div>`).join("")}</div>`;
  if (s.vt === "dots") return `<div class="vz-dots">${v.items.map((it:any)=>`<div class="vz-dot"><span style="background:${STC[it[1]]}"></span>${it[0]}</div>`).join("")}</div>`;
  if (s.vt === "table") return `<table class="vz-tbl"><thead><tr>${v.head.map((h:string)=>`<th>${h}</th>`).join("")}</tr></thead><tbody>${v.rows.map((r:string[])=>`<tr>${r.map((c)=>`<td>${c}</td>`).join("")}</tr>`).join("")}${v.foot?`<tr class="vz-foot">${v.foot.map((c:string)=>`<td>${c}</td>`).join("")}</tr>`:""}</tbody></table>`;
  return "";
}
---
<section class="tj-hero">
  <div class="tj-hero-in">
    <p class="tj-eyebrow">{L("Der rote Faden","The thread")}</p>
    <h1 class="tj-h1">{L("Eine Bestellung, der ganze Weg.","One order, the whole way.")}</h1>
    <p class="tj-lead">{L("Folge dem Lagerbock NW-1001 durch die ganze Firma — jeder Schritt mit Diagramm und Live-Link.","Follow bearing block NW-1001 through the whole company — every step with a diagram and a live link.")}</p>
    <div class="tj-meta">
      <span class="tj-pill"><span class="tj-pill-dot"></span>NW-1001</span>
      <span class="tj-scroll">{L("scrollen, der Faden folgt","scroll, the thread follows")} ↓</span>
    </div>
  </div>
</section>

<div class="tj-progress"><div class="tj-progress-fill" id="tj-progress"></div></div>

<section class="tj-body">
  <div class="tj-journey" id="tj-journey">
    <span class="tj-track" id="tj-track"></span>
    <span class="tj-fill" id="tj-fill"></span>
    {steps.map((s, i) => (
      <div class="tj-step" data-step={i}>
        <div class="tj-rail">
          <span class="tj-node" data-node={i}>{i + 1}</span>
        </div>
        <article class="tj-card">
          <div class="tj-text">
            <span class="tj-ph">{s.ph}</span>
            <p class="tj-step-n">{L("Schritt","Step")} {i + 1} / {steps.length}</p>
            <h2 class="tj-t">{s.t}</h2>
            <p class="tj-x">{s.x}</p>
            <a class="tj-live" href={s.h} target={s.ext ? "_blank" : undefined} rel={s.ext ? "noopener" : undefined}>{L("Jetzt live ansehen","See it live now")} · {s.l} {s.ext ? "↗" : "→"}</a>
          </div>
          <div class="tj-viz" set:html={viz(s)} />
        </article>
      </div>
    ))}
  </div>
</section>

<style is:global>
  .tj-hero { background:#123A33; color:#F4F6F5; }
  .tj-hero-in { max-width:62rem; margin:0 auto; padding:clamp(48px,7vw,92px) clamp(1.25rem,5vw,3.5rem) clamp(28px,4vw,44px); }
  .tj-eyebrow { font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 16px; }
  .tj-h1 { font-family:var(--font-head); font-weight:700; font-size:clamp(32px,6vw,64px); line-height:.99; letter-spacing:-.03em; margin:0 0 16px; max-width:18ch; color:#F4F6F5; }
  .tj-lead { font-size:clamp(16px,1.6vw,20px); line-height:1.6; color:#CADAD5; max-width:60ch; margin:0 0 22px; }
  .tj-meta { display:flex; flex-wrap:wrap; align-items:center; gap:1rem; }
  .tj-pill { display:inline-flex; align-items:center; gap:.45rem; font-family:var(--font-mono); font-size:.78rem; font-weight:600; letter-spacing:.04em; color:#E6B23A; border:1px solid #E6B23A55; border-radius:9999px; padding:.28rem .7rem; }
  .tj-pill-dot { width:.45rem; height:.45rem; border-radius:50%; background:#E6B23A; }
  .tj-scroll { font-family:var(--font-mono); font-size:.75rem; color:#8FB0A8; }

  .tj-progress { position:sticky; top:0; z-index:40; height:4px; background:#E2E8F0; }
  .tj-progress-fill { height:100%; width:0; background:#E6B23A; transition:width .1s linear; }

  .tj-body { background:#F8F9FA; }
  .tj-journey { position:relative; max-width:62rem; margin:0 auto; padding:clamp(2.5rem,5vw,4rem) clamp(1.25rem,5vw,3.5rem) clamp(4rem,8vw,6rem); }
  .tj-track, .tj-fill { position:absolute; left:calc(clamp(1.25rem,5vw,3.5rem) + 1.75rem); width:2px; transform:translateX(-50%); border-radius:2px; }
  .tj-track { background:#E2E8F0; }
  .tj-fill { background:#E6B23A; height:0; }
  .tj-step { display:grid; grid-template-columns:3.5rem minmax(0,1fr); align-items:start; }
  .tj-rail { position:relative; align-self:stretch; }
  .tj-node { position:absolute; left:1.75rem; top:2.2rem; transform:translate(-50%,-50%); width:1.9rem; height:1.9rem; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:var(--font-mono); font-weight:700; font-size:.8rem; background:#fff; border:1px solid #C0C8C5; color:#92938F; box-shadow:0 0 0 4px #F8F9FA; z-index:2; transition:background .3s,border-color .3s,color .3s; }
  .tj-node.active { background:#E6B23A; border-color:#E6B23A; color:#1B1C1E; }
  .tj-card { max-width:none; min-width:0; margin-bottom:clamp(1.5rem,3vw,2.5rem); background:#fff; border:1px solid #E2E8F0; border-radius:18px; box-shadow:0 10px 30px rgba(11,28,25,.06); padding:clamp(20px,3vw,34px); display:grid; grid-template-columns:1fr; gap:22px; }
  @media (min-width:780px){ .tj-card { grid-template-columns:1.05fr .95fr; align-items:center; } }
  .tj-ph { display:inline-block; font-family:var(--font-mono); font-size:11px; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:#16463E; background:#EFEAE0; border-radius:9999px; padding:4px 11px; margin:0 0 12px; }
  .tj-step-n { font-family:var(--font-mono); font-size:12px; color:#92938F; margin:0 0 6px; }
  .tj-t { font-family:var(--font-head); font-weight:600; font-size:clamp(22px,3vw,34px); letter-spacing:-.02em; color:#1B1C1E; margin:0 0 12px; line-height:1.1; }
  .tj-x { font-size:clamp(15px,1.6vw,18px); line-height:1.6; color:#3C3E42; margin:0 0 20px; }
  .tj-live { display:inline-flex; align-items:center; gap:8px; text-decoration:none; background:#123A33; color:#fff; font-weight:600; font-size:15px; padding:11px 18px; border-radius:11px; transition:background .15s; }
  .tj-live:hover { background:#0E2E29; }
  .tj-viz { background:#F8F9FA; border:1px solid #E2E8F0; border-radius:14px; padding:18px; }

  /* Diagramme (exakt wie bisher) */
  .vz-flow { display:flex; flex-wrap:wrap; align-items:center; gap:8px; }
  .vz-pill { font-family:var(--font-mono); font-size:12px; padding:7px 12px; border-radius:999px; border:1px solid #C0C8C5; background:#fff; color:#5C5E63; }
  .vz-pill.on { background:#E6B23A; border-color:#E6B23A; color:#1B1C1E; font-weight:700; }
  .vz-pill.past { background:#e7f4ec; border-color:#16794a55; color:#16794a; }
  .vz-arr { color:#C0C8C5; }
  .vz-bars { display:flex; flex-direction:column; gap:14px; }
  .vz-bl { display:flex; justify-content:space-between; font-size:13px; color:#5C5E63; margin-bottom:5px; }
  .vz-bl b { font-family:var(--font-mono); color:#1B1C1E; }
  .vz-track { height:9px; background:#E2E8F0; border-radius:999px; overflow:hidden; }
  .vz-fillb { height:100%; border-radius:999px; transition:width .8s cubic-bezier(.4,0,.2,1); }
  .vz-dots { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
  .vz-dot { display:flex; align-items:center; gap:7px; font-family:var(--font-mono); font-size:12px; color:#3C3E42; }
  .vz-dot span { width:11px; height:11px; border-radius:50%; }
  .vz-tbl { width:100%; border-collapse:collapse; font-size:13.5px; }
  .vz-tbl th { text-align:left; font-family:var(--font-mono); font-size:10px; letter-spacing:.06em; text-transform:uppercase; color:#92938F; padding:6px 8px; border-bottom:1px solid #E2E8F0; }
  .vz-tbl td { padding:9px 8px; border-bottom:1px solid #F1F3F2; color:#1B1C1E; }
  .vz-tbl .vz-foot td { font-weight:700; color:#123A33; border-top:1px solid #123A33; border-bottom:none; }

  html.js .tj-step { opacity:0; transform:translateY(16px); transition:opacity .6s var(--ease-quint,ease), transform .6s var(--ease-quint,ease); }
  html.js .tj-step.in { opacity:1; transform:none; }
  @media (prefers-reduced-motion: reduce) {
    html.js .tj-step { opacity:1; transform:none; transition:none; }
    .tj-node, .tj-live, .vz-fillb, .tj-progress-fill { transition:none; }
  }
</style>

<script>
  const journey = document.getElementById("tj-journey");
  if (journey) {
    const steps = Array.from(journey.querySelectorAll(".tj-step"));
    const nodes = Array.from(journey.querySelectorAll(".tj-node"));
    const track = document.getElementById("tj-track");
    const fill = document.getElementById("tj-fill");
    const prog = document.getElementById("tj-progress");
    const nodeCenter = (n) => { const r = n.getBoundingClientRect(); return r.top + r.height / 2 + window.scrollY; };

    let ticking = false;
    function scene() {
      ticking = false;
      if (!nodes.length) return;
      const jTop = journey.getBoundingClientRect().top + window.scrollY;
      const top = nodeCenter(nodes[0]) - jTop;
      const bottom = nodeCenter(nodes[nodes.length - 1]) - jTop;
      const span = Math.max(1, bottom - top);
      track.style.top = top + "px"; track.style.height = span + "px";
      fill.style.top = top + "px";
      const mid = window.scrollY + window.innerHeight / 2;
      const frac = Math.max(0, Math.min(1, (mid - (top + jTop)) / span));
      fill.style.height = (frac * span) + "px";
      prog.style.width = (frac * 100) + "%";
      nodes.forEach((n) => n.classList.toggle("active", nodeCenter(n) <= mid + 2));
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(scene); } }

    // Reveal + Balken-Animation beim Eintreten
    const io = new IntersectionObserver((ents) => {
      ents.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          e.target.querySelectorAll(".vz-fillb").forEach((el) => { el.style.width = el.dataset.w + "%"; });
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: "0px 0px -18% 0px" });
    steps.forEach((st) => io.observe(st));

    addEventListener("scroll", onScroll, { passive: true });
    addEventListener("resize", onScroll);
    addEventListener("load", scene);
    scene();
  }
</script>
