<style>
  .kn-mqrow { overflow:hidden; -webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent); mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent); }
  .kn-mq { display:flex; gap:9px; width:max-content; animation:kn-mqA 46s linear infinite; }
  .kn-mqb { animation:kn-mqB 54s linear infinite; }
  .kn-mqrow:hover .kn-mq { animation-play-state:paused; }
  .kn-mqpill { display:inline-flex; align-items:center; gap:8px; flex:none; border:1px solid rgba(166,207,197,.2); border-radius:999px; padding:6px 14px; font-family:var(--font-mono); font-size:11.5px; color:#C7D8D2; }
  .kn-mqmono { width:22px; height:22px; border-radius:6px; border:1px solid; font-weight:700; font-size:10px; display:inline-flex; align-items:center; justify-content:center; flex:none; }
  @keyframes kn-mqA { from{ transform:translateX(0); } to{ transform:translateX(-50%); } }
  @keyframes kn-mqB { from{ transform:translateX(-50%); } to{ transform:translateX(0); } }

  .kn-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }

  .kn-filterbar { position:sticky; top:0; z-index:50; background:rgba(248,249,250,.94); backdrop-filter:saturate(160%) blur(10px); -webkit-backdrop-filter:saturate(160%) blur(10px); border-top:1px solid #E2E8F0; border-bottom:1px solid #DCE0E5; }
  .kn-filt { cursor:pointer; transition:all .18s; font-family:var(--font-mono); font-size:12px; font-weight:600; border-radius:8px; padding:8px 13px; display:inline-flex; align-items:center; gap:8px; white-space:nowrap; background:#fff; color:#3C3E42; border:1px solid #C0C8C5; }
  .kn-fdot { width:7px; height:7px; border-radius:50%; display:inline-block; }

  .kn-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(16.5rem,1fr)); gap:14px; grid-auto-flow:row dense; }
  .kn-feat { grid-column:span 1; }
  @media (min-width:780px){ .kn-feat{ grid-column:span 2; } }
  .kn-card { position:relative; overflow:hidden; display:flex; flex-direction:column; gap:6px; background:#fff; border-radius:13px; padding:18px 20px; text-decoration:none; color:#1B1C1E; transition:transform .28s cubic-bezier(.22,1,.36,1), box-shadow .28s, border-color .28s; }
  a.kn-card:hover { transform:translateY(-4px); box-shadow:0 16px 36px rgba(11,28,25,.12); }
  .kn-arrow { display:inline-block; transition:transform .25s; }
  a.kn-card:hover .kn-arrow { transform:translate(3px,-3px); }

  .kn-led { animation:kn-led 1.8s ease-in-out infinite; }
  @keyframes kn-led { 0%,100%{ opacity:1; transform:scale(1); } 50%{ opacity:.35; transform:scale(.6); } }
  @media (prefers-reduced-motion: reduce){ .kn-mq, .kn-led{ animation:none !important; } }
</style>

<script is:inline>
  (function(){
    var bar = document.querySelector(".kn-filterbar"); if(!bar) return;
    var grid = document.getElementById("kn-grid");
    var cards = Array.prototype.slice.call(grid.querySelectorAll(".kn-card"));
    var ghead = JSON.parse(bar.getAttribute("data-ghead") || "{}");
    var state = { group: "all", inUse: false };
    var fOff = { bg:"#fff", col:"#3C3E42", bd:"#C0C8C5" };

    function paintFilters(){
      bar.querySelectorAll(".kn-filt[data-group]").forEach(function(btn){
        var k = btn.getAttribute("data-group"), c = btn.getAttribute("data-color"), on = state.group===k;
        btn.setAttribute("aria-pressed", on?"true":"false");
        btn.style.background = on?c:fOff.bg; btn.style.color = on?"#fff":fOff.col; btn.style.borderColor = on?c:fOff.bd;
        var dot = btn.querySelector(".kn-fdot"); if(dot) dot.style.background = on?"#fff":c;
      });
      var iu = bar.querySelector(".kn-inuse");
      iu.setAttribute("aria-pressed", state.inUse?"true":"false");
      iu.style.background = state.inUse?"#E7F3EC":fOff.bg; iu.style.color = state.inUse?"#16794a":fOff.col; iu.style.borderColor = state.inUse?"#16794a":fOff.bd;
    }
    function apply(){
      var n = 0;
      cards.forEach(function(card){
        var g = card.getAttribute("data-group"), u = card.getAttribute("data-inuse")==="1";
        var vis = (state.group==="all"||g===state.group) && (!state.inUse||u);
        card.style.display = vis?"":"none"; if(vis) n++;
      });
      document.getElementById("kn-vis").textContent = n;
      document.getElementById("kn-empty").style.display = n?"none":"block";
      var gh = document.getElementById("kn-ghead");
      if(state.group!=="all" && ghead[state.group]){
        gh.style.display="flex";
        document.getElementById("kn-ghead-name").textContent = ghead[state.group].name;
        document.getElementById("kn-ghead-dot").style.background = ghead[state.group].color;
      } else gh.style.display="none";
      paintFilters();
    }
    bar.querySelectorAll(".kn-filt[data-group]").forEach(function(btn){
      btn.addEventListener("click", function(){ state.group = btn.getAttribute("data-group"); apply(); });
    });
    bar.querySelector(".kn-inuse").addEventListener("click", function(){ state.inUse = !state.inUse; apply(); });
    apply();

    // Zähler
    var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ var el=e.target, to=+el.getAttribute("data-to")||0, t0=performance.now();
      (function step(t){ var p=Math.min((t-t0)/1100,1); el.textContent=Math.round(to*(1-Math.pow(1-p,3))); if(p<1) requestAnimationFrame(step); })(t0);
      io.unobserve(el); } }); }, { threshold:0.5 });
    document.querySelectorAll(".kn-count").forEach(function(el){ io.observe(el); });
  })();
</script>
