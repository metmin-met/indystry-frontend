---
// Glossar (lang-aware): die Begriffe der Demo-Firma, jeder mit Link zum Thema/zur Demo, wo er
// vorkommt. Macht den Stack + Prozess nachschlagbar.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const L = (d: string, e: string) => (de ? d : e);
const P = (path: string) => (de ? "" : "/en") + path;
import { tagHref, tagForLabel } from "../../lib/tags";
const ERP = "https://erp-demo.indystry.works/odoo";
const TWIN = "https://twin-demo.indystry.works";
const BI = "https://bi-demo.indystry.works";
type T = { k: string; d: string; href: string; ext?: boolean };
const groups: { name: string; terms: T[] }[] = [
  { name: L("Fertigung & Anlage", "Production & plant"), terms: [
    { k: L("Leitstand / SCADA", "Control room / SCADA"), d: L("Live-Sicht aller Maschinen mit Zustand und Messwerten.", "Live view of all machines with state and readings."), href: P("/leitstand/") },
    { k: L("Anlagen-Twin", "Plant twin"), d: L("Klickbarer 3D-Drilldown Werk → Maschine → Schaltschrank → Plan.", "Clickable 3D drilldown plant → machine → cabinet → plan."), href: P("/anlage/") },
    { k: L("Schaltschrank", "Control cabinet"), d: L("Gehäuse mit SPS, Antrieben, Klemmen und Sicherungen.", "Enclosure with PLC, drives, terminals and fuses."), href: P("/anlage/") },
    { k: "SPS / CPU", d: L("Speicherprogrammierbare Steuerung — verarbeitet Eingänge zu Ausgängen.", "Programmable logic controller — turns inputs into outputs."), href: P("/anlage/") },
    { k: L("Frequenzumrichter (FU)", "Variable-frequency drive (VFD)"), d: L("Stellt die Drehzahl der Servo- und Spindelmotoren.", "Sets the speed of servo and spindle motors."), href: P("/anlage/") },
    { k: L("Stromlaufplan", "Wiring plan"), d: L("Schaltplan einer Komponente — bis hierhin geht der Drilldown.", "Schematic of a component — the drilldown goes this far."), href: P("/anlage/") },
    { k: L("Digital Twin", "Digital twin"), d: L("Simulation der Linie: Durchsatz, Ausschuss, Kosten als What-if.", "Line simulation: throughput, scrap, cost as what-if."), href: TWIN, ext: true },
    { k: L("Vorausschauende Wartung", "Predictive maintenance"), d: L("Aus Vibration/Temperatur die Wartung ableiten, bevor es kracht.", "Derive maintenance from vibration/temperature before failure."), href: P("/historian/") },
  ]},
  { name: L("Daten, BI & Historian", "Data, BI & historian"), terms: [
    { k: "Historian", d: L("Zeitreihen-Speicher jeder Maschine — Temperatur, Vibration.", "Time-series store per machine — temperature, vibration."), href: P("/historian/") },
    { k: L("Zeitreihe", "Time series"), d: L("Messwert über die Zeit, Grundlage für Trend und Alarm.", "A measurement over time, the basis for trend and alert."), href: P("/historian/") },
    { k: "OEE", d: L("Gesamtanlageneffektivität = Verfügbarkeit × Leistung × Qualität.", "Overall equipment effectiveness = availability × performance × quality."), href: BI, ext: true },
    { k: "Process-Drift", d: L("Schleichende Abweichung — die BI sieht sie vor der Endprüfung.", "Slow deviation — BI sees it before final inspection."), href: BI, ext: true },
    { k: L("Massenbilanz", "Mass balance"), d: L("Wo Material und Ausbeute verloren gehen.", "Where material and yield are lost."), href: BI, ext: true },
  ]},
  { name: L("ERP & Prozess", "ERP & process"), terms: [
    { k: L("Make-to-order", "Make-to-order"), d: L("Auf Bestellung fertigen statt auf Lager — Nordwerks Modell.", "Build to order rather than to stock — Nordwerk's model."), href: P("/werk/") },
    { k: "MRP", d: L("Materialbedarfsplanung: errechnet Bedarfe + Fertigungsaufträge.", "Material requirements planning: computes demand + production orders."), href: ERP, ext: true },
    { k: L("Stückliste (BOM)", "Bill of materials (BOM)"), d: L("Welche Rohstoffe in ein Produkt gehen.", "Which raw materials go into a product."), href: ERP, ext: true },
    { k: L("Charge / Los", "Batch / lot"), d: L("Eine rückverfolgbare Fertigungsmenge.", "A traceable production quantity."), href: P("/historian/") },
    { k: L("Kommissionierung (Picking)", "Picking"), d: L("Fertigware für den Versand zusammenstellen.", "Assembling finished goods for shipment."), href: ERP, ext: true },
    { k: L("Lead / Opportunity", "Lead / opportunity"), d: L("Eine Anfrage auf dem Weg zum Auftrag (CRM).", "An inquiry on its way to becoming an order (CRM)."), href: ERP, ext: true },
    { k: L("Servicevertrag / SLA", "Service contract / SLA"), d: L("Zugesicherte Wartung + Reaktionszeit für den Kunden.", "Committed maintenance + response time for the customer."), href: P("/portal/") },
    { k: L("Reklamation / 8D", "Complaint / 8D"), d: L("Schadensfall strukturiert lösen + Wiederholung verhindern.", "Resolve a damage case structurally + prevent recurrence."), href: P("/suche/") },
  ]},
  { name: L("KI, Betrieb & Souveränität", "AI, operations & sovereignty"), terms: [
    { k: L("KI-Antwort (RAG)", "AI answer (RAG)"), d: L("Sprachmodell antwortet nur auf Basis der eigenen Firmendaten, mit Quellen.", "A language model answers only from the company's own data, with sources."), href: P("/suche/") },
    { k: L("KI & Mensch", "AI & humans"), d: L("Was die KI übernimmt — und wofür es Menschen braucht.", "What the AI takes on — and what still needs humans."), href: P("/ki-mensch/") },
    { k: "Read-only", d: L("Ansehen, nichts kann kaputtgehen — alle Demos sind nur lesend.", "Look around, nothing can break — all demos are read-only."), href: P("/demos/") },
    { k: "Lock-in", d: L("Abhängigkeit von einem Anbieter — genau das vermeidet der Stack.", "Dependence on one vendor — exactly what the stack avoids."), href: P("/stack/") },
    { k: L("Souveränität", "Sovereignty"), d: L("Alles selbst gehostet, Daten bleiben im Haus.", "All self-hosted, data stays in-house."), href: P("/stack/") },
  ]},
  { name: L("Sicherheit & Compliance", "Security & compliance"), terms: [
    { k: "ISMS", d: L("Informationssicherheits-Managementsystem: Regeln, Risiken und Nachweise an einem Ort.", "Information security management system: rules, risks and evidence in one place."), href: P("/compliance/") },
    { k: "ISO 27001:2022", d: L("Der Standard für Informationssicherheit — 93 Controls in vier Themen (Annex A).", "The standard for information security — 93 controls in four themes (Annex A)."), href: P("/compliance/") },
    { k: "NIS2", d: L("EU-Richtlinie für kritische & wichtige Einrichtungen — Pflicht zur Risikovorsorge.", "EU directive for essential & important entities — duty of risk preparedness."), href: P("/compliance/") },
    { k: L("Risiko-Heatmap", "Risk heatmap"), d: L("Wahrscheinlichkeit × Auswirkung je Risiko, mit hinterlegter Maßnahme.", "Likelihood × impact per risk, with the measure attached."), href: P("/compliance/") },
    { k: "SIEM", d: L("Angriffserkennung: auffälliges Verhalten auf Servern und Clients wird alarmiert.", "Intrusion detection: suspicious behaviour on servers and clients is alerted."), href: P("/compliance/") },
    { k: "SSO / MFA", d: L("Ein Login per offenem Standard, zweiter Faktor als Schutz.", "One login via open standard, a second factor as protection."), href: P("/software-rollout/") },
    { k: L("Audit-Trail", "Audit trail"), d: L("Wer hat wann was getan — nachvollziehbar und manipulationssicher.", "Who did what when — traceable and tamper-evident."), href: P("/compliance/") },
  ]},
  { name: L("Betrieb & Resilienz", "Operations & resilience"), terms: [
    { k: L("Out-of-Band (OOB)", "Out-of-band (OOB)"), d: L("Zugang zur Maschine, auch wenn Netz oder Betriebssystem tot sind — eigener Mobilfunk.", "Access to the machine even when network or OS is dead — its own cellular link."), href: P("/resilienz/") },
    { k: L("Backup 3-2-1", "Backup 3-2-1"), d: L("Drei Kopien, zwei Medien, eine außer Haus.", "Three copies, two media, one off-site."), href: P("/resilienz/") },
    { k: L("Restore-Test", "Restore test"), d: L("Ein Backup zählt erst, wenn der Restore bewiesen ist.", "A backup only counts once the restore is proven."), href: P("/resilienz/") },
    { k: L("App-Kiosk", "App kiosk"), d: L("Self-Service-Software ohne Adminrechte für den Nutzer.", "Self-service software with no admin rights for the user."), href: P("/software-rollout/") },
    { k: "LAPS", d: L("Rotierendes lokales Admin-Passwort je Gerät — kein Domain-Admin nötig.", "A rotating local admin password per device — no domain admin needed."), href: P("/software-rollout/") },
    { k: "MDM", d: L("Mobile Geräte zentral verwalten: Enrollment, Kiosk-Modus, Apps, Sperren.", "Manage mobile devices centrally: enrollment, kiosk mode, apps, locking."), href: P("/software-rollout/") },
    { k: L("CMDB / Netz-BIM", "CMDB / network BIM"), d: L("Standorte, Geräte, VLANs und Verkabelung als lebendes Modell.", "Sites, devices, VLANs and cabling as a living model."), href: P("/koennen/") },
    { k: "Mesh-VPN", d: L("Verschlüsseltes Netz zwischen Standorten mit alternativen Wegen.", "An encrypted network between sites with alternative paths."), href: P("/stack/") },
  ]},
  { name: L("Kosten, Kennzahlen & Anlagen", "Costing, KPIs & assets"), terms: [
    { k: L("Lot-Costing", "Lot costing"), d: L("Selbstkosten je Charge, nachvollziehbar bis zum Beleg.", "Cost per batch, traceable down to the document."), href: P("/kosten/") },
    { k: L("Niederstwert (NRV)", "Net realisable value (NRV)"), d: L("Bestände zum niedrigeren Wert bewerten — automatisch, prüfsicher.", "Value inventory at the lower amount — automatic, audit-proof."), href: P("/kosten/") },
    { k: "Landed-Cost", d: L("Fracht, Zoll und Versicherung in die Materialkosten einrechnen.", "Roll freight, duty and insurance into material cost."), href: P("/kosten/") },
    { k: L("Management-Review", "Management review"), d: L("Regelmäßiger Review der Kennzahlen mit Maßnahmen und Verantwortlichen.", "Regular review of the KPIs with actions and owners."), href: P("/kennzahlen/") },
    { k: L("KPI-Snapshot", "KPI snapshot"), d: L("Jeder Monatsstand wird eingefroren — revisionssicher, keine Schönung.", "Every monthly state is frozen — audit-proof, no polishing."), href: P("/kennzahlen/") },
    { k: L("Instandhaltung (Asset)", "Maintenance (asset)"), d: L("Anlage, Norm, Prüffrist und Doku an einem Objekt.", "Asset, standard, inspection interval and docs on one object."), href: P("/instandhaltung/") },
    { k: "PED", d: L("EU-Druckgeräte-Richtlinie für Kessel, Behälter und Leitungen.", "EU Pressure Equipment Directive for vessels, tanks and lines."), href: P("/instandhaltung/") },
    { k: "MCP", d: L("Protokoll, über das die KI rechtegeprüft auf die Suche zugreift.", "Protocol through which the AI accesses search, permission-checked."), href: P("/suche/") },
    { k: L("NFC-Tracking", "NFC tracking"), d: L("Behälter per Funk-Chip scannen, Standort und Foto festhalten.", "Scan containers by radio chip, record location and photo."), href: P("/app/") },
  ]},
];
const total = groups.reduce((a, g) => a + g.terms.length, 0);
---
<section style="background:#F8F9FA;">
  <div style="max-width:1000px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0 0 16px;">{L("Glossar", "Glossary")}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(34px,6vw,64px); line-height:1.0; letter-spacing:-0.03em; margin:0 0 14px;">{L("Die Begriffe, kurz erklärt.", "The terms, briefly explained.")}</h1>
    <p style="font-size:clamp(17px,1.6vw,20px); line-height:1.6; color:#5C5E63; max-width:62ch; margin:0 0 clamp(32px,4vw,48px);">{L(`Von SPS bis Souveränität — ${total} Begriffe aus dieser Demo. Jeder verlinkt direkt dorthin, wo er live vorkommt.`, `From PLC to sovereignty — ${total} terms from this demo. Each links straight to where it shows up live.`)}</p>

    {groups.map((g) => (
      <div style="margin-bottom:clamp(28px,3.5vw,40px);">
        <div style="display:flex; align-items:baseline; gap:14px; margin-bottom:12px;">
          <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#16463E;">{g.name}</span>
          <span style="flex:1; height:1px; background:#E2E8F0;"></span>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:12px;">
          {g.terms.map((t) => { const sl = tagForLabel(t.k); const href = sl ? tagHref(sl, lang) : t.href; const ext = !sl && t.ext; return (
            <a href={href} target={ext ? "_blank" : undefined} rel={ext ? "noopener" : undefined} class={sl ? "taglink" : ""}
              style="text-decoration:none; color:#1B1C1E; border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:14px 16px; display:block;">
              <span style="display:flex; align-items:center; gap:8px;">
                <span style="font-weight:600; font-size:15px;">{t.k}</span>
                <span style="margin-left:auto; color:#92938F; font-size:13px;">{sl ? (de ? "suchen" : "search") + " ⌕" : (t.ext ? "↗" : "→")}</span>
              </span>
              <span style="display:block; font-size:14px; line-height:1.5; color:#5C5E63; margin-top:4px;">{t.d}</span>
            </a>
          ); })}
        </div>
      </div>
    ))}
  </div>
</section>
