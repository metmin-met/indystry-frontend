---
// /kennzahlen/ — Kennzahlen & Management-Review (KPI-System, snapshot-auditiert). Un-branded.
// Demo-Zahlen sind synthetisch (Nordwerk).
import type { Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const b = de ? "" : "/en";
const L = (d: string, e: string) => (de ? d : e);
const AC = "#3d4fc0"; // Domänen-Akzent (Kennzahlen/Daten)

// Beispiel-KPIs (synthetisch). to = Zielwert, suf = Suffix, pre = Präfix.
const kpis = [
  { k: "V", n: L("Termintreue", "On-time delivery"), to: 96, suf: "%", c: "#16794a" },
  { k: "V", n: L("Ausschussquote", "Scrap rate"), to: 2, suf: "%", c: "#c4673f", dec: 1, val: 2.3 },
  { k: "V", n: L("Anlagen-Effektivität (OEE)", "Overall equipment effectiveness"), to: 84, suf: "%", c: "#2a86a8" },
  { k: "M", n: L("Rohertragsmarge", "Gross margin"), to: 38, suf: "%", c: "#3d4fc0" },
  { k: "M", n: L("Liquiditätsreichweite", "Cash runway"), to: 11, suf: L(" Mon.", " mo"), c: "#7b5cc4" },
  { k: "V", n: L("Reklamationen / Quartal", "Complaints / quarter"), to: 4, suf: "", c: "#16794a" },
];
const cats = [
  { code: "M1–M14", t: L("Finanzkennzahlen", "Financial KPIs"), d: L("Umsatz, Rohertrag, Marge, Liquidität, Forderungen, Investitionen — der kaufmännische Puls.", "Revenue, gross profit, margin, liquidity, receivables, capex — the commercial pulse.") },
  { code: "V1–V13", t: L("Operative Kennzahlen", "Operational KPIs"), d: L("Durchsatz, Ausbeute, Ausschuss, Termintreue, OEE, Reklamationen — was in der Halle zählt.", "Throughput, yield, scrap, on-time delivery, OEE, complaints — what counts on the floor.") },
];
const feats = [
  { t: L("Snapshot-Audit", "Snapshot audit"), d: L("Jeder Monatsstand wird eingefroren — revisionssicher, keine nachträgliche Schönung.", "Every monthly state is frozen — audit-proof, no retroactive polishing.") },
  { t: L("Zeitreihe statt Momentaufnahme", "Time series, not a snapshot"), d: L("Trends über Monate und Jahre, weil jeder Stand erhalten bleibt.", "Trends across months and years, because every state is kept.") },
  { t: L("Management-Review", "Management review"), d: L("Strukturierter Review nach ISO-9001-Logik: Kennzahl → Bewertung → Maßnahme → Verantwortlicher.", "Structured review in ISO-9001 logic: metric → assessment → action → owner.") },
  { t: L("Eigenes Cockpit", "Own cockpit"), d: L("Dashboards direkt im ERP, gebaut mit offenen Chart-Bibliotheken — keine Vendor-Lizenz.", "Dashboards right in the ERP, built with open chart libraries — no vendor licence.") },
  { t: L("Aus echten Daten", "From real data"), d: L("Die Kennzahlen ziehen sich aus Produktion, Lager und Buchhaltung — kein manuelles Sammeln.", "KPIs pull from production, stock and accounting — no manual gathering.") },
  { t: L("Persönliche Sicht", "Personal view"), d: L("Jede Rolle sieht ihre relevanten Kennzahlen — nicht alle 27 auf einmal.", "Each role sees its relevant KPIs — not all 27 at once.") },
];
---
<!-- HERO -->
<section style="position:relative; background:#123A33; color:#F4F6F5; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-25%; left:58%; width:55%; height:90%; background:radial-gradient(circle,rgba(61,79,192,.20),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(52px,8vw,104px) clamp(24px,5vw,56px) clamp(40px,6vw,64px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px;">{L("Kennzahlen & Management-Review", "KPIs & management review")}</p>
    <h1 style="font-family:var(--font-head); font-weight:700; font-size:clamp(34px,6.5vw,68px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:16ch;">{L("27 Kennzahlen. Eine Wahrheit.", "27 KPIs. One truth.")} <span style="color:#E6B23A;">{L("Auf Knopfdruck.", "At a click.")}</span></h1>
    <p style="font-size:clamp(17px,1.7vw,21px); line-height:1.6; color:#CADAD5; max-width:64ch; margin:0;">{L("Das Management-Review zieht sich die Zahlen selbst — aus Produktion, Lager und Buchhaltung. Jeder Stand wird eingefroren, also lässt sich nichts schönrechnen. Demozahlen synthetisch.", "The management review pulls the numbers itself — from production, stock and accounting. Every state is frozen, so nothing can be massaged. Demo figures are synthetic.")}</p>
  </div>
</section>

<!-- KPI-KACHELN -->
<section style="background:#F8F9FA;">
  <div data-kpi style="max-width:1080px; margin:0 auto; padding:clamp(40px,5vw,64px) clamp(24px,5vw,56px) clamp(24px,3vw,32px);">
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px;">
      {kpis.map((m) => (
        <div style="border:1px solid #E2E8F0; border-radius:14px; background:#fff; padding:18px 20px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
            <span style="font-family:var(--font-mono); font-size:10px; font-weight:600; letter-spacing:0.08em; color:#92938F; border:1px solid #C0C8C5; border-radius:999px; padding:2px 7px;">{m.k}</span>
            <span style={`width:8px; height:8px; border-radius:50%; background:${m.c};`}></span>
          </div>
          <div style={`font-family:var(--font-head); font-weight:800; font-size:clamp(28px,3.4vw,40px); line-height:1; color:${m.c};`}><span class="kpi-c" data-to={m.to} data-dec={m.dec || 0} data-val={m.val || m.to}>{m.val || m.to}</span>{m.suf}</div>
          <div style="font-size:13.5px; color:#5C5E63; margin-top:8px; line-height:1.4;">{m.n}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- §01 KATEGORIEN -->
<section style="background:#F8F9FA;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(24px,3vw,40px) clamp(24px,5vw,56px) clamp(44px,6vw,72px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§01 · {L("Zwei Familien, 27 Kennzahlen", "Two families, 27 KPIs")}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:14px;">
      {cats.map((c) => (
        <div style={`border:1px solid #E2E8F0; border-top:3px solid ${AC}; border-radius:14px; background:#fff; padding:22px 24px;`}>
          <p style="font-family:var(--font-mono); font-size:12px; color:#92938F; margin:0 0 8px;">{c.code}</p>
          <p style="font-family:var(--font-head); font-weight:700; font-size:20px; color:#1B1C1E; margin:0 0 8px;">{c.t}</p>
          <p style="font-size:14.5px; line-height:1.6; color:#5C5E63; margin:0;">{c.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- §02 FEATURES (beige) -->
<section style="background:#EFEAE0;">
  <div style="max-width:1080px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">§02 · {L("Warum man den Zahlen trauen kann", "Why you can trust the numbers")}</span>
      <span style="flex:1; height:1px; background:#C0C8C5;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(248px,1fr)); gap:12px;">
      {feats.map((m) => (
        <div style="border:1px solid #E2E8F0; border-radius:12px; background:#fff; padding:16px 18px;">
          <p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{m.t}</p>
          <p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{m.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section style="position:relative; background:#0E2E29; color:#EAF1EE; overflow:hidden; background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px); background-size:46px 46px;">
  <div style="position:absolute; bottom:-20%; left:50%; transform:translateX(-50%); width:60%; height:80%; background:radial-gradient(circle,rgba(230,178,58,.13),transparent 60%); pointer-events:none;"></div>
  <div style="position:relative; max-width:1080px; margin:0 auto; padding:clamp(48px,7vw,96px) clamp(24px,5vw,56px); text-align:center;">
    <h2 style="font-family:var(--font-head); font-weight:800; font-size:clamp(28px,5vw,52px); line-height:1.02; letter-spacing:-0.035em; margin:0 auto; max-width:22ch;">{L("Wie lange dauert euer Monatsbericht?", "How long does your monthly report take?")}</h2>
    <p style="font-size:clamp(16px,1.7vw,20px); color:#C7D8D2; max-width:52ch; margin:20px auto 30px;">{L("Wenn die Antwort in Tagen gemessen wird, liegt hier die Abkürzung.", "If the answer is measured in days, here's the shortcut.")}</p>
    <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
      <a href={b + "/kontakt/"} style="background:#E6B23A; color:#123A33; text-decoration:none; font-family:var(--font-head); font-weight:700; font-size:16px; padding:15px 26px; border-radius:10px;">{L("Pain-List schicken", "Send pain list")} →</a>
      <a href={b + "/demos/"} style="font-family:var(--font-mono); font-size:13px; color:#A6CFC5; display:inline-flex; align-items:center;">{L("BI-Cockpit live ansehen", "See the BI cockpit live")} ↗</a>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce){ .kpi-c{ animation:none !important; } }
</style>
<script is:inline>
  (function(){
    var root = document.querySelector("[data-kpi]"); if(!root) return;
    var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(!e.isIntersecting) return;
      var el=e.target, to=parseFloat(el.getAttribute("data-to"))||0, dec=parseInt(el.getAttribute("data-dec"))||0,
          val=parseFloat(el.getAttribute("data-val"))||to, t0=performance.now(), dur=1100;
      (function step(t){ var p=Math.min((t-t0)/dur,1); var cur=val*(1-Math.pow(1-p,3));
        el.textContent = dec ? cur.toFixed(dec) : Math.round(cur); if(p<1) requestAnimationFrame(step); })(t0);
      io.unobserve(el); }); }, { threshold:0.5 });
    root.querySelectorAll(".kpi-c").forEach(function(el){ io.observe(el); });
  })();
</script>
