---
// Leitstand / SCADA (read-only, lang-aware): HMI-Kachelsicht der Nordwerk-Maschinen mit
// aktuellen Sensorwerten + Trend, aus demselben Warehouse-Snapshot wie Historian/Grafana.
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
---
<section style="background:#0E2522;" data-de={String(de)}>
  <div style="max-width:1180px; margin:0 auto; padding:clamp(40px,6vw,80px) clamp(20px,4vw,48px) clamp(64px,8vw,110px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:#A6CFC5; margin:0 0 14px;">{de ? "Leitstand · SCADA · read-only" : en ? "Control room · SCADA · read-only" : "中控室 · SCADA · read-only"}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(32px,5.5vw,60px); line-height:1.0; letter-spacing:-0.03em; color:#F4F6F5; margin:0 0 12px;">{de ? "Das Werk auf einen Blick." : en ? "The plant at a glance." : "全厂一览无余。"}</h1>
    <p style="font-size:clamp(16px,1.5vw,19px); line-height:1.6; color:#A6CFC5; max-width:60ch; margin:0 0 6px;">{de ? "Jede Maschine, ihr Zustand, ihre aktuellen Messwerte — die Operator-Sicht. Dieselben Daten wie im Historian und in der BI." : en ? "Every machine, its state, its current readings — the operator view. The same data as in the historian and BI." : "每台机器、其状态、其当前读数 — 操作员视角。与历史数据库和 BI 使用同一批数据。"}</p>
    <div style="display:flex; flex-wrap:wrap; gap:8px; margin:0 0 18px;">
      {["SCADA/HMI","OPC-UA","TimescaleDB","Echtzeit","read-only"].map((x) => (<span style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.06em; color:#A6CFC5; border:1px solid #2E5A52; border-radius:999px; padding:5px 12px;">{x}</span>))}
    </div>
    <p id="meta" style="font-family:var(--font-mono); font-size:12px; color:#6E8C84; margin:0 0 clamp(26px,3.5vw,38px);">{de ? "Snapshot wird geladen …" : en ? "Loading snapshot …" : "正在加载快照 …"}</p>
    <div id="tiles" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(270px,1fr)); gap:16px;"></div>
  </div>
</section>

<section style="background:#F8F9FA;">
  <div style="max-width:1180px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(20px,4vw,48px);">
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
      <span style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#16463E; white-space:nowrap;">{de ? "Was ein echter Leitstand leistet" : en ? "What a real control room does" : "真正的中控室能做什么"}</span>
      <span style="flex:1; height:1px; background:#E2E8F0;"></span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(248px,1fr)); gap:12px;">
      <div style="border:1px solid #E2E8F0; border-left:3px solid #16463E; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Eine Wahrheit" : en ? "One truth" : "唯一的事实来源"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Dieselbe Datenquelle wie Historian und BI — kein zweiter Zahlenstand, der widerspricht." : en ? "The same data source as historian and BI — no second set of numbers that contradicts." : "与历史数据库和 BI 同一数据源 — 不会出现互相矛盾的第二套数字。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-left:3px solid #16463E; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Alarmmanagement" : en ? "Alarm management" : "报警管理"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Normkonforme Alarme (OPC-UA Alarms & Conditions): Grenzwert mit Hysterese, melden → quittieren → klären, mit Historie — nicht nur Anzeige, sondern Handlungspfad." : en ? "Standard alarms (OPC-UA Alarms & Conditions): limit with hysteresis, raise → acknowledge → clear, with history — not just display, but a path to act." : "符合标准的报警（OPC-UA Alarms & Conditions）：带滞回的限值，触发 → 确认 → 消除，并保留历史 — 不仅是显示，更是处置路径。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-left:3px solid #16463E; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Herstellerneutral (OPC-UA)" : en ? "Vendor-neutral (OPC-UA)" : "厂商中立（OPC-UA）"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Koppelt an SPS und Leittechnik verschiedener Hersteller — eine Sicht über alles." : en ? "Couples to PLCs and control systems from different vendors — one view over all." : "对接不同厂商的 SPS 与主控系统 — 一个视图统览全局。"}</p></div>
      <div style="border:1px solid #E2E8F0; border-left:3px solid #16463E; border-radius:12px; background:#fff; padding:16px 18px;"><p style="font-weight:600; font-size:15px; color:#1B1C1E; margin:0 0 5px;">{de ? "Rollen & read-only" : en ? "Roles & read-only" : "角色权限与 read-only"}</p><p style="font-size:13px; line-height:1.5; color:#5C5E63; margin:0;">{de ? "Der Operator sieht alles, greift aber nur ein, wo es erlaubt ist — protokolliert." : en ? "The operator sees everything but only intervenes where allowed — logged." : "操作员可查看一切，但只能在获授权处干预 — 全程留痕。"}</p></div>
    </div>
    <p style="font-size:14px; line-height:1.6; color:#5C5E63; border-top:1px solid #E2E8F0; margin-top:24px; padding-top:18px; max-width:70ch;">{de ? "Die Werte kommen aus dem Historian, der Zwilling rechnet darauf weiter." : en ? "The values come from the historian, the twin computes on top of them." : "数值来自历史数据库，数字孪生在此基础上继续计算。"} <a href={(de?"":en?"/en":"/cn")+"/historian/"} style="color:#16463E; font-weight:600; text-decoration:none;">{de ? "Zum Historian" : en ? "To the historian" : "前往历史数据库"} →</a> &nbsp; <a href={(de?"":en?"/en":"/cn")+"/twin/"} style="color:#16463E; font-weight:600; text-decoration:none;">{de ? "Zum digitalen Zwilling" : en ? "To the digital twin" : "前往数字孪生"} →</a></p>
  </div>
</section>

<script>
  const DE = document.querySelector("[data-de]")?.getAttribute("data-de") === "true";
  const L = DE ? "de-DE" : "en-GB";
  const $ = (s) => document.querySelector(s);
  const ST = DE
    ? { run:{c:"#3FBF7F",t:"läuft"}, warn:{c:"#E6B23A",t:"Warnung"}, idle:{c:"#8A9A95",t:"kein Sensor"} }
    : { run:{c:"#3FBF7F",t:"running"}, warn:{c:"#E6B23A",t:"warning"}, idle:{c:"#8A9A95",t:"no sensor"} };

  function spark(vs, color) {
    if (!vs || !vs.length) return "";
    let v0 = Math.min(...vs), v1 = Math.max(...vs); if (v0===v1){v0--;v1++;}
    const w=240,h=40;
    const d = vs.map((v,i)=>(i?"L":"M")+(i/(vs.length-1)*w).toFixed(1)+" "+((h-3)-(h-6)*(v-v0)/(v1-v0)).toFixed(1)).join(" ");
    const lx=w.toFixed(1), ly=((h-3)-(h-6)*(vs[vs.length-1]-v0)/(v1-v0)).toFixed(1);
    return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none"><path d="${d}" fill="none" stroke="${color}" stroke-width="1.6"/><circle cx="${lx}" cy="${ly}" r="2.4" fill="${color}"><animate attributeName="opacity" values="1;.25;1" dur="1.4s" repeatCount="indefinite"/></circle></svg>`;
  }
  const clamp=(x,lo,hi)=>Math.max(lo,Math.min(hi,x));

  // Live-Modell: echte Baseline aus /_live, dazwischen sanftes Ticken (Sensor-Rauschen)
  let base=null; const buf={}; let metaDt=null, metaLive=false;
  function seed(d){
    base=d; metaLive=!!d.live; metaDt=new Date(d.generated*1000);
    const byM={}; d.series.forEach(x=>{ (byM[x.machine_id]=byM[x.machine_id]||{})[x.metric]=x; });
    const lat=d.latest||{};
    d.machines.forEach(m=>{
      const t=byM[m.id]&&byM[m.id].temperatur_c, v=byM[m.id]&&byM[m.id].vibration_mm_s;
      const has=!!(t||v);
      const baseT=lat[m.id+"_temperatur_c"], baseV=lat[m.id+"_vibration_mm_s"];
      const series=(t&&t.pts)?t.pts.map(p=>p.v).slice(-30):[];
      buf[m.id]={ has, name:m.name, line:m.line, kind:m.kind,
        baseT:(baseT!=null?baseT:(series.length?series[series.length-1]:42)),
        baseV:(baseV!=null?baseV:2),
        curT:(baseT!=null?baseT:(series.length?series[series.length-1]:42)),
        curV:(baseV!=null?baseV:2),
        temps: series.length?series:[baseT!=null?baseT:42] };
    });
  }
  function tick(){
    if(!base) return; const now=Date.now()/1000;
    base.machines.forEach((m,i)=>{ const b=buf[m.id]; if(!b||!b.has) return;
      b.curT=clamp(b.baseT + 1.1*Math.sin(now/3.1+i*1.7) + (Math.random()-0.5)*0.9, 24, 96);
      b.curV=clamp(b.baseV + 0.32*Math.sin(now/2.3+i*0.9) + (Math.random()-0.5)*0.22, 0.5, 9.5);
      b.temps.push(b.curT); if(b.temps.length>30) b.temps.shift();
    });
    paint();
  }
  function paint(){
    if(!base) return;
    $("#meta").textContent = `${metaLive?"\u25CF Live":"Snapshot"} ${metaDt.toLocaleDateString(L)} ${metaDt.toLocaleTimeString(L,{hour:"2-digit",minute:"2-digit"})} \u00B7 ${base.machines.length} ${DE ? "Maschinen \u00B7 read-only" : "machines \u00B7 read-only"}`;
    const tiles = $("#tiles"); tiles.innerHTML = "";
    base.machines.forEach(m => {
      const b=buf[m.id];
      const hasData=b&&b.has;
      let st="idle";
      if (hasData) { st="run"; if (b.curT>46 || b.curV>3.4) st="warn"; }
      const led = ST[st];
      const tile = document.createElement("div");
      tile.style.cssText = "border:1px solid #214740; border-radius:12px; background:#13322D; padding:16px; color:#E8EFEC;";
      tile.innerHTML = `
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:2px;">
          <span style="font:600 16px var(--font-head,sans-serif);">${m.name}</span>
          <span style="display:inline-flex;align-items:center;gap:6px;font:11px monospace;color:${led.c};">
            <span style="width:9px;height:9px;border-radius:50%;background:${led.c};box-shadow:0 0 8px ${led.c};animation:nwpulse 1.4s ease-in-out infinite;"></span>${led.t}</span>
        </div>
        <div style="font:11px monospace; color:#6E8C84; margin-bottom:12px;">${m.line} \u00B7 ${m.kind}</div>
        ${hasData ? `
          <div style="display:flex; gap:18px; margin-bottom:10px;">
            <div><div style="font:10px monospace;color:#6E8C84;">TEMP</div><div style="font:600 22px var(--font-mono,monospace);color:#E6B23A;">${b.curT.toFixed(1)}<span style="font-size:12px;color:#6E8C84;"> \u00B0C</span></div></div>
            <div><div style="font:10px monospace;color:#6E8C84;">VIBR</div><div style="font:600 22px var(--font-mono,monospace);color:#3FBF7F;">${b.curV.toFixed(2)}<span style="font-size:12px;color:#6E8C84;"> mm/s</span></div></div>
          </div>
          ${spark(b.temps, "#E6B23A")}`
        : `<div style="padding:14px 0 18px; color:#6E8C84; font:13px monospace;">${DE ? "Montage/Pr\u00FCfung \u2014<br>keine Sensor-Messreihe" : "Assembly/inspection \u2014<br>no sensor metric"}</div>`}
      `;
      tiles.appendChild(tile);
    });
  }
  function loadTel(){ return fetch("/_live/telemetry",{cache:"no-store"}).then(r=>{if(!r.ok)throw 0;return r.json();}).then(d=>{if(!d||!d.machines)throw 0;return d;}).catch(()=>fetch("/data/nordwerk-telemetry.json").then(r=>r.json())); }
  loadTel().then(d=>{ seed(d); paint(); }).catch(()=>{ $("#meta").textContent = DE ? "Daten nicht ladbar." : "Could not load data."; });
  setInterval(()=>loadTel().then(seed).catch(()=>{}), 30000);
  setInterval(tick, 2000);
</script>
<style>@keyframes nwpulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.35);opacity:.55}}</style>
