---
// Bento-Grid-Feature-Showcase (aus dem Stitch-ERP-Entwurf abgeleitet).
// Gemischt große Karten: Monitoring · Open-API-Dev (dunkel) · Gold-Kachel · Status.
import { type Lang } from "../../lib/content";
interface Props { lang: Lang }
const { lang } = Astro.props;
const de = lang === "de";
const en = lang === "en";
const machines = de
  ? [["Drehzentrum B1", "läuft"], ["CNC-Fräse A1", "läuft"], ["Montagezelle M2", "läuft"]]
  : en
  ? [["Lathe B1", "running"], ["CNC mill A1", "running"], ["Assembly cell M2", "running"]]
  : [["车削中心 B1", "运行中"], ["CNC 铣床 A1", "运行中"], ["装配单元 M2", "运行中"]];
---
<section style="background:#EFEAE0; border-top:1px solid #E2E8F0;">
  <div style="max-width:1280px; margin:0 auto; padding:clamp(96px,12vw,168px) clamp(24px,5vw,56px);">
    <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:16px; margin-bottom:clamp(8px,2vw,16px);">
      <p style="font-size:12px; font-weight:600; font-family:var(--font-mono); letter-spacing:0.14em; text-transform:uppercase; color:#16463E; margin:0;">{de ? "System — Präzision & Kontrolle" : en ? "System — precision & control" : "系统 — 精度与掌控"}</p>
      <p style="font-size:12px; font-family:var(--font-mono); letter-spacing:0.08em; color:#92938F; margin:0;">SELF-HOSTED · ON-PREM</p>
    </div>
    <h2 style="font-weight:600; font-size:clamp(28px,4vw,48px); line-height:1.05; letter-spacing:-0.025em; margin:0 0 clamp(36px,5vw,56px); max-width:22ch;">{de ? "Vom Sensor bis zur Auswertung — alles im Blick." : en ? "From sensor to insight — everything in view." : "从传感器到分析 — 一切尽在掌握。"}</h2>

    <div class="bento">
      <!-- Monitoring (groß) -->
      <div class="b-card b-monitor" style="background:#FFFFFF; border:1px solid #E2E8F0; border-radius:12px; padding:clamp(22px,3vw,32px);">
        <p style="font-weight:600; font-size:clamp(19px,2vw,22px); letter-spacing:-0.015em; margin:0 0 4px;">{de ? "Live-Produktionsüberwachung" : en ? "Live production monitoring" : "实时生产监控"}</p>
        <p style="font-size:15px; color:#5C5E63; margin:0 0 22px;">{de ? "Behalte jede Maschine im Blick." : en ? "Keep every machine in view." : "每台机器尽收眼底。"}</p>
        <div style="display:grid; gap:0;">
          {machines.map(([n, st]) => (
            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; padding:14px 0; border-top:1px solid #E2E8F0;">
              <span style="display:flex; align-items:center; gap:10px; font-family:var(--font-mono); font-size:13px; letter-spacing:0.04em; color:#1B1C1E;"><span style="width:8px; height:8px; border-radius:50%; background:#16794a;"></span>{n.toUpperCase()}</span>
              <span style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:#16794a;">{st}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Dev / Open API (dunkel) -->
      <div class="b-card b-dev blueprint" style="border-radius:12px; padding:clamp(22px,3vw,32px); color:#F8F9FA; display:flex; flex-direction:column;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px; margin-bottom:auto;">
          <span style="font-family:var(--font-mono); font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:#7C9A92;">{de ? "Entwickler-First" : en ? "Developer-first" : "开发者优先"}</span>
          <span style="font-family:var(--font-mono); font-size:11px; font-weight:600; letter-spacing:0.06em; color:#123A33; background:#E6B23A; border-radius:9999px; padding:4px 12px;">Open API</span>
        </div>
        <p style="font-weight:600; font-size:clamp(18px,1.8vw,21px); letter-spacing:-0.015em; margin:24px 0 8px;">{de ? "Voller Zugriff auf den Quellcode." : en ? "Full access to the source code." : "完全访问源代码。"}</p>
        <p style="font-size:14px; line-height:1.6; color:#9FB8B0; margin:0;">{de ? "Anpassungen auf Code-Ebene — keine versteckten Gebühren, kein Lock-in." : en ? "Customise at code level — no hidden fees, no lock-in." : "在代码层面定制 — 无隐藏费用，无厂商锁定。"}</p>
      </div>

      <!-- Gold-Kachel -->
      <div class="b-card b-gold" style="background:#E6B23A; border-radius:12px; padding:clamp(20px,2.5vw,28px); color:#123A33; display:flex; flex-direction:column; justify-content:space-between; min-height:150px;">
        <span style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; opacity:0.8;">{de ? "Betrieb" : en ? "Deployment" : "部署"}</span>
        <span style="font-weight:700; font-size:clamp(22px,2.4vw,28px); letter-spacing:-0.02em; font-family:var(--font-head);">{de ? "Eure Infrastruktur." : en ? "Your infrastructure." : "您的基础设施。"}</span>
      </div>

      <!-- Status (weiß) -->
      <div class="b-card b-status" style="background:#FFFFFF; border:1px solid #E2E8F0; border-radius:12px; padding:clamp(20px,2.5vw,28px); display:flex; flex-direction:column; justify-content:space-between; min-height:150px;">
        <span style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#92938F;">Status</span>
        <div>
          <p style="font-weight:600; font-size:16px; margin:0 0 4px; display:flex; align-items:center; gap:8px;"><span style="width:8px; height:8px; border-radius:50%; background:#16794a;"></span>{de ? "DSGVO-konform" : en ? "GDPR-compliant" : "符合 GDPR"}</p>
          <p style="font-size:13px; color:#5C5E63; margin:0;">{de ? "EU-Hosting · verschlüsseltes Backup" : en ? "EU hosting · encrypted backup" : "欧盟托管 · 加密备份"}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento { display: grid; gap: 16px; grid-template-columns: 1.5fr 1fr 1fr; }
  .b-monitor { grid-column: 1; grid-row: 1 / span 2; }
  .b-dev { grid-column: 2 / span 2; grid-row: 1; min-height: 200px; }
  .b-gold { grid-column: 2; grid-row: 2; }
  .b-status { grid-column: 3; grid-row: 2; }
  @media (max-width: 860px) {
    .bento { grid-template-columns: 1fr 1fr; }
    .b-monitor { grid-column: 1 / span 2; grid-row: auto; }
    .b-dev { grid-column: 1 / span 2; grid-row: auto; }
    .b-gold, .b-status { grid-column: auto; grid-row: auto; }
  }
  @media (max-width: 520px) { .bento { grid-template-columns: 1fr; } .b-gold, .b-status { grid-column: auto; } }
</style>
