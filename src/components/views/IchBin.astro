const TR: Record<string,string> = {"AD/SSO": "AD/SSO", "Abschluss-Anpassungen": "Final adjustments", "Allgemeine Tätigkeiten": "General tasks", "Angebotswesen": "Quotations", "Anlagenbau / Anlagentechnik": "Plant engineering / Construction", "Anlagenmontage": "Plant assembly", "Antriebstechnik": "Drive technology", "Audits": "Audits", "Auftragsabwicklung": "Order processing", "Auftragssteuerung": "Order control", "Auftragsvergabe": "Order placement", "Automatisierung": "Automation", "Bestellwesen": "Purchasing", "Buchhaltung": "Accounting", "Budgetplanung": "Budget planning", "Compliance": "Compliance", "Controller": "Controller", "Datenblätter/NDA": "Datasheets/NDA", "Datenpflege": "Data maintenance", "Debitoren": "Accounts receivable", "Dokumentenlenkung": "Document control", "ERP-Administration": "ERP administration", "Eigentümer-Familie": "Owner family", "Eigentümer-Reporting": "Owner reporting", "Einkauf": "Procurement", "Entgraten/Sortieren": "Deburring/Sorting", "Ersatzteilmanagement": "Spare parts management", "Eskalationsmanagement": "Escalation management", "Externer Auditor": "External auditor", "Ferialpraktikant": "Intern", "Fertigungsplanung": "Production planning", "Finanzverantwortung": "Financial responsibility", "Geschäftsleitung (GF)": "Management", "Helpdesk-Agent": "Helpdesk agent", "Hilfstätigkeiten": "Support tasks", "ISMS": "ISMS", "IT-Administrator": "IT administrator", "IT-Infrastruktur": "IT infrastructure", "IT-Onboarding": "IT onboarding", "Industriespion": "Industrial spy", "Instandhaltung": "Maintenance", "Instandsetzung": "Repairs", "Interne Audits": "Internal audits", "Interner Auditor / ISMS": "Internal auditor / ISMS", "Inventur": "Inventory", "Jahresabschluss": "Year-end closing", "Kalibrierung/Wartung": "Calibration/Maintenance", "Kommissionierung": "Picking", "Kontenabstimmung": "Account reconciliation", "Konzern-Konsolidierung": "Group consolidation", "Konzern-Reporting": "Group reporting", "Konzernverrechnung": "Intercompany billing", "Kostenrechnung": "Cost accounting", "Kreditoren": "Accounts payable", "Kunde": "Customer", "Kundenbetreuung": "Customer support", "Laboranalytik": "Lab analysis", "Lager- / Logistik-Verantwortlicher": "Warehouse/Logistics manager", "Lager-Berichtswesen": "Warehouse reporting", "Lager-Mitarbeiter": "Warehouse staff", "Lagerplanung": "Warehouse planning", "Latente Steuern": "Deferred taxes", "Leittechnik-Programmierer": "Control system programmer", "Leittechnik/SCADA": "Control systems/SCADA", "Lieferant": "Supplier", "Lieferantenmanagement": "Supplier management", "Main Audit": "Main audit", "Maintenance / Instandhaltung": "Maintenance", "Management-Reporting": "Management reporting", "Materialdisposition": "Material planning", "Messauswertung": "Measurement evaluation", "Messtechnik": "Measurement technology", "Mikroskopie/Analytik": "Microscopy/Analysis", "Mitarbeiter (allgemein)": "Employee (general)", "Mitbewerber": "Competitor", "Monitoring": "Monitoring", "Muster-Anfragen": "Sample requests", "Muttergesellschaft": "Parent company", "OPC-UA": "OPC-UA", "Operator / Werker": "Operator", "Opportunistischer Angreifer": "Opportunistic attacker", "PROFINET": "PROFINET", "Personal (HR)": "HR", "Personaleinteilung": "Staff scheduling", "Personalführung": "Personnel management", "Personalverwaltung": "HR administration", "Potentieller Kunde / Lead": "Potential customer / Lead", "Pre-Audit": "Pre-audit", "Produktions-KPIs": "Production KPIs", "Produktionsleitung": "Production management", "Produktionsplanung / Disposition": "Production planning", "Produktionsreporting": "Production reporting", "Projektsteuerung": "Project control", "Prozessentwicklung": "Process development", "Prüfmittelverwaltung": "Test equipment management", "Prüfzeugnisse/Konformität": "Test certificates/Conformity", "QM-Manager": "QM manager", "QM-System": "QM system", "Qualitätsprüfer": "Quality inspector", "Rechnungsstellung": "Invoicing", "Recruiting": "Recruiting", "Reklamation": "Complaint", "Reklamationsbearbeitung": "Complaint handling", "Rohmaterial-Lieferung": "Raw material delivery", "SPS-Programmierer": "PLC programmer", "SPS-Programmierung": "PLC programming", "Schichtführung": "Shift supervision", "Schichtleitung": "Shift management", "Schichtplanung": "Shift planning", "Schichtübergabe-Doku": "Shift handover docs", "Schulungsorganisation": "Training organization", "Staplerfahrer": "Forklift operator", "Steuerberater (extern)": "Tax advisor (external)", "Steuerbuchung": "Tax accounting", "Strategie": "Strategy", "Strategische Entscheidungen": "Strategic decisions", "Ticket-Bearbeitung": "Ticket handling", "Treasury": "Treasury", "Unterstützung Analytik": "Analytics support", "User-Support": "User support", "Verfahrenstechnik / R&D": "Process engineering / R&D", "Verpackung": "Packaging", "Versand": "Shipping", "Versandsteuerung": "Shipping control", "Versuchsplanung": "Test planning", "Vertriebs-Innendienst": "Sales back office", "Wareneingang": "Goods receipt", "Wareneingangsprüfung": "Goods receipt inspection", "Wartungsplanung": "Maintenance planning", "Werks-Audit": "Plant audit", "Werkstoffanalytik": "Material analysis", "Werkstoffprüfung": "Material testing", "Werkstudent": "Working student", "Wärmebehandlung": "Heat treatment", "Zeitwirtschaft": "Time management", "Zerspanung": "Machining", "Zertifizierungsaudits": "Certification audits"};
const tr = (x: string) => de ? x : (TR[x] || x);
const slug = (s: string) => s.toLowerCase().replace(/ä/g,"ae").replace(/ö/g,"oe").replace(/ü/g,"ue").replace(/ß/g,"ss").replace(/[^a-z0-9]+/g,"-").replace(/(^-|-$)/g,"");
const total = clusters.reduce((a,c)=>a+c.roles.length,0);
const mono = (s: string) => s.replace(/[^A-Za-zÄÖÜ]/g,"").slice(0,2).toUpperCase();
---
<section style="background:#123A33; color:#F4F6F5;">
  <div style="max-width:1180px; margin:0 auto; padding:clamp(52px,8vw,100px) clamp(24px,5vw,56px) clamp(36px,5vw,52px);">
    <p style="font-family:var(--font-mono); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px;">{L("Ich bin …", "I am …", "我是……")}</p>
    <h1 style="font-family:var(--font-head); font-weight:600; font-size:clamp(34px,6vw,68px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 16px; max-width:18ch;">{L("Das ganze Team. Auf Karten.", "The whole team. On cards.", "整个团队，尽在卡片上。")}</h1>
    <p style="font-size:clamp(16px,1.6vw,20px); line-height:1.6; color:#CADAD5; max-width:64ch; margin:0;">{L(`${total} Rollen einer Fertigung — jede mit ihrem Alltag und ihren Aufgaben. Filter über die Pills oder die Suche, klick eine Demo und sieh, was indystry für sie tut.`, `${total} roles of a manufacturer — each with their day and their tasks. Filter via the pills or search, click a demo and see what indystry does for them.`, `一家制造企业的 ${total} 个角色——每个都有各自的日常和任务。用标签或搜索筛选，点开一个演示，看看 indystry 为他们做了什么。`)}</p>
  </div>
</section>

<section style="background:#F8F9FA;">
  <div style="max-width:1180px; margin:0 auto; padding:clamp(28px,4vw,48px) clamp(24px,5vw,56px) clamp(72px,9vw,120px);">
    <div class="ib-controls">
      <input id="ib-search" type="search" autocomplete="off" placeholder={L("Suchen … Rolle, Aufgabe (z. B. Wartung, Rechnung)","Search … role, task (e.g. maintenance, invoice)","搜索……角色、任务（如：维护、发票）")} />
    </div>
    <div class="ib-chips" id="ib-clf">
      <button class="ib-chip" data-cl="" aria-pressed="true">{L("Alle","All","全部")} · {total}</button>
      {clusters.map((c) => <button class="ib-chip" data-cl={c.name} style={`--cc:${c.c}`}>{c.name} · {c.roles.length}</button>)}
    </div>
    <p id="ib-empty" hidden style="font-family:var(--font-mono); font-size:14px; color:#92938F;">{L("Keine Rolle passt — anderes Stichwort?","No role matches — try another keyword?","没有匹配的角色——换个关键词试试？")}</p>

    <div class="ib-grid">
      {clusters.map((c) => c.roles.map((r) => (
        <article id={slug(r.n)} class="pcard" data-cl={c.name} data-q={(tr(r.n)+" "+r.tags.map(tr).join(" ")+" "+tr(r.desc)+" "+tr(r.day)).toLowerCase()} style={`--cc:${c.c}`}>
          <div class="pcard-head">
            <span class="pcard-mono">{mono(tr(r.n))}</span>
            <div style="min-width:0;">
              <p class="pcard-cl">{c.name}</p>
              {PS.has(slug(r.n)) ? <a class="pcard-name taglink" href={tagHref(slug(r.n), lang)} title={L("Diese Rolle in der Suche","This role in search","在搜索中查看此角色")} style="text-decoration:none; color:inherit; display:block;">{tr(r.n)}</a> : <p class="pcard-name">{tr(r.n)}</p>}
            </div>
          </div>
          <p class="pcard-desc">{tr(r.desc)}</p>
          <div class="pcard-day"><span class="pcard-day-lbl">{L("Mein Tag","My day","我的一天")}</span> {tr(r.day)}</div>
          <div class="pcard-tags">{r.tags.map((t) => <button class="ptag" data-tag={tr(t).toLowerCase()}>{tr(t)}</button>)}</div>
          <div class="pcard-demos">{r.demos.map((d) => <a class="pdemo" href={d.h} target={d.x?"_blank":undefined} rel={d.x?"noopener":undefined}>{d.l} {d.x?"↗":"→"}</a>)}</div>
        </article>
      )))}
    </div>
  </div>
</section>

<style>
  .ib-controls { margin-bottom:14px; }
  #ib-search { width:100%; box-sizing:border-box; font-size:16px; padding:13px 16px; border:1px solid #C0C8C5; border-radius:12px; background:#fff; outline:none; font-family:inherit; }
  #ib-search:focus { border-color:#123A33; box-shadow:0 0 0 3px rgba(18,58,51,.08); }
  .ib-chips { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:26px; }
  .ib-chip { font-family:var(--font-mono); font-size:11.5px; padding:6px 12px; border:1px solid #C0C8C5; border-radius:999px; background:#fff; cursor:pointer; color:#5C5E63; transition:all .15s; }
  .ib-chip:hover { color:#1B1C1E; border-color:var(--cc,#123A33); }
  .ib-chip[aria-pressed="true"] { background:var(--cc,#123A33); color:#fff; border-color:var(--cc,#123A33); }
  .ib-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:16px; }
  .pcard { border:1px solid #E2E8F0; border-top:3px solid var(--cc); border-radius:14px; background:#fff; padding:18px; display:flex; flex-direction:column; gap:10px; scroll-margin-top:90px; transition:box-shadow .15s, transform .15s; }
  .pcard:hover { box-shadow:0 8px 24px rgba(11,28,25,.08); transform:translateY(-2px); }
  .pcard.flash { box-shadow:0 0 0 3px var(--cc); }
  .pcard[hidden] { display:none; }
  .pcard-head { display:flex; align-items:center; gap:11px; }
  .pcard-mono { flex:none; width:40px; height:40px; border-radius:10px; background:var(--cc); color:#fff; display:inline-flex; align-items:center; justify-content:center; font-family:var(--font-head,sans-serif); font-weight:600; font-size:15px; }
  .pcard-cl { font-family:var(--font-mono); font-size:10px; letter-spacing:.06em; text-transform:uppercase; color:#92938F; margin:0; }
  .pcard-name { font-family:var(--font-head,sans-serif); font-weight:600; font-size:17px; color:#1B1C1E; margin:1px 0 0; line-height:1.15; }
  .pcard-desc { font-size:14px; line-height:1.5; color:#3C3E42; margin:0; }
  .pcard-day { font-size:13.5px; line-height:1.55; color:#5C5E63; background:#F8F9FA; border-left:3px solid var(--cc); border-radius:0 8px 8px 0; padding:9px 12px; }
  .pcard-day-lbl { display:block; font-family:var(--font-mono); font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:var(--cc); margin-bottom:2px; }
  .pcard-tags { display:flex; flex-wrap:wrap; gap:6px; margin-top:auto; }
  .ptag { font-family:var(--font-mono); font-size:10.5px; color:#16463E; background:#EFEAE0; border:none; border-radius:999px; padding:3px 9px; cursor:pointer; }
  .ptag:hover { background:#E6D9C4; }
  .pcard-demos { display:flex; flex-wrap:wrap; gap:7px; }
  .pdemo { text-decoration:none; font-family:var(--font-mono); font-size:11.5px; font-weight:600; color:#fff; background:#123A33; border-radius:8px; padding:6px 11px; }
  .pdemo:hover { background:#0E2E29; }
</style>

<script>
  const search = document.getElementById("ib-search");
  const chips = Array.from(document.querySelectorAll(".ib-chip"));
  const cards = Array.from(document.querySelectorAll(".pcard"));
  const empty = document.getElementById("ib-empty");
  let activeCl = "";
  function apply() {
    const q = search.value.trim().toLowerCase();
    let any = false;
    cards.forEach((c) => {
      const m = (!q || c.dataset.q.includes(q)) && (!activeCl || c.dataset.cl === activeCl);
      c.hidden = !m; if (m) any = true;
    });
    empty.hidden = any;
  }
  search.addEventListener("input", apply);
  chips.forEach((ch) => ch.addEventListener("click", () => { activeCl = ch.dataset.cl; chips.forEach((x) => x.setAttribute("aria-pressed", String(x === ch))); apply(); window.scrollTo({ top: document.querySelector(".ib-controls").getBoundingClientRect().top + window.scrollY - 80, behavior:"smooth" }); }));
  document.querySelectorAll(".ptag").forEach((t) => t.addEventListener("click", () => { search.value = t.dataset.tag; activeCl=""; chips.forEach((x)=>x.setAttribute("aria-pressed",String(x.dataset.cl===""))); apply(); }));
  // Deep-Link: zur Karte scrollen + kurz hervorheben
  const h = decodeURIComponent((location.hash||"").replace("#",""));
  if (h) { const card = document.getElementById(h); if (card) { setTimeout(()=>{ card.scrollIntoView({behavior:"smooth",block:"center"}); card.classList.add("flash"); setTimeout(()=>card.classList.remove("flash"),1600); }, 300); } }
</script>
