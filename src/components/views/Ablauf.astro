---
// /ablauf/ — Prozess-Dokument als gestaltete Web-Seite: Hero + sticky Inhaltsverzeichnis (Scroll-Spy)
// + gerahmte Mermaid-Diagramme/Tabellen. Inhalt aus dem pandoc-Fragment (Single-Source zu .md/PDF).
// Regen bei Doku-Änderung: pandoc -f gfm -t html --no-highlight PROZESS-ABLAUF.md -o frontend/src/data/ablauf-content.txt
import html from "../../data/ablauf-content.txt?raw";
import htmlEn from "../../data/ablauf-content.en.txt?raw";
import { linkifyDemos } from "../../lib/linkify";
import PhaseMatrix from "./PhaseMatrix.astro";
interface Props { lang: "de" | "en" }
const { lang } = Astro.props;
const de = lang === "de";
const src = de ? html : htmlEn;
const L = (d: string, e: string) => (de ? d : e);
const chips = de
  ? ["Business + echter System-Status", "✅ klickbare Live-Demo", "aus der Demo-DB verifiziert"]
  : ["Business + real system status", "✅ clickable live demo", "verified from the demo DB"];

// Die flache „Phase → Live-Demo-Matrix“-Tabelle herausschneiden und durch das
// interaktive Herzstück ersetzen; den Rest des Dokuments klickbar machen (linkify).
const MARK = '<h2 id="5--phase--live-demo-matrix">';
const mi = src.indexOf(MARK);
const headRaw = mi >= 0 ? src.slice(0, mi) : src;
let tailRaw = "";
if (mi >= 0) { const rest = src.slice(mi); const te = rest.indexOf("</table>"); tailRaw = te >= 0 ? rest.slice(te + 8) : ""; }
const head = linkifyDemos(headRaw, lang);
const tail = linkifyDemos(tailRaw, lang);
---
<section class="ablauf-hero">
  <div class="ablauf-hero-inner">
    <p class="ablauf-eyebrow">{L("Auftragsfluss & Zustände", "Order flow & states")}</p>
    <h1 class="ablauf-h1">{L("Vom Bestelleingang bis zur Lieferung.", "From order intake to delivery.")}</h1>
    <p class="ablauf-lead">{L("Eine Bestellung, der ganze Weg durch die Firma — mit jedem Status, den sie durchläuft, und dem, was unser Stack in jeder Phase dafür tut.", "One order, the whole way through the company — with every state it passes through, and what our stack does in each phase.")}</p>
    <div class="ablauf-chips">{chips.map((c) => <span class="ablauf-chip">{c}</span>)}</div>
    <p class="ablauf-dl"><a href="/PROZESS-ABLAUF.pdf" download>{L("Ganzen Ablauf als PDF mitnehmen", "Take the whole flow as PDF")} ↓</a></p>
  </div>
</section>

<section class="ablauf-wrap">
  <div class="ablauf-layout">
    <aside class="ablauf-toc" aria-label={L("Auf dieser Seite", "On this page")}>
      <p class="ablauf-toc-title">{L("Auf dieser Seite", "On this page")}</p>
      <nav id="ablauf-toc-nav"></nav>
    </aside>
    <article class="ablauf-doc">
      <Fragment set:html={head} />
      <section class="ablauf-matrix">
        <h2 id="5--phase--live-demo-matrix">{L("5 · Phase → Live-Demo-Matrix", "5 · Phase → live-demo matrix")}</h2>
        <p class="ablauf-matrix-intro">{L("Jede Phase mit ihren passenden Live-Demos — alles anklickbar. Die ganze Reise als große Landkarte: ", "Every phase with its matching live demos — all clickable. The whole journey as one big map: ")}<a href={de ? "/landkarte/" : "/en/landkarte/"}>{L("Werks-Landkarte", "factory map")} →</a></p>
        <PhaseMatrix lang={lang} variant="embed" />
      </section>
      <Fragment set:html={tail} />
    </article>
  </div>
</section>

<style>
  .ablauf-hero { background:#123A33; color:#F4F6F5; }
  .ablauf-hero-inner { max-width:1180px; margin:0 auto; padding:clamp(52px,8vw,104px) clamp(24px,5vw,56px) clamp(44px,6vw,72px); }
  .ablauf-eyebrow { font-family:var(--font-mono,monospace); font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:#A6CFC5; margin:0 0 18px; }
  .ablauf-h1 { font-family:var(--font-head,sans-serif); font-weight:600; font-size:clamp(36px,6.5vw,72px); line-height:0.99; letter-spacing:-0.03em; margin:0 0 18px; max-width:18ch; }
  .ablauf-lead { font-size:clamp(17px,1.7vw,21px); line-height:1.6; color:#CADAD5; max-width:62ch; margin:0 0 26px; }
  .ablauf-chips { display:flex; flex-wrap:wrap; gap:10px; }
  .ablauf-chip { font-family:var(--font-mono,monospace); font-size:12px; color:#CADAD5; border:1px solid #2E5A52; border-radius:999px; padding:6px 13px; }

  .ablauf-wrap { background:#F8F9FA; }
  .ablauf-layout { max-width:1180px; margin:0 auto; padding:clamp(36px,5vw,72px) clamp(24px,5vw,56px) clamp(72px,9vw,120px); display:grid; grid-template-columns:1fr; gap:32px; }
  @media (min-width:1000px) { .ablauf-layout { grid-template-columns:230px minmax(0,1fr); gap:48px; } }

  .ablauf-toc { display:none; }
  @media (min-width:1000px) {
    .ablauf-toc { display:block; align-self:start; position:sticky; top:90px; max-height:calc(100dvh - 120px); overflow:auto; }
  }
  .ablauf-toc-title { font-family:var(--font-mono,monospace); font-size:11px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#92938F; margin:0 0 12px; }
  #ablauf-toc-nav a { display:block; font-size:13.5px; line-height:1.35; color:#5C5E63; text-decoration:none; padding:6px 0 6px 12px; border-left:2px solid #E2E8F0; }
  #ablauf-toc-nav a:hover { color:#16463E; }
  #ablauf-toc-nav a.active { color:#123A33; font-weight:600; border-left-color:#E6B23A; }

  .ablauf-doc { min-width:0; max-width:780px; }
  .ablauf-doc > h1:first-child { display:none; }
  .ablauf-doc > blockquote:first-of-type { background:#fff; border:1px solid #E2E8F0; border-left:3px solid #E6B23A; border-radius:0 12px 12px 0; padding:16px 20px; margin:0 0 32px; color:#3C3E42; }
  .ablauf-doc h2 { font-family:var(--font-head,sans-serif); font-weight:600; font-size:clamp(22px,3vw,30px); color:#123A33; margin:clamp(40px,5vw,60px) 0 16px; padding-bottom:8px; border-bottom:2px solid #E6B23A; scroll-margin-top:90px; }
  .ablauf-doc h3 { font-family:var(--font-head,sans-serif); font-weight:600; font-size:18px; color:#16463E; margin:26px 0 8px; scroll-margin-top:90px; }
  .ablauf-doc p { font-size:16px; line-height:1.65; color:#3C3E42; margin:8px 0; }
  .ablauf-doc blockquote { border-left:3px solid #C0C8C5; background:#fff; margin:14px 0; padding:8px 16px; color:#5C5E63; border-radius:0 8px 8px 0; }
  .ablauf-doc code { font-family:var(--font-mono,monospace); font-size:13px; background:#EFEAE0; padding:1px 6px; border-radius:4px; }
  .ablauf-doc strong { color:#1B1C1E; }
  .ablauf-doc table { border-collapse:separate; border-spacing:0; width:100%; margin:16px 0; font-size:14px; display:block; overflow-x:auto; border:1px solid #E2E8F0; border-radius:12px; background:#fff; }
  .ablauf-doc th, .ablauf-doc td { border-bottom:1px solid #EFEAE0; border-right:1px solid #EFEAE0; padding:9px 13px; text-align:left; vertical-align:top; }
  .ablauf-doc tr td:last-child, .ablauf-doc tr th:last-child { border-right:none; }
  .ablauf-doc tbody tr:last-child td { border-bottom:none; }
  .ablauf-doc th { background:#123A33; color:#fff; font-weight:600; white-space:nowrap; }
  .ablauf-doc a { color:#16463E; }
  .ablauf-doc hr { border:none; border-top:1px solid #E2E8F0; margin:32px 0; }
  .ablauf-doc ul, .ablauf-doc ol { margin:8px 0 8px 20px; }
  .ablauf-doc li { margin:4px 0; font-size:16px; line-height:1.6; color:#3C3E42; }
  .ablauf-doc .mermaid { background:#fff; border:1px solid #E2E8F0; border-radius:14px; padding:clamp(14px,2vw,24px); margin:18px 0; text-align:center; overflow-x:auto; box-shadow:0 1px 2px rgba(11,28,25,.04); }
  .ablauf-doc .mermaid svg { max-width:100%; height:auto; }
  .ablauf-dl { margin:18px 0 0; }
  .ablauf-dl a { font-family:var(--font-mono,monospace); font-size:12.5px; font-weight:600; color:#CADAD5; text-decoration:none; border:1px solid #2E5A52; border-radius:999px; padding:7px 14px; transition:background .15s,color .15s; }
  .ablauf-dl a:hover { background:#E6B23A; color:#123A33; border-color:#E6B23A; }
  .ablauf-matrix { margin-top:clamp(40px,5vw,60px); }
  .ablauf-matrix-intro { font-size:15px; line-height:1.6; color:#5C5E63; margin:0 0 20px; max-width:70ch; }
  .ablauf-matrix-intro a { color:#16463E; font-weight:600; text-decoration:none; }
  .ablauf-matrix-intro a:hover { text-decoration:underline; }
  .ablauf-doc .demo-chip { display:inline-flex; align-items:center; gap:5px; text-decoration:none; font-family:var(--font-mono,monospace); font-size:12px; font-weight:600; color:#15433b; background:color-mix(in srgb, var(--cc,#16463E) 10%, #fff); border:1px solid color-mix(in srgb, var(--cc,#16463E) 36%, #fff); border-radius:999px; padding:1px 9px; line-height:1.75; white-space:nowrap; transition:background .14s,border-color .14s; }
  .ablauf-doc .demo-chip:hover { background:color-mix(in srgb, var(--cc,#16463E) 20%, #fff); border-color:var(--cc,#16463E); }
</style>

<script>
  import mermaid from "mermaid";
  const root = document.querySelector(".ablauf-doc");
  if (root) {
    // Mermaid
    root.querySelectorAll("pre.mermaid, pre > code.mermaid, code.language-mermaid").forEach((el) => {
      const pre = el.closest("pre") || el;
      const div = document.createElement("div");
      div.className = "mermaid";
      div.textContent = el.textContent || "";
      pre.replaceWith(div);
    });
    mermaid.initialize({ startOnLoad: false, theme: "neutral", securityLevel: "strict", flowchart: { useMaxWidth: true } });
    mermaid.run({ nodes: Array.from(root.querySelectorAll(".mermaid")) }).catch(() => {});

    // Inhaltsverzeichnis aus den H2 + Scroll-Spy
    const nav = document.getElementById("ablauf-toc-nav");
    const heads = Array.from(root.querySelectorAll("h2[id]"));
    if (nav && heads.length) {
      const map = new Map();
      heads.forEach((h) => {
        const a = document.createElement("a");
        a.href = "#" + h.id;
        a.textContent = h.textContent || "";
        nav.appendChild(a);
        map.set(h.id, a);
      });
      const spy = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            map.forEach((a) => a.classList.remove("active"));
            const a = map.get(en.target.id);
            if (a) a.classList.add("active");
          }
        });
      }, { rootMargin: "-80px 0px -70% 0px", threshold: 0 });
      heads.forEach((h) => spy.observe(h));
    }
  }
</script>
